#!/bin/sh
# Publish the Lily Design System helper packages.
#
#   - npm packages: the svelte / react / vue / angular / html / nunjucks
#     `*-{theme,locale,text-size}-select` helpers (18 packages).
#   - NuGet packages: the Blazor `*-select` helpers (3 packages).
#
# Usage:
#   bin/publish-helpers --dry-run     # validate tarballs/packs, publish nothing
#   bin/publish-helpers               # publish for real
#
# Requirements for a real publish:
#   - npm:   `npm login` (or NPM_TOKEN in ~/.npmrc) with rights to the
#            `lily-design-system-*` package names.
#   - NuGet: NUGET_API_KEY env var with push rights to nuget.org.
#
# Note: the npm helper packages ship their source (`main` -> ./index.ts),
# matching the catalog convention; consumers compile the source via their
# own bundler.
set -eu

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DRY=""
if [ "${1:-}" = "--dry-run" ]; then DRY="--dry-run"; fi

echo "== npm helper packages =="
# svelte / react / vue / html / nunjucks: each package's `prepublishOnly`
# runs the catalog's dist build, so publish from the package root.
for d in "$ROOT"/lily-design-system-svelte-helpers/lily-design-system-*-select \
         "$ROOT"/lily-design-system-react-helpers/lily-design-system-*-select \
         "$ROOT"/lily-design-system-vue-helpers/lily-design-system-*-select \
         "$ROOT"/lily-design-system-html-helpers/lily-design-system-*-select \
         "$ROOT"/lily-design-system-nunjucks-helpers/lily-design-system-*-select; do
  [ -f "$d/package.json" ] || continue
  echo "--> $(basename "$d")"
  ( cd "$d" && npm publish --access public $DRY )
done

# Angular: ng-packagr writes the publishable package.json INTO dist/, so the
# catalog must be built first and each package published from its dist/.
echo "--> building angular dist (ng-packagr)"
pnpm -C "$ROOT/lily-design-system-angular-helpers" build
for d in "$ROOT"/lily-design-system-angular-helpers/lily-design-system-*-select; do
  [ -d "$d/dist" ] || continue
  echo "--> $(basename "$d") (from dist/)"
  ( cd "$d/dist" && npm publish --access public $DRY )
done

echo "== Blazor NuGet packages =="
NUPKG_OUT="$ROOT/dist-nuget"
for proj in "$ROOT"/lily-design-system-blazor-helpers/lily-design-system-blazor-*-select/*.csproj; do
  [ -f "$proj" ] || continue
  echo "--> pack $(basename "$proj")"
  dotnet pack "$proj" -c Release -o "$NUPKG_OUT"
done
if [ -z "$DRY" ]; then
  : "${NUGET_API_KEY:?set NUGET_API_KEY to push to nuget.org}"
  for pkg in "$NUPKG_OUT"/*.nupkg; do
    echo "--> push $(basename "$pkg")"
    dotnet nuget push "$pkg" --source https://api.nuget.org/v3/index.json --api-key "$NUGET_API_KEY" --skip-duplicate
  done
else
  echo "(dry run: packed .nupkg into $NUPKG_OUT, did not push)"
fi
