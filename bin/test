#!/bin/sh
set -euf

## https://github.com/sixarm/unix-shell-script-kit

err() { >&2 printf %s\\n "Error: ${*}"; }

directory_exists_or_err() { test -d "$1" || err "Directory should exist: $1"; }
file_exists_or_err() { test -f "$1" || err "File should exist: $1"; }
file_size_or_err() { file_exists_or_err "$1" && test -s "$1" || err "File should have size: $1"; }
symlink_exists_or_err() { test -h "$1" || err "Symlink should exist: $1"; }
grep_exists_or_err() { grep -q -m 1 "$@" || err "grep should exist: " "$@"; }
task_exists_or_err() { grep -q -m 1 "^- \[" "$1" || err "task should exist: " "$1"; }
implemented_or_err() { if (grep -q -m 1 "Not yet implemented\." "$1"); then err "not yet implemented: $1"; else true; fi; }

## Utilities

repo_setup_exists_or_err() (
    # dir="$1"
    file_size_or_err "$1/CITATION.cff"
    file_size_or_err "$1/CODE_OF_CONDUCT.md"
    file_size_or_err "$1/LICENSE.md"
)

ai_exists_or_err() (
    # dir="$1" — the spec-driven-development convention is a spec/
    # directory of specification files per directory, entered via
    # spec/index.md; older single-file spec/index.md (and the still-older
    # plan.md / tasks.md split) have been merged into it.
    directory_exists_or_err "$1"
    file_size_or_err "$1/index.md"
    symlink_exists_or_err "$1/README.md"
    file_size_or_err "$1/AGENTS.md" && implemented_or_err "$1/AGENTS.md"
    file_size_or_err "$1/CLAUDE.md"
    directory_exists_or_err "$1/spec"
    file_size_or_err "$1/spec/index.md" && implemented_or_err "$1/spec/index.md"
)

## Main

top="$(git rev-parse --show-toplevel)"

# repo_root_ai_exists_or_err is identical to ai_exists_or_err now that
# every dir uses spec/index.md; kept as an alias for callers that read more
# naturally with the repo-root phrasing.
repo_root_ai_exists_or_err() (
    ai_exists_or_err "$1"
)

test_repository() {
    repo_setup_exists_or_err "$top"
    repo_root_ai_exists_or_err "$top"
}

test_components() {
    "$top/bin/list-components-as-kebab-case" | 
    while read -r component; do
        ai_exists_or_err "$top/components/$component"
    done
}

test_lilydesignsystem_github_io() {
    "$top/bin/list-components-as-kebab-case" | 
    while read -r component; do
        dir="$top/lilydesignsystem.github.io/src/routes/components/$component"
        ai_exists_or_err "$dir"
        file_size_or_err "$dir/+page.svelte"
    done
}

test_implementations() {
    "$top/bin/list-implementations" | 
    while read -r implementation; do
        dir="$top/$implementation"
        ai_exists_or_err "$dir"
        file_exists_or_err "$dir/.git-subtree-push"
    done
}

test_implementations_with_vite() {
    "$top/bin/list-implementations" | grep \(react-next-examples\|svelte-sveltekit-examples\|vue-nuxt-examples\) |
    while read -r implementation; do
        dir="$top/$implementation"
        file_size_or_err "$dir/package.json"
        file_size_or_err "$dir/pnpm-lock.yaml"
        file_size_or_err "$dir/tsconfig.json"
        file_size_or_err "$dir/vite.config.ts"
        file_size_or_err "$dir/vitest-setup.js"
    done
}

test_implementations_with_svelte() {
    # Only the svelte component libraries follow the src/lib/components
    # layout. Exclude the *-helpers catalogs, which hold a couple of
    # opinionated helper subprojects rather than the 492-component set.
    "$top/bin/list-implementations" | grep svelte- | grep -v -- '-helpers' |
    while read -r implementation; do
        "$top/bin/list-components-as-pascal-case" | 
        while read -r component; do
            dir="$top/$implementation/src/lib/components/$component"
            file_size_or_err "$dir/index.md"
            file_size_or_err "$dir/$component.svelte"
            file_size_or_err "$dir/$component.stories.svelte"
            file_size_or_err "$dir/$component.test.ts"
            rm -f "$dir/$component.md"
        done
    done
}

test_implementation_nunjucks_headless() {
    "$top/bin/list-implementations" | grep nunjucks-headless |
    while read -r implementation; do
        "$top/bin/list-components-as-kebab-case" | 
        while read -r component; do
            dir="$top/$implementation/components/$component"
            file_size_or_err "$dir/macro.njk"
            file_size_or_err "$dir/macro.test.js"
            file_size_or_err "$dir/index.md"
        done
    done
}

test_implementation_nunjucks_example() {
    "$top/bin/list-implementations" | grep nunjucks-example |
    while read -r implementation; do
        "$top/bin/list-components-as-kebab-case" | 
        while read -r component; do
            dir="$top/$implementation/components"
            file_size_or_err "$dir/$component.njk"
        done
    done
}

test_repository
test_components
test_lilydesignsystem_github_io
test_implementations
test_implementations_with_vite
test_implementations_with_svelte
test_implementation_nunjucks_headless
test_implementation_nunjucks_example
