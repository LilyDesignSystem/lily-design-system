#!/bin/sh
set -euf

## https://github.com/sixarm/unix-shell-script-kit

# Errors are collected via a flag file (functions below run in
# subshells, so a plain variable would not survive); the script
# exits non-zero if any check failed.
ERRFLAG="$(mktemp)"
trap 'rm -f "$ERRFLAG"' EXIT

err() { >&2 printf %s\\n "Error: ${*}"; printf 1 >> "$ERRFLAG"; }

directory_exists_or_err() { test -d "$1" || err "Directory should exist: $1"; }
file_exists_or_err() { test -f "$1" || err "File should exist: $1"; }
file_size_or_err() { file_exists_or_err "$1" && test -s "$1" || err "File should have size: $1"; }
symlink_exists_or_err() { test -h "$1" || err "Symlink should exist: $1"; }
grep_exists_or_err() { grep -q -m 1 "$@" || err "grep should exist: " "$@"; }
task_exists_or_err() { grep -q -m 1 "^- \[" "$1" || err "task should exist: " "$1"; }
implemented_or_err() { if (grep -q -m 1 "Not yet implemented\." "$1"); then err "not yet implemented: $1"; else true; fi; }

## Utilities

repo_setup_exists_or_err() (
    # dir="$1"
    file_size_or_err "$1/CITATION.cff"
    file_size_or_err "$1/CODE_OF_CONDUCT.md"
    file_size_or_err "$1/LICENSE.md"
)

ai_exists_or_err() (
    # dir="$1" — the spec-driven-development convention is a spec/
    # directory of specification files per directory, entered via
    # spec/index.md; older single-file spec.md (and the still-older
    # plan.md / tasks.md split) have been merged into it.
    directory_exists_or_err "$1"
    file_size_or_err "$1/index.md"
    symlink_exists_or_err "$1/README.md"
    file_size_or_err "$1/AGENTS.md" && implemented_or_err "$1/AGENTS.md"
    file_size_or_err "$1/CLAUDE.md"
    directory_exists_or_err "$1/spec"
    file_size_or_err "$1/spec/index.md" && implemented_or_err "$1/spec/index.md"
)

## Main

top="$(git rev-parse --show-toplevel)"

# repo_root_ai_exists_or_err is identical to ai_exists_or_err now that
# every dir uses spec/index.md; kept as an alias for callers that read
# more naturally with the repo-root phrasing.
repo_root_ai_exists_or_err() (
    ai_exists_or_err "$1"
)

test_repository() {
    repo_setup_exists_or_err "$top"
    repo_root_ai_exists_or_err "$top"
}

# The canonical catalog must be internally consistent, and every
# hand-off copy of it (component dirs, CSS hooks, example-app
# registries) must carry exactly one entry per catalog row. Every
# defect class here has occurred in practice.
test_catalog_consistency() {
    tsv="$top/components.tsv"
    count="$(wc -l < "$tsv" | tr -d ' ')"

    dups="$(cut -f1 "$tsv" | sort | uniq -d)"
    test -z "$dups" || err "duplicate slugs in components.tsv: $dups"
    dup_names="$(cut -f2 "$tsv" | sort | uniq -d)"
    test -z "$dup_names" || err "duplicate PascalCase names in components.tsv: $dup_names"

    # components/ directories <-> catalog rows, both directions.
    cut -f1 "$tsv" | sort > "${ERRFLAG}.slugs"
    find "$top/components" -mindepth 1 -maxdepth 1 -type d -not -name '.*' -exec basename {} \; | sort > "${ERRFLAG}.dirs"
    missing_dirs="$(comm -23 "${ERRFLAG}.slugs" "${ERRFLAG}.dirs")"
    test -z "$missing_dirs" || err "catalog slugs without components/ dir: $missing_dirs"
    orphan_dirs="$(comm -13 "${ERRFLAG}.slugs" "${ERRFLAG}.dirs")"
    test -z "$orphan_dirs" || err "components/ dirs not in catalog: $orphan_dirs"

    # css-style-sheet-template.css: exactly one hook per slug.
    while read -r slug; do
        hooks="$(grep -c "^\.$slug {" "$top/css-style-sheet-template.css" || true)"
        test "$hooks" = "1" || err "css-style-sheet-template.css has $hooks hooks for: $slug"
    done < "${ERRFLAG}.slugs"

    rm -f "${ERRFLAG}.slugs" "${ERRFLAG}.dirs"

    # Example-app registries carry one entry per catalog row.
    registry_count_or_err() {
        # file="$1" pattern="$2"
        n="$(grep -c "$2" "$1" || true)"
        test "$n" = "$count" || err "registry $1 has $n entries; catalog has $count"
    }
    registry_count_or_err "$top/lily-design-system-svelte-sveltekit-examples/src/lib/data/components.ts" 'slug: "'
    registry_count_or_err "$top/lily-design-system-react-next-examples/app/data/components.ts" 'slug: "'
    registry_count_or_err "$top/lily-design-system-vue-nuxt-examples/data/components.ts" 'slug: "'
    registry_count_or_err "$top/lily-design-system-blazor-web-examples/src/LilyBlazorWebExamples/Data/ComponentData.cs" '^        new("'
    registry_count_or_err "$top/lily-design-system-html-css-js-examples/pages/components/index.html" 'slug: "'
    registry_count_or_err "$top/lily-design-system-html-css-js-examples/pages/components/component.html" 'slug: "'
    registry_count_or_err "$top/lilydesignsystem.github.io/src/lib/components.ts" 'name: "'
    registry_count_or_err "$top/lily-design-system-svelte-sveltekit-examples/src/lib/data/component-demos.ts" "^  '"
    registry_count_or_err "$top/lily-design-system-react-next-examples/app/data/component-demos.ts" "^  '"
    registry_count_or_err "$top/lily-design-system-vue-nuxt-examples/data/component-demos.ts" "^  '"
    registry_count_or_err "$top/lily-design-system-angular-examples/src/app/component-demos.ts" "^  '"
    registry_count_or_err "$top/index.md" '^- \[.*\](components/'
}

test_components() {
    "$top/bin/list-components-as-kebab-case" |
    while read -r component; do
        ai_exists_or_err "$top/components/$component"
    done
}

test_lilydesignsystem_github_io() {
    "$top/bin/list-components-as-kebab-case" |
    while read -r component; do
        dir="$top/lilydesignsystem.github.io/src/routes/components/$component"
        ai_exists_or_err "$dir"
        file_size_or_err "$dir/+page.svelte"
    done
}

test_implementations() {
    "$top/bin/list-implementations" |
    while read -r implementation; do
        dir="$top/$implementation"
        ai_exists_or_err "$dir"
        file_exists_or_err "$dir/.git-subtree-push"
    done
}

test_implementations_with_vite() {
    "$top/bin/list-implementations" | grep \(react-next-examples\|svelte-sveltekit-examples\|vue-nuxt-examples\) |
    while read -r implementation; do
        dir="$top/$implementation"
        file_size_or_err "$dir/package.json"
        file_size_or_err "$dir/pnpm-lock.yaml"
        file_size_or_err "$dir/tsconfig.json"
        file_size_or_err "$dir/vite.config.ts"
        file_size_or_err "$dir/vitest-setup.js"
    done
}

test_implementations_with_svelte() {
    # Only the svelte component libraries follow the src/lib/components
    # layout. Exclude the *-helpers catalogs, which hold a couple of
    # opinionated helper subprojects rather than the full component set.
    "$top/bin/list-implementations" | grep svelte- | grep -v -- '-helpers' |
    while read -r implementation; do
        "$top/bin/list-components-as-pascal-case" |
        while read -r component; do
            dir="$top/$implementation/src/lib/components/$component"
            file_size_or_err "$dir/index.md"
            file_size_or_err "$dir/$component.svelte"
            file_size_or_err "$dir/$component.stories.svelte"
            file_size_or_err "$dir/$component.test.ts"
            rm -f "$dir/$component.md"
        done
    done
}

test_implementation_nunjucks_headless() {
    "$top/bin/list-implementations" | grep nunjucks-headless |
    while read -r implementation; do
        "$top/bin/list-components-as-kebab-case" |
        while read -r component; do
            dir="$top/$implementation/components/$component"
            file_size_or_err "$dir/macro.njk"
            file_size_or_err "$dir/macro.test.js"
            file_size_or_err "$dir/index.md"
        done
    done
}

test_implementation_nunjucks_example() {
    "$top/bin/list-implementations" | grep nunjucks-example |
    while read -r implementation; do
        "$top/bin/list-components-as-kebab-case" |
        while read -r component; do
            dir="$top/$implementation/components"
            file_size_or_err "$dir/$component.njk"
        done
    done
}

##
# Helper chooser glyphs must not appear as bare non-ASCII characters in the
# places that RENDER them: the exported constant, and the icon markup. A
# bare glyph is near-invisible in an editor and a variation selector
# (U+FE0E) has no visual form at all — one was nearly lost to a careless
# edit, and a plain sed cannot see a numeric codepoint assertion either.
#
# Code contexts must use an escape ("\u27A4"); markup contexts must use an
# HTML entity (&#10148;). Prose is not checked: a changelog explaining that
# the glyph moved from one character to another has to show them.
#
# ASCII "A" (U+0041) is exempt — it cannot be mangled, and escaping it
# would only make it harder to read.
##
test_helper_glyphs_are_escaped() (
    # NOTE: this script runs under `set -euf`; -f disables globbing, so
    # file lists come from find, as everywhere else here.
    find "$top" -type d -name 'lily-design-system-*-chooser' -not -path '*/node_modules/*' \
    | while IFS= read -r pkg; do
        find "$pkg" -maxdepth 1 -type f \
            \( -name '*.ts' -o -name '*.tsx' -o -name '*.vue' -o -name '*.svelte' \
               -o -name '*.cs' -o -name '*.js' -o -name '*.njk' -o -name '*.razor' \) \
        | while IFS= read -r file; do
            case "$file" in *.test.*|*.spec.*|*Tests.cs) continue ;; esac

            # The exported glyph constant, in any framework's spelling.
            if grep -e 'CIRCLE_WITH_RIGHT_HALF_BLACK *=' -e 'GLOBE_WITH_MERIDIANS *=' \
                    -e 'BLACK_RIGHTWARDS_ARROWHEAD *=' -e 'CircleWithRightHalfBlack *=' \
                    -e 'GlobeWithMeridians *=' -e 'BlackRightwardsArrowhead *=' "$file" \
               | grep -q -e '◑' -e '➤' -e '🌐' -e '︎'; then
                err "glyph constant holds a bare character; use an escape such as \\u27A4: $file"
            fi

            # The icon markup that emits the glyph.
            if grep -- '-chooser-icon' "$file" | grep -q -e '◑' -e '➤' -e '🌐' -e '︎'; then
                err "icon markup holds a bare character; use an entity such as &#10148;: $file"
            fi
        done
    done
)

test_repository
test_catalog_consistency
test_components
test_lilydesignsystem_github_io
test_implementations
test_implementations_with_vite
test_implementations_with_svelte
test_implementation_nunjucks_headless
test_implementation_nunjucks_example
test_helper_glyphs_are_escaped

if test -s "$ERRFLAG"; then
    >&2 printf %s\\n "bin/test: FAILED"
    exit 1
fi
