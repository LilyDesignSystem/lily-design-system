#!/bin/sh
set -euf

## https://github.com/sixarm/unix-shell-script-kit

err() { >&2 printf %s\\n "Error: ${*}"; }

directory_exists_or_err() { test -d "$1" || err "Directory should exist: $1"; }
file_exists_or_err() { test -f "$1" || err "File should exist: $1"; }
file_not_empty_or_err() { file_exists_or_err "$1" && test -s "$1" || err "File should be not empty: $1"; }
symlink_exists_or_err() { test -h "$1" || err "Symlink should exist: $1"; }

## Utilities

repo_setup_exists_or_err() (
    # dir="$1"
    file_not_empty_or_err "$1/CITATION.cff"
    file_not_empty_or_err "$1/CODE_OF_CONDUCT.md"
    file_not_empty_or_err "$1/LICENSE.md"
)

ai_exists_or_err() (
    # dir="$1"
    directory_exists_or_err "$1"
    file_not_empty_or_err "$1/index.md"
    symlink_exists_or_err "$1/README.md"
    file_not_empty_or_err "$1/AGENTS.md"
    file_not_empty_or_err "$1/CLAUDE.md"
    file_not_empty_or_err "$1/plan.md"
    file_not_empty_or_err "$1/tasks.md"
)

## Main

top="$(git rev-parse --show-toplevel)"

## Test repository
repo_setup_exists_or_err "$top"
ai_exists_or_err "$top"

## Test components
"$top/bin/list-components-as-kebab-case" | 
while read -r component; do
    ai_exists_or_err "$top/components/$component"
done

## Test implementations
"$top/bin/list-implementations" | 
while read -r implementation; do
    dir="$top/$implementation"
    ai_exists_or_err "$dir"
    file_exists_or_err "$dir/.git-subtree-push"
done

## Test implementations that use our preferred JavaScript + TypeScript + Vite + PNPM
"$top/bin/list-implementations" | grep \(react-next-examples\|svelte-sveltekit-examples\|vue-nuxt-examples\) |
while read -r implementation; do
    dir="$top/$implementation"
    file_exists_or_err "$dir/package.json"
    file_exists_or_err "$dir/pnpm-lock.yaml"
    file_exists_or_err "$dir/tsconfig.json"
    file_exists_or_err "$dir/vite.config.ts"
    file_exists_or_err "$dir/vitest-setup.js"
done

## Test implementations that use Svelte SvelteKit examples
"$top/bin/list-implementations" | grep svelte-sveltekit-examples |
while read -r implementation; do
    dir="$top/$implementation"
    directory_exists_or_err "$dir/src/lib/components"
    "$top/bin/list-components-as-title-case/$component_title_case" | 
    while read -r component; do
        file_exists_or_err "$dir/index.md"
        file_exists_or_err "$dir/$component_title_case.svelte"
        file_exists_or_err "$dir/$component_title_case.stories.svelte"
    done
done
