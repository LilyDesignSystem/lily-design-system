#!/bin/sh
set -euf
top="$(git rev-parse --show-toplevel)"

cd "$top"

claude "

ultrathink.

update, upgrade, fix, harmonize, audit, test. 

work on every subdirectory subproject:

improve every existing important file in every existing subdirectory:

- index.md
- AGENTS.md
- plan.md
- tasks.md

read components.tsv (the source of truth) then:

- regenerate AGENTS/components.md 
- update root index.md components section.

run bin/sync tu update all subproject AGENTS/ directories
  
important directories:

- bin
- components

subproject directories:

- lilydesignsystem.github.io
- lily-design-system-blazor-headless
- lily-design-system-blazor-web-examples
- lily-design-system-html-headless
- lily-design-system-html-css-js-examples
- lily-design-system-nunjucks-headless
- lily-design-system-nunjucks-eleventy-examples
- lily-design-system-react-headless
- lily-design-system-react-next-examples
- lily-design-system-svelte-headless
- lily-design-system-svelte-sveltekit-examples
- lily-design-system-vue-headless
- lily-design-system-vue-nuxt-examples

"
