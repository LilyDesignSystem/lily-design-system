{#
  ImageInput macro — a graphical submit button that displays an image.

  HTML tag: <input type="image">
  CSS class: image-input
  Accessibility: alt is required as the accessible name.

  Params:
    src, alt (required), width, height, name, value,
    formaction, formmethod, formnovalidate, formtarget,
    id, classes, attributes.
#}
{%- macro imageInput(params) -%}
{%- set p = params | default({}) -%}
<input
  class="image-input{% if p.classes %} {{ p.classes }}{% endif %}"
  type="image"
  src="{{ p.src }}"
  alt="{{ p.alt }}"
  {%- if p.width %} width="{{ p.width }}"{% endif %}
  {%- if p.height %} height="{{ p.height }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.value %} value="{{ p.value }}"{% endif %}
  {%- if p.formaction %} formaction="{{ p.formaction }}"{% endif %}
  {%- if p.formmethod %} formmethod="{{ p.formmethod }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
