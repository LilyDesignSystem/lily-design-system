{#
  EspanaTarjetaSanitariaIndividualInput macro — an input for
    entering a España Tarjeta Sanitaria Individual (TSI) code.

  HTML tag: <input type="text">
  CSS class: espana-tarjeta-sanitaria-individual-input
  Format: alphanumeric; the exact length and shape depends on the
    autonomous community that issued the card. The TSI commonly
    maps to the national CIP-SNS (Código de Identificación Personal
    del Sistema Nacional de Salud), which is 14 characters.
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/espana-tarjeta-sanitaria-individual-input/macro.njk" import espanaTarjetaSanitariaIndividualInput %}
    {{ espanaTarjetaSanitariaIndividualInput({ id: "tsi" }) }}
#}
{%- macro espanaTarjetaSanitariaIndividualInput(params) -%}
<input
  class="espana-tarjeta-sanitaria-individual-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  pattern="[A-Za-z0-9 \-]{1,20}"
  maxlength="20"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
