{#
  ThemeSelect macro — a select dropdown for choosing a theme.

  HTML tag: <select>
  CSS class: theme-select

  Params:
    value       string   Current selection.
    name        string
    required    boolean
    disabled    boolean
    label       string   aria-label.
    labelledBy  string
    describedBy string
    invalid     boolean
    id          string
    classes     string
    attributes  object

  Body content: ThemeSelectOption children via caller().
#}
{%- macro themeSelect(params) -%}
{%- set p = params | default({}) -%}
<select
  class="theme-select{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% endif %}
  {%- if p.describedBy %} aria-describedby="{{ p.describedBy }}"{% endif %}
  {%- if p.invalid %} aria-invalid="true"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</select>
{%- endmacro -%}
