{#
  DontListItem macro — a discouraged-practice item in a dont-list guideline list.

  HTML tag: <li>
  CSS class: dont-list-item

  Params:
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage: see DontList.
#}
{%- macro dontListItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="dont-list-item{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</li>
{%- endmacro -%}
