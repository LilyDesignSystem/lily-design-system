{#
  NumberInput macro — an input for entering a numeric value with validation.

  HTML tag: <input type="number">
  CSS class: number-input
  Accessibility: see TextInput. Screen reader users may prefer
    inputmode="numeric" on a type="text" input for free-form numbers
    (phone digits, NHS number digits); use this NumberInput only
    when the value is a genuine number with arithmetic semantics.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, placeholder, autocomplete,
    min, max, step, inputmode, classes, attributes.

  Usage:
    {% from "components/number-input/macro.njk" import numberInput %}
    {{ numberInput({ id: "age", min: 0, max: 120, step: 1 }) }}
#}
{%- macro numberInput(params) -%}
<input
  class="number-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="number"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.placeholder %} placeholder="{{ params.placeholder }}"{% endif %}
  {%- if params.autocomplete %} autocomplete="{{ params.autocomplete }}"{% endif %}
  {%- if params.min is defined %} min="{{ params.min }}"{% endif %}
  {%- if params.max is defined %} max="{{ params.max }}"{% endif %}
  {%- if params.step is defined %} step="{{ params.step }}"{% endif %}
  {%- if params.inputmode %} inputmode="{{ params.inputmode }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
