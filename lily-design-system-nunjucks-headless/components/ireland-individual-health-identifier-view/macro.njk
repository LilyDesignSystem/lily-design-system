{#
  IrelandIndividualHealthIdentifierView macro — a read-only display
    of an Ireland Individual Health Identifier (IHI).

  HTML tag: <span>
  CSS class: ireland-individual-health-identifier-view
  Formatting: when params.value reduces to exactly 7 digits, the
    macro groups them as "XXXX XXX". Non-matching values render
    as-is.

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/ireland-individual-health-identifier-view/macro.njk" import irelandIndividualHealthIdentifierView %}
    {{ irelandIndividualHealthIdentifierView({ value: "1234567", label: "IHI" }) }}
#}
{%- macro irelandIndividualHealthIdentifierView(params) -%}
{%- set raw = params.value | default("") -%}
{%- set stripped = raw | replace(" ", "") | replace("-", "") -%}
{%- set isSeven = (stripped | length) == 7 and stripped.match("^[0-9]{7}$") -%}
<span
  class="ireland-individual-health-identifier-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if isSeven -%}
    {{ stripped.slice(0, 4) }} {{ stripped.slice(4, 7) }}
  {%- else -%}
    {{ raw }}
  {%- endif -%}
</span>
{%- endmacro -%}
