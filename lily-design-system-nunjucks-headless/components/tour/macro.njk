{#
  Tour macro — a tour guide, such as for sightseeing, pathways,
    demonstrations, onboarding, etc.

  HTML tag: <section>
  CSS class: tour

  Params:
    label       string   Accessible name. Default "Tour".
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: typically a TourList via caller().
#}
{%- macro tour(params) -%}
{%- set p = params | default({}) -%}
<section
  class="tour{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Tour') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</section>
{%- endmacro -%}
