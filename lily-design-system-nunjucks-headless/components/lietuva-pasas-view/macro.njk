{#
  LietuvaPasasView macro — a read-only display of Lithuania's
    Pasas.

  HTML tag: <span>
  CSS class: lietuva-pasas-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/lietuva-pasas-view/macro.njk" import lietuvaPasasView %}
    {{ lietuvaPasasView({ value: "sample", label: "Lithuanian Passport" }) }}
#}
{%- macro lietuvaPasasView(params) -%}
<span
  class="lietuva-pasas-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
