{# AddressographBox macro — a passive identification block containing the consumer's patient or subject details. #}
{%- macro addressographBox(params) -%}
<div
  class="addressograph-box{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
