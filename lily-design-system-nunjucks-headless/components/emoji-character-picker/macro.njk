{#
  EmojiCharacterPicker macro — a picker for browsing and selecting emoji.

  HTML tag: <div role="dialog">
  CSS class: emoji-character-picker

  Params: label, open, id, classes, attributes. Caller provides picker content.
#}
{%- macro emojiCharacterPicker(params) -%}
{%- set p = params | default({}) -%}
<div
  class="emoji-character-picker{% if p.classes %} {{ p.classes }}{% endif %}"
  role="dialog"
  aria-label="{{ p.label | default('Emoji picker') }}"
  {%- if not p.open %} hidden{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
