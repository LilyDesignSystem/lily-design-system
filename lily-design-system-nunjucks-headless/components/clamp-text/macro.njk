{#
  ClampText macro — a text container that truncates content to a
    maximum number of lines.

  HTML tag: <div>
  CSS class: clamp-text
  Behavior: Sets `data-lines` and CSS custom property
    `--clamp-text-lines` so consumer CSS can apply `line-clamp` /
    `-webkit-line-clamp`. Full content remains in the DOM for
    assistive tech. No `overflow: hidden` is applied — leave that
    to the consumer.

  Params:
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    lines       number   Maximum number of visible lines. Default 2.
    label       string   Optional aria-label.
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/clamp-text/macro.njk" import clampText %}
    {{ clampText({ text: "Long paragraph…", lines: 3 }) }}
#}
{%- macro clampText(params) -%}
{%- set lines = params.lines | default(2) -%}
<div
  class="clamp-text{% if params.classes %} {{ params.classes }}{% endif %}"
  data-lines="{{ lines }}"
  style="--clamp-text-lines: {{ lines }};"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
