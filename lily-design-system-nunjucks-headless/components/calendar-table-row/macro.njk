{#
  TableRow macro — a table interactive grid row.

  HTML tag: <tr>
  CSS class: table-row

  Params:
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Body content: TableCol or TableData cells via caller().

  Usage: see Table.
#}
{%- macro calendarTableRow(params) -%}
{%- set p = params | default({}) -%}
<tr
  class="calendar-table-row{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</tr>
{%- endmacro -%}
