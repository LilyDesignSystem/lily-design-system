{#
  TreeListItem macro — one item in a tree navigation list.

  HTML tag: <li role="treeitem">
  CSS class: tree-list-item

  Params:
    expanded    boolean  aria-expanded state (true | false). Omit
                         to leave the attribute off — useful for
                         leaf items with no children.
    selected    boolean  aria-selected.
    current     boolean  aria-current="page".
    level       number   aria-level for flattened trees (optional).
    text        string
    html        string
    id          string
    classes     string
    attributes  object

  Body content: the item content (typically a TreeLink and, for
    branches, a nested TreeList), via caller().
#}
{%- macro treeListItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="tree-list-item{% if p.classes %} {{ p.classes }}{% endif %}"
  role="treeitem"
  {%- if p.expanded != undefined %} aria-expanded="{{ 'true' if p.expanded else 'false' }}"{% endif %}
  {%- if p.selected %} aria-selected="true"{% endif %}
  {%- if p.current %} aria-current="page"{% endif %}
  {%- if p.level %} aria-level="{{ p.level }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</li>
{%- endmacro -%}
