{#
  UnitedStatesSocialSecurityNumberInput macro — an input for
    entering a US Social Security number.

  HTML tag: <input type="text">
  CSS class: united-states-social-security-number-input
  Format: nine digits, canonically grouped "XXX-XX-XXXX".
  Accessibility: inputmode="numeric", autocomplete="off"
    (SSNs have no standardised autocomplete token), spellcheck
    suppressed. Pair with a Hint explaining the format.

  Params:
    id            string   Element id. Required.
    name          string
    value         string
    label         string
    describedBy   string
    errormessage  string
    invalid       boolean
    required      boolean
    disabled      boolean
    readonly      boolean
    classes       string
    attributes    object

  Usage:
    {% from "components/united-states-social-security-number-input/macro.njk" import unitedStatesSocialSecurityNumberInput %}
    {{ unitedStatesSocialSecurityNumberInput({ id: "ssn" }) }}
#}
{%- macro unitedStatesSocialSecurityNumberInput(params) -%}
<input
  class="united-states-social-security-number-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  inputmode="numeric"
  pattern="[0-9 \-]{9,11}"
  maxlength="11"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
