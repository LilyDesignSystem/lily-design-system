{#
  VitalSignHeartRateVariabilityView macro — a read-only display of
    heart rate variability (HRV), typically RMSSD in milliseconds.

  HTML tag: <span>
  CSS class: vital-sign-heart-rate-variability-view
  Accessibility: unit wrapped in <abbr title="milliseconds">.

  Params: value, label, id, classes, attributes.
#}
{%- macro vitalSignHeartRateVariabilityView(params) -%}
<span
  class="vital-sign-heart-rate-variability-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><span class="vital-sign-value">{{ params.value | default('') }}</span>&nbsp;<abbr class="vital-sign-unit" title="milliseconds">ms</abbr></span>
{%- endmacro -%}
