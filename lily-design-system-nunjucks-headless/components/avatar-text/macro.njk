{#
  AvatarText macro — an avatar inner text, such as initials.

  HTML tag: <span>
  CSS class: avatar-text
  Accessibility:
    - When placed inside an Avatar (which carries role="img" +
      aria-label), the initials are decorative and aria-hidden so
      screen readers do not speak letter-by-letter.
    - When used standalone, pass params.decorative=false to let the
      text through.

  Params:
    text        string   Initials or short text.
    html        string   Raw HTML content.
    decorative  boolean  Default true. Set false to expose text.
    label       string   aria-label when not decorative.
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/avatar-text/macro.njk" import avatarText %}
    {{ avatarText({ text: "JS" }) }}
#}
{%- macro avatarText(params) -%}
{%- set decorative = params.decorative -%}
{%- set isDecorative = decorative or decorative is not defined -%}
<span
  class="avatar-text{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if isDecorative %} aria-hidden="true"
  {%- elif params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</span>
{%- endmacro -%}
