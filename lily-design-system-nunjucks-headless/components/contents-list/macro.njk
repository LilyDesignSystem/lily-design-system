{#
  ContentsList macro — an ordered list of contents list item components.

  HTML tag: <ol>
  CSS class: contents-list

  Params:
    id          string
    classes     string
    attributes  object

  Body content: ContentsListItem children via caller().
#}
{%- macro contentsList(params) -%}
{%- set p = params | default({}) -%}
<ol
  class="contents-list{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</ol>
{%- endmacro -%}
