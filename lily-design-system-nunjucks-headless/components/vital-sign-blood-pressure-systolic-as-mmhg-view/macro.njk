{#
  VitalSignBloodPressureSystolicAsMmhgView macro — a read-only display
    of systolic blood pressure in mmHg.

  HTML tag: <span>
  CSS class: vital-sign-blood-pressure-systolic-as-mmhg-view
  Accessibility: the unit is wrapped in <abbr title="millimetres
    of mercury">.

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/vital-sign-blood-pressure-systolic-as-mmhg-view/macro.njk" import vitalSignBloodPressureSystolicAsMmhgView %}
    {{ vitalSignBloodPressureSystolicAsMmhgView({ value: 118 }) }}
#}
{%- macro vitalSignBloodPressureSystolicAsMmhgView(params) -%}
<span
  class="vital-sign-blood-pressure-systolic-as-mmhg-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><span class="vital-sign-value">{{ params.value | default('') }}</span>&nbsp;<abbr class="vital-sign-unit" title="millimetres of mercury">mmHg</abbr></span>
{%- endmacro -%}
