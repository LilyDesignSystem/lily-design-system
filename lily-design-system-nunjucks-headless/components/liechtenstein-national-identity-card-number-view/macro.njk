{#
  LiechtensteinNationalIdentityCardNumberView macro — a read-only display of Liechtenstein's
    Liechtenstein National Identity Card Number.

  HTML tag: <span>
  CSS class: liechtenstein-national-identity-card-number-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/liechtenstein-national-identity-card-number-view/macro.njk" import liechtensteinNationalIdentityCardNumberView %}
    {{ liechtensteinNationalIdentityCardNumberView({ value: "sample", label: "Liechtenstein National Identity Card Number" }) }}
#}
{%- macro liechtensteinNationalIdentityCardNumberView(params) -%}
<span
  class="liechtenstein-national-identity-card-number-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
