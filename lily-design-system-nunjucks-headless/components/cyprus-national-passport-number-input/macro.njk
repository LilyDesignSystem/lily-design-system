{#
  CyprusNationalPassportNumberInput macro — an input for entering Cyprus's
    National Passport Number.

  HTML tag: <input type="text">
  CSS class: cyprus-national-passport-number-input
  Format: passports before 13/12/2010 begin with 'E' followed by 6 digits (e.g. E123456); biometric passports issued after 13/12/2010 begin with 'K' followed by 8 digits (e.g. K12345678)
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/cyprus-national-passport-number-input/macro.njk" import cyprusNationalPassportNumberInput %}
    {{ cyprusNationalPassportNumberInput({ id: "field-id", label: "National Passport Number" }) }}
#}
{%- macro cyprusNationalPassportNumberInput(params) -%}
<input
  class="cyprus-national-passport-number-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
