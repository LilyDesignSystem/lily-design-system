{#
  NetPromoterScorePickerButton macro — one button inside a
    NetPromoterScorePicker (value 0–10).

  HTML tag: <button role="radio">
  CSS class: net-promoter-score-picker-button
  Data attributes:
    - data-value: the selected score.
    - data-category: "detractor" | "passive" | "promoter".

  Params:
    value        number   0–10. Required.
    checked      boolean
    disabled     boolean
    label        string   Default "Rate {value} out of 10".
    id           string
    name         string
    classes      string
    attributes   object
#}
{%- macro netPromoterScorePickerButton(params) -%}
{%- set value = params.value -%}
{%- set category = "detractor" -%}
{%- if value >= 9 -%}
  {%- set category = "promoter" -%}
{%- elif value >= 7 -%}
  {%- set category = "passive" -%}
{%- endif -%}
{%- set label = params.label | default("Rate " ~ value ~ " out of 10") -%}
<button
  class="net-promoter-score-picker-button{% if params.classes %} {{ params.classes }}{% endif %}"
  type="{{ params.type | default('button') }}"
  role="radio"
  aria-checked="{{ 'true' if params.checked else 'false' }}"
  aria-label="{{ label }}"
  tabindex="{{ '0' if params.checked else '-1' }}"
  data-value="{{ value }}"
  data-category="{{ category }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.name %} name="{{ params.name }}"{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ value }}</button>
{%- endmacro -%}
