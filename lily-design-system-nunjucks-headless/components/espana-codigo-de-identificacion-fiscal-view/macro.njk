{#
  EspanaCodigoDeIdentificacionFiscalView macro — a read-only display of Spain's
    Código de Identificación Fiscal (CIF).

  HTML tag: <span>
  CSS class: espana-codigo-de-identificacion-fiscal-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/espana-codigo-de-identificacion-fiscal-view/macro.njk" import espanaCodigoDeIdentificacionFiscalView %}
    {{ espanaCodigoDeIdentificacionFiscalView({ value: "sample", label: "Tax Identification Code" }) }}
#}
{%- macro espanaCodigoDeIdentificacionFiscalView(params) -%}
<span
  class="espana-codigo-de-identificacion-fiscal-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
