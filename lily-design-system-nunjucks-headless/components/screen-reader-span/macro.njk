{#
  ScreenReaderSpan macro — a visually hidden span of text intended
    for screen readers to provide more descriptive labels.

  HTML tag: <span>
  CSS class: screen-reader-span
  Accessibility: marked with the visually-hidden pattern in CSS so
    sighted users don't see it, but assistive tech reads it aloud.

  Params:
    text        string   Plain text (escaped).
    html        string   Raw HTML.
    id          string
    classes     string
    attributes  object
#}
{%- macro screenReaderSpan(params) -%}
{%- set p = params | default({}) -%}
<span
  class="screen-reader-span{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</span>
{%- endmacro -%}
