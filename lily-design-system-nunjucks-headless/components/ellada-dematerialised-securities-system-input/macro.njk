{#
  ElladaDematerialisedSecuritiesSystemInput macro — an input for entering Greece's
    Dematerialised Securities System (DSS).

  HTML tag: <input type="text">
  CSS class: ellada-dematerialised-securities-system-input
  Format: 10 digits linked to the investor's personal details (name, ID number, passport number, tax registration number) and managed by the Central Securities Depository of Greece
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/ellada-dematerialised-securities-system-input/macro.njk" import elladaDematerialisedSecuritiesSystemInput %}
    {{ elladaDematerialisedSecuritiesSystemInput({ id: "field-id", label: "Dematerialised Securities System" }) }}
#}
{%- macro elladaDematerialisedSecuritiesSystemInput(params) -%}
<input
  class="ellada-dematerialised-securities-system-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
