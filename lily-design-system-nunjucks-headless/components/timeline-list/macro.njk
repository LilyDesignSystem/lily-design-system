{#
  TimelineList macro — an ordered list of chronological events or
    milestones.

  HTML tag: <ol>
  CSS class: timeline-list

  Params:
    label       string   Accessible name.
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: TimelineListItem children via caller().
#}
{%- macro timelineList(params) -%}
{%- set p = params | default({}) -%}
<ol
  class="timeline-list{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</ol>
{%- endmacro -%}
