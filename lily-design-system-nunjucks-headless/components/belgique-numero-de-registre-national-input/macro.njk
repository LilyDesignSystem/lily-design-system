{#
  BelgiqueNumeroDeRegistreNationalInput macro — an input for entering Belgium's
    Numéro de Registre National / Rijksregisternummer (NRN).

  HTML tag: <input type="text">
  CSS class: belgique-numero-de-registre-national-input
  Format: 11 digits where the first 6 are the date of birth (YYMMDD), the next 3 are an ordering number (uneven for men, even for women) and the last 2 a check digit
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/belgique-numero-de-registre-national-input/macro.njk" import belgiqueNumeroDeRegistreNationalInput %}
    {{ belgiqueNumeroDeRegistreNationalInput({ id: "field-id", label: "National Register Number" }) }}
#}
{%- macro belgiqueNumeroDeRegistreNationalInput(params) -%}
<input
  class="belgique-numero-de-registre-national-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
