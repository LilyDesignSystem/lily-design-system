{#
  Header macro — a page or section header area.

  HTML tag: <header>
  CSS class: header

  Params:
    label       string   aria-label.
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: via caller().
#}
{%- macro header(params) -%}
{%- set p = params | default({}) -%}
<header
  class="header{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</header>
{%- endmacro -%}
