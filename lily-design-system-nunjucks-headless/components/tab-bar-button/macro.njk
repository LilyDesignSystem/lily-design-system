{#
  TabBarButton macro — one tab button in a tab group.

  HTML tag: <button role="tab">
  CSS class: tab-bar-button

  Params:
    text        string
    html        string
    label       string
    selected    boolean  aria-selected.
    controls    string   id of the tabpanel it controls.
    disabled    boolean
    id          string
    classes     string
    attributes  object
#}
{%- macro tabBarButton(params) -%}
{%- set p = params | default({}) -%}
<button
  class="tab-bar-button{% if p.classes %} {{ p.classes }}{% endif %}"
  type="button"
  role="tab"
  aria-selected="{{ 'true' if p.selected else 'false' }}"
  tabindex="{{ '0' if p.selected else '-1' }}"
  {%- if p.controls %} aria-controls="{{ p.controls }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</button>
{%- endmacro -%}
