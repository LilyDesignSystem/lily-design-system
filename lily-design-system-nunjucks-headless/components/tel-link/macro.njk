{#
  TelLink macro — a tel: hyperlink for a telephone number.

  HTML tag: <a>
  CSS class: tel-link
  Accessibility:
    - Visible text defaults to the dialable number.
    - For international numbers, include the country code in
      params.number (e.g. "+44 20 7946 0958"). The href strips
      non-dial characters automatically.

  Params:
    number      string   Phone number. Required. May include spaces,
                         hyphens, and parentheses for readability;
                         the href normalises to dialable form.
    text        string   Visible text. Defaults to number.
    html        string   Raw HTML content (rendered via `| safe`).
    label       string   aria-label override.
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/tel-link/macro.njk" import telLink %}
    {{ telLink({ number: "0300 123 4567" }) }}
    {{ telLink({ number: "+44 20 7946 0958", text: "Call us" }) }}
#}
{%- macro telLink(params) -%}
{%- set dialable = params.number | replace(" ", "") | replace("-", "") | replace("(", "") | replace(")", "") -%}
<a
  class="tel-link{% if params.classes %} {{ params.classes }}{% endif %}"
  href="tel:{{ dialable }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- else -%}{{ params.number }}
  {%- endif -%}
</a>
{%- endmacro -%}
