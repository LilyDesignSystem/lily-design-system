{#
  CymruRhifYGwasanaethIechydGwladolInput macro — an input for entering Wales's
    Rhif y Gwasanaeth Iechyd Gwladol (Rhif GIG).

  HTML tag: <input type="text">
  CSS class: cymru-rhif-y-gwasanaeth-iechyd-gwladol-input
  Format: 10 digits in 3-3-4 format with a Modulus-11 check digit (shared with England and the Isle of Man)
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/cymru-rhif-y-gwasanaeth-iechyd-gwladol-input/macro.njk" import cymruRhifYGwasanaethIechydGwladolInput %}
    {{ cymruRhifYGwasanaethIechydGwladolInput({ id: "field-id", label: "National Health Service Number" }) }}
#}
{%- macro cymruRhifYGwasanaethIechydGwladolInput(params) -%}
<input
  class="cymru-rhif-y-gwasanaeth-iechyd-gwladol-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
