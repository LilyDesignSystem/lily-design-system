{#
  Input macro — a generic HTML input element.

  HTML tag: <input>
  CSS class: input

  Params: type (default "text"), id, name, value, label,
    required, disabled, readonly, placeholder, classes, attributes.
#}
{%- macro input(params) -%}
{%- set p = params | default({}) -%}
<input
  class="input{% if p.classes %} {{ p.classes }}{% endif %}"
  type="{{ p.type | default('text') }}"
  value="{{ p.value | default('') }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.placeholder %} placeholder="{{ p.placeholder }}"{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.readonly %} readonly{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
