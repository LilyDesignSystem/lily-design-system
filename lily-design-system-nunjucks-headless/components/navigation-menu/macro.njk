{#
  NavigationMenu macro — a site-wide navigation menu with links.

  HTML tag: <nav>
  CSS class: navigation-menu

  Params: label (default "Site navigation"), labelledBy, id, classes, attributes.
#}
{%- macro navigationMenu(params) -%}
{%- set p = params | default({}) -%}
<nav
  class="navigation-menu{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Site navigation') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</nav>
{%- endmacro -%}
