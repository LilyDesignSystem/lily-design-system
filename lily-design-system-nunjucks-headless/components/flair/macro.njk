{#
  Flair macro — a decorative highlight or emphasis element.

  HTML tag: <span>
  CSS class: flair
  Accessibility: by default flair is decorative — it provides
    visual emphasis without semantic meaning. Set params.label if
    the flair conveys important information that is not available
    elsewhere on the page.

  Params:
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    label       string   Accessible name (aria-label). Omit when
                         purely decorative.
    decorative  boolean  If true, aria-hidden="true" is set.
                         Default false.
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/flair/macro.njk" import flair %}
    Limited-time offer {{ flair({ text: "NEW", label: "New feature" }) }}
#}
{%- macro flair(params) -%}
<span
  class="flair{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.decorative %} aria-hidden="true"
  {%- elif params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</span>
{%- endmacro -%}
