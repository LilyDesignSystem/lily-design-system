{#
  VitalSignHeartRateAsBeatsPerMinuteView macro — a read-only display
    of heart rate in beats per minute (BPM).

  HTML tag: <span>
  CSS class: vital-sign-heart-rate-as-beats-per-minute-view
  Accessibility: the unit is wrapped in <abbr title="beats per
    minute"> so assistive tech can expand "bpm" into its full form.

  Params:
    value       number|string  The integer heart rate.
    label       string         Accessible name for the whole cell.
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/vital-sign-heart-rate-as-beats-per-minute-view/macro.njk" import vitalSignHeartRateAsBeatsPerMinuteView %}
    {{ vitalSignHeartRateAsBeatsPerMinuteView({ value: 72 }) }}
#}
{%- macro vitalSignHeartRateAsBeatsPerMinuteView(params) -%}
<span
  class="vital-sign-heart-rate-as-beats-per-minute-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><span class="vital-sign-value">{{ params.value | default('') }}</span>&nbsp;<abbr class="vital-sign-unit" title="beats per minute">bpm</abbr></span>
{%- endmacro -%}
