{#
  SectionHeading macro — a styled heading introducing a major content
    section, with optional eyebrow and subtitle.

  HTML tag: <header>
  CSS class: section-heading
  Accessibility:
    - Renders a real <h2>–<h6> so the document outline is preserved.
    - Eyebrow and subtitle are <p> siblings — they do not contribute
      to the heading hierarchy.

  Params:
    heading        string   REQUIRED. Main heading text.
    eyebrow        string   Eyebrow text rendered as <p> above the heading.
    subtitle       string   Subtitle text rendered as <p> below the heading.
    level          number   2 | 3 | 4 | 5 | 6. Default 2. Heading element.
    id             string
    classes        string
    attributes     object

  Usage:
    {% from "components/section-heading/macro.njk" import sectionHeading %}
    {{ sectionHeading({
      eyebrow: "Why us",
      heading: "Built for everyone",
      subtitle: "Open source, privacy first.",
      level: 2
    }) }}
#}
{%- macro sectionHeading(params) -%}
{%- set level = params.level | default(2) -%}
<header
  class="section-heading{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.eyebrow %}<p class="section-heading-eyebrow">{{ params.eyebrow }}</p>{% endif %}
  {%- if level == 2 %}<h2 class="section-heading-heading">{{ params.heading }}</h2>
  {%- elif level == 3 %}<h3 class="section-heading-heading">{{ params.heading }}</h3>
  {%- elif level == 4 %}<h4 class="section-heading-heading">{{ params.heading }}</h4>
  {%- elif level == 5 %}<h5 class="section-heading-heading">{{ params.heading }}</h5>
  {%- elif level == 6 %}<h6 class="section-heading-heading">{{ params.heading }}</h6>
  {%- else %}<h2 class="section-heading-heading">{{ params.heading }}</h2>
  {%- endif %}
  {%- if params.subtitle %}<p class="section-heading-subtitle">{{ params.subtitle }}</p>{% endif %}
</header>
{%- endmacro -%}
