{#
  LiechtensteinPassportNumberView macro — a read-only display of Liechtenstein's
    Liechtenstein Passport Number.

  HTML tag: <span>
  CSS class: liechtenstein-passport-number-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/liechtenstein-passport-number-view/macro.njk" import liechtensteinPassportNumberView %}
    {{ liechtensteinPassportNumberView({ value: "sample", label: "Liechtenstein Passport Number" }) }}
#}
{%- macro liechtensteinPassportNumberView(params) -%}
<span
  class="liechtenstein-passport-number-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
