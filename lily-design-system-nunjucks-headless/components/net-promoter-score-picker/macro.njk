{#
  NetPromoterScorePicker macro — a picker for selecting a 0–10
    Net Promoter Score.

  HTML tag: <div role="radiogroup">
  CSS class: net-promoter-score-picker
  Accessibility: role="radiogroup" with a required accessible name
    such as "How likely are you to recommend us?".

  Params:
    label        string   Accessible name. Default "Net Promoter Score".
    labelledBy   string
    id           string
    classes      string
    attributes   object

  Body content: NetPromoterScorePickerButton children via caller().
#}
{%- macro netPromoterScorePicker(params) -%}
{%- set p = params | default({}) -%}
<div
  class="net-promoter-score-picker{% if p.classes %} {{ p.classes }}{% endif %}"
  role="radiogroup"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- else %} aria-label="{{ p.label | default('Net Promoter Score') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
