{#
  ColorPicker macro — a container for picking colors by swatch.

  HTML tag: <div role="radiogroup">
  CSS class: color-picker

  Params: label, labelledBy, id, classes, attributes. Caller provides
    ColorPickerButton children.
#}
{%- macro colorPicker(params) -%}
{%- set p = params | default({}) -%}
<div
  class="color-picker{% if p.classes %} {{ p.classes }}{% endif %}"
  role="radiogroup"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Colour') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
