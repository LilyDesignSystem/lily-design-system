{#
  BulgariaEdinenGrazhdanskiNomerInput macro — an input for entering Bulgaria's
    Единен граждански номер / Edinen grazhdanski nomer (EGN).

  HTML tag: <input type="text">
  CSS class: bulgaria-edinen-grazhdanski-nomer-input
  Format: 10 digits: the first 6 are the date of birth (YYMMDD), the next 3 encode area and birth order (ninth digit even for boy, odd for girl), and the tenth is a check digit
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/bulgaria-edinen-grazhdanski-nomer-input/macro.njk" import bulgariaEdinenGrazhdanskiNomerInput %}
    {{ bulgariaEdinenGrazhdanskiNomerInput({ id: "field-id", label: "Uniform Civil Number" }) }}
#}
{%- macro bulgariaEdinenGrazhdanskiNomerInput(params) -%}
<input
  class="bulgaria-edinen-grazhdanski-nomer-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
