{#
  MenuItem macro — one item in a menu.

  HTML tag: <li role="menuitem"> wrapping a <button> for
    command semantics.
  CSS class: menu-item

  Params:
    text        string   Visible text (escaped).
    html        string   Raw HTML body.
    label       string   aria-label override.
    disabled    boolean
    shortcut    string   Keyboard shortcut hint (e.g. "Ctrl+K").
    id          string
    classes     string
    attributes  object
#}
{%- macro menuItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="menu-item{% if p.classes %} {{ p.classes }}{% endif %}"
  role="none"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <button
    class="menu-item-button"
    type="button"
    role="menuitem"
    {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
    {%- if p.disabled %} disabled{% endif %}
  >
    <span class="menu-item-text">
      {%- if p.html -%}{{ p.html | safe }}
      {%- elif p.text -%}{{ p.text }}
      {%- elif caller -%}{{ caller() }}
      {%- endif -%}
    </span>
    {%- if p.shortcut %}
    <kbd class="menu-item-shortcut">{{ p.shortcut }}</kbd>
    {%- endif %}
  </button>
</li>
{%- endmacro -%}
