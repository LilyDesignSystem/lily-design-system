{# MockupPhoneLandscape macro — a box area that looks like a mobile phone in landscape orientation. #}
{%- macro mockupPhoneLandscape(params) -%}
<div
  class="mockup-phone-landscape{% if params.classes %} {{ params.classes }}{% endif %}"
  role="img"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
