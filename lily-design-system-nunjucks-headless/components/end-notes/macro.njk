{#
  endNotes macro — see components/end-notes/index.md for canonical documentation.

  HTML tag: <section>
  CSS class: end-notes

  Params:
    text       string  Plain text content.
    html       string  Raw HTML content (rendered via | safe).
    label      string  aria-label (defaults to 'End notes').
    classes    string
    attributes object
#}
{%- macro endNotes(params) -%}
<section
  class="end-notes{% if params.classes %} {{ params.classes }}{% endif %}"
  aria-label="{{ params.label | default('End notes') }}"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}
    {{ params.html | safe }}
  {%- elif params.text -%}
    {{ params.text }}
  {%- elif caller -%}
    {{ caller() }}
  {%- endif -%}
</section>
{%- endmacro -%}
