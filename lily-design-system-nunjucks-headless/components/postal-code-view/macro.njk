{#
  PostalCodeView macro — a read-only display of a postal or ZIP code.

  HTML tag: <span>
  CSS class: postal-code-view
  Accessibility: a bare identifier; set params.label when context
    is not clear from surrounding text.

  Params:
    value       string   Postal/ZIP code text.
    label       string   Accessible name (aria-label).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/postal-code-view/macro.njk" import postalCodeView %}
    {{ postalCodeView({ value: "SW1A 1AA" }) }}
#}
{%- macro postalCodeView(params) -%}
<span
  class="postal-code-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default('') }}</span>
{%- endmacro -%}
