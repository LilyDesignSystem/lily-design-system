{#
  ItaliaCodiceFiscaleView macro — a read-only display of Italy's
    Codice fiscale (CF).

  HTML tag: <span>
  CSS class: italia-codice-fiscale-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/italia-codice-fiscale-view/macro.njk" import italiaCodiceFiscaleView %}
    {{ italiaCodiceFiscaleView({ value: "sample", label: "Italian Fiscal Code" }) }}
#}
{%- macro italiaCodiceFiscaleView(params) -%}
<span
  class="italia-codice-fiscale-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
