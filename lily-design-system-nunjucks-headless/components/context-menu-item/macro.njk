{#
  ContextMenuItem macro — one item in a context menu.

  HTML tag: <li role="none"> wrapping a <button role="menuitem">
  CSS class: context-menu-item

  Params:
    text        string
    html        string
    label       string
    disabled    boolean
    shortcut    string   Keyboard shortcut hint.
    danger      boolean  Mark as a destructive action (data attribute).
    id          string
    classes     string
    attributes  object
#}
{%- macro contextMenuItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="context-menu-item{% if p.classes %} {{ p.classes }}{% endif %}"
  role="none"
  {%- if p.danger %} data-danger="true"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <button
    class="context-menu-item-button"
    type="button"
    role="menuitem"
    {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
    {%- if p.disabled %} disabled{% endif %}
  >
    <span class="context-menu-item-text">
      {%- if p.html -%}{{ p.html | safe }}
      {%- elif p.text -%}{{ p.text }}
      {%- elif caller -%}{{ caller() }}
      {%- endif -%}
    </span>
    {%- if p.shortcut %}
    <kbd class="context-menu-item-shortcut">{{ p.shortcut }}</kbd>
    {%- endif %}
  </button>
</li>
{%- endmacro -%}
