{#
  DateTimeView macro — a read-only display of a formatted date and
    time.

  HTML tag: <time>
  CSS class: date-time-view
  Behavior: Renders `<time datetime={value}>`. Display text falls
    back from html → text → format → value. The component does not
    localize — the consumer formats `format` (or `text`/`html`) for
    display.

  Params:
    text         string   Plain text content (escaped). Overrides format.
    html         string   Raw HTML content. Overrides text and format.
    value        string   ISO 8601 datetime value. Required.
    format       string   Pre-formatted display text fallback.
    label        string   Optional aria-label.
    id           string
    classes      string
    attributes   object

  Usage:
    {% from "components/date-time-view/macro.njk" import dateTimeView %}
    {{ dateTimeView({
      value: "2026-04-27T15:00:00Z",
      format: "27 April 2026, 3:00 pm"
    }) }}
#}
{%- macro dateTimeView(params) -%}
<time
  class="date-time-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.value %} datetime="{{ params.value }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- elif params.format -%}{{ params.format }}
  {%- elif params.value -%}{{ params.value }}
  {%- endif -%}
</time>
{%- endmacro -%}
