{#
  ChatListItem macro — one chat list item component, typically
    containing one chat message component.

  HTML tag: <li>
  CSS class: chat-list-item

  Params:
    id          string
    classes     string
    attributes  object

  Body content: typically a ChatMessage, via caller().
#}
{%- macro chatListItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="chat-list-item{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</li>
{%- endmacro -%}
