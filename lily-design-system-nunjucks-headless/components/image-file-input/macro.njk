{#
  ImageFileInput macro — an input for selecting image files with preview.

  HTML tag: <input type="file" accept="image/*">
  CSS class: image-file-input

  Params:
    id, name, label, accept (default "image/*"), multiple, capture,
    required, disabled, classes, attributes.
#}
{%- macro imageFileInput(params) -%}
{%- set p = params | default({}) -%}
<input
  class="image-file-input{% if p.classes %} {{ p.classes }}{% endif %}"
  type="file"
  accept="{{ p.accept | default('image/*') }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.multiple %} multiple{% endif %}
  {%- if p.capture %} capture="{{ p.capture }}"{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
