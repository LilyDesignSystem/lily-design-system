{#
  Collapsible macro — a container that can be expanded or collapsed.

  HTML tag: <details>
  CSS class: collapsible

  Params: summary, summaryHtml, open, name, id, classes, attributes.
    Body content via caller().
#}
{%- macro collapsible(params) -%}
{%- set p = params | default({}) -%}
<details
  class="collapsible{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.open %} open{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <summary class="collapsible-summary">
    {%- if p.summaryHtml -%}{{ p.summaryHtml | safe }}
    {%- else -%}{{ p.summary }}
    {%- endif -%}
  </summary>
  <div class="collapsible-body">
    {%- if p.html -%}{{ p.html | safe }}
    {%- elif p.text -%}{{ p.text }}
    {%- elif caller -%}{{ caller() }}
    {%- endif -%}
  </div>
</details>
{%- endmacro -%}
