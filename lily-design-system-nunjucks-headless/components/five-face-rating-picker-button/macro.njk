{#
  FiveFaceRatingPickerButton macro — one face button inside a
    FiveFaceRatingPicker.

  HTML tag: <button role="radio">
  CSS class: five-face-rating-picker-button
  Data attribute: data-value (1–5).

  Params:
    value        number   1–5. Required.
    checked      boolean
    disabled     boolean
    label        string   Auto-generated from value when omitted
                          ("Very unhappy", ..., "Very happy").
    id           string
    name         string
    classes      string
    attributes   object
#}
{%- macro fiveFaceRatingPickerButton(params) -%}
{%- set value = params.value -%}
{%- set phrase = "Neutral" -%}
{%- if value == 1 -%}{%- set phrase = "Very unhappy" -%}
{%- elif value == 2 -%}{%- set phrase = "Unhappy" -%}
{%- elif value == 3 -%}{%- set phrase = "Neutral" -%}
{%- elif value == 4 -%}{%- set phrase = "Happy" -%}
{%- elif value == 5 -%}{%- set phrase = "Very happy" -%}
{%- endif -%}
{%- set label = params.label | default(phrase) -%}
<button
  class="five-face-rating-picker-button{% if params.classes %} {{ params.classes }}{% endif %}"
  type="{{ params.type | default('button') }}"
  role="radio"
  aria-checked="{{ 'true' if params.checked else 'false' }}"
  aria-label="{{ label }}"
  tabindex="{{ '0' if params.checked else '-1' }}"
  data-value="{{ value }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.name %} name="{{ params.name }}"{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
></button>
{%- endmacro -%}
