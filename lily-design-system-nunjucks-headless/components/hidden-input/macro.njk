{#
  HiddenInput macro — a hidden input for including data in form submission.

  HTML tag: <input type="hidden">
  CSS class: hidden-input
  Accessibility: hidden inputs are not exposed to assistive tech at
    all. Do not put anything in params.value that a user would need
    to read; this is for server-round-trip data only
    (CSRF tokens, pagination cursors, etc.).

  Params:
    id          string   Element id.
    name        string   Required.
    value       string   Submitted value.
    classes     string
    attributes  object

  Usage:
    {% from "components/hidden-input/macro.njk" import hiddenInput %}
    {{ hiddenInput({ name: "csrf_token", value: sessionCsrf }) }}
#}
{%- macro hiddenInput(params) -%}
<input
  class="hidden-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="hidden"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  name="{{ params.name }}"
  value="{{ params.value | default('') }}"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
