{#
  TextAreaInputWithCharacterCounter macro — a multi-line text area plus a live
    character counter showing "N of M characters".

  HTML tag: <div> wrapping <textarea> + <output>
  CSS class: text-area-input-with-character-counter

  Params: id, name, value, maximum, rows (default 5), label, required,
    disabled, placeholder, classes, attributes.
#}
{%- macro textAreaWithCharacterCounter(params) -%}
{%- set p = params | default({}) -%}
{%- set textareaId = p.id | default('text-area-input-with-character-counter') -%}
<div
  class="text-area-input-with-character-counter{% if p.classes %} {{ p.classes }}{% endif %}"
  data-module="text-area-input-with-character-counter"
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <textarea
    class="text-area-input-with-character-counter-textarea"
    id="{{ textareaId }}-textarea"
    rows="{{ p.rows | default(5) }}"
    {%- if p.name %} name="{{ p.name }}"{% endif %}
    {%- if p.maximum %} maxlength="{{ p.maximum }}" aria-describedby="{{ textareaId }}-counter"{% endif %}
    {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
    {%- if p.placeholder %} placeholder="{{ p.placeholder }}"{% endif %}
    {%- if p.required %} required{% endif %}
    {%- if p.disabled %} disabled{% endif %}
  >{{ p.value | default('') }}</textarea>
  {%- if p.maximum %}
  <output
    class="text-area-input-with-character-counter-counter"
    id="{{ textareaId }}-counter"
    aria-live="polite"
    for="{{ textareaId }}-textarea"
    data-maximum="{{ p.maximum }}"
  >{{ (p.value | default('')) | length }} of {{ p.maximum }} characters</output>
  {%- endif %}
</div>
{%- endmacro -%}
