{#
  TaskList macro — an ordered list of task list items.

  HTML tag: <ol>
  CSS class: task-list
  Accessibility: an ordered list conveys sequence to assistive tech.
    params.label or params.labelledBy gives the list an accessible
    name.

  Params:
    label       string   Accessible name (aria-label).
    labelledBy  string   aria-labelledby target (preferred).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Body content: TaskListItem children via caller().

  Usage:
    {% from "components/task-list/macro.njk" import taskList %}
    {% from "components/task-list-item/macro.njk" import taskListItem %}

    {% call taskList({ label: "Application progress" }) %}
      {{ taskListItem({
        title: "Personal details",
        href: "/personal",
        status: "completed",
        statusText: "Completed"
      }) }}
      {{ taskListItem({
        title: "Medical history",
        href: "/medical",
        status: "in-progress",
        statusText: "In progress"
      }) }}
    {% endcall %}
#}
{%- macro taskList(params) -%}
{%- set p = params | default({}) -%}
<ol
  class="task-list{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</ol>
{%- endmacro -%}
