{#
  LietuvaAsmensKodasView macro — a read-only display of Lithuania's
    Asmens kodas.

  HTML tag: <span>
  CSS class: lietuva-asmens-kodas-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/lietuva-asmens-kodas-view/macro.njk" import lietuvaAsmensKodasView %}
    {{ lietuvaAsmensKodasView({ value: "sample", label: "Personal Code" }) }}
#}
{%- macro lietuvaAsmensKodasView(params) -%}
<span
  class="lietuva-asmens-kodas-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
