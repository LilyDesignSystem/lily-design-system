{#
  NederlandPaspoortNummerView macro — a read-only display of Netherlands's
    Paspoort Nummer.

  HTML tag: <span>
  CSS class: nederland-paspoort-nummer-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/nederland-paspoort-nummer-view/macro.njk" import nederlandPaspoortNummerView %}
    {{ nederlandPaspoortNummerView({ value: "sample", label: "Dutch Passport Number" }) }}
#}
{%- macro nederlandPaspoortNummerView(params) -%}
<span
  class="nederland-paspoort-nummer-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
