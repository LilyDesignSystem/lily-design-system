{#
  PostalCodeInput macro — an input for entering a postal or ZIP code.

  HTML tag: <input type="text">
  CSS class: postal-code-input
  Accessibility:
    - Uses autocomplete="postal-code" so browsers fill address
      fields correctly.
    - Pair with a Hint that explains any locale-specific format
      expectation (UK postcode, US ZIP, etc.).

  Params:
    id            string   Element id. Required.
    name          string
    value         string
    label         string
    describedBy   string
    errormessage  string
    invalid       boolean
    required      boolean
    disabled      boolean
    readonly      boolean
    pattern       string   Optional regex for locale validation.
    maxlength     number   Default 10.
    autocomplete  string   Default "postal-code".
    classes       string
    attributes    object

  Usage:
    {% from "components/postal-code-input/macro.njk" import postalCodeInput %}
    {{ postalCodeInput({ id: "pc" }) }}
#}
{%- macro postalCodeInput(params) -%}
<input
  class="postal-code-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="{{ params.autocomplete | default('postal-code') }}"
  maxlength="{{ params.maxlength | default(10) }}"
  spellcheck="false"
  {%- if params.pattern %} pattern="{{ params.pattern }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
