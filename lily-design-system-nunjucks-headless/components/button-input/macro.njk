{#
  ButtonInput macro — an input element of type button for form actions.

  HTML tag: <input type="button">
  CSS class: button-input
  Note: prefer the <button> element (Lily's Button macro) for most
    cases. Use ButtonInput when you need the input-element variant
    — for example, when form builders historically expect <input>.
  Accessibility: the visible label is the value attribute (which is
    also what screen readers read). Add params.label to override
    with an aria-label if the value alone is ambiguous.

  Params:
    id            string   Element id.
    name          string
    value         string   Visible label text.
    disabled      boolean
    label         string   aria-label override.
    classes       string
    attributes    object

  Usage:
    {% from "components/button-input/macro.njk" import buttonInput %}
    {{ buttonInput({ value: "Clear form", attributes: { onclick: "form.reset()" } }) }}
#}
{%- macro buttonInput(params) -%}
<input
  class="button-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="button"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.name %} name="{{ params.name }}"{% endif %}
  value="{{ params.value | default('') }}"
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
