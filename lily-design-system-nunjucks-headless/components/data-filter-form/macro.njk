{#
  DataFilterForm macro — a form for filtering data by criteria.

  HTML tag: <form>
  CSS class: data-filter-form

  Params: action (default "#"), method (default "get"), label,
    id, classes, attributes. Caller provides field inputs.
#}
{%- macro dataFilterForm(params) -%}
{%- set p = params | default({}) -%}
<form
  class="data-filter-form{% if p.classes %} {{ p.classes }}{% endif %}"
  action="{{ p.action | default('#') }}"
  method="{{ p.method | default('get') }}"
  role="search"
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</form>
{%- endmacro -%}
