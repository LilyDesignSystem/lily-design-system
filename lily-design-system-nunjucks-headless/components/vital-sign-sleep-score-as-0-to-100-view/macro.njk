{#
  VitalSignSleepScoreAs0To100View macro — a read-only display of a
    sleep score on a 0 – 100 scale.

  HTML tag: <span>
  CSS class: vital-sign-sleep-score-as-0-to-100-view
  The "/100" denominator is rendered as a plain span for clarity.

  Params: value, label, id, classes, attributes.
#}
{%- macro vitalSignSleepScoreAs0To100View(params) -%}
<span
  class="vital-sign-sleep-score-as-0-to-100-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><span class="vital-sign-value">{{ params.value | default('') }}</span><span class="vital-sign-unit">&nbsp;/&nbsp;100</span></span>
{%- endmacro -%}
