{#
  FiveStarRatingPickerButton macro — one star button inside a
    FiveStarRatingPicker.

  HTML tag: <button role="radio">
  CSS class: five-star-rating-picker-button
  Data attribute: data-value with the rating this button selects.
  Accessibility: aria-label is required and typically names the
    value ("Rate 1 star", "Rate 2 stars", ...).

  Params:
    value        number   The rating this button selects (1–5).
    checked      boolean  Current selection state.
    disabled     boolean
    label        string   Required for screen reader announcement.
    id           string
    name         string
    classes      string
    attributes   object
#}
{%- macro fiveStarRatingPickerButton(params) -%}
{%- set label = params.label | default("Rate " ~ params.value ~ (" star" if params.value == 1 else " stars")) -%}
<button
  class="five-star-rating-picker-button{% if params.classes %} {{ params.classes }}{% endif %}"
  type="{{ params.type | default('button') }}"
  role="radio"
  aria-checked="{{ 'true' if params.checked else 'false' }}"
  aria-label="{{ label }}"
  tabindex="{{ '0' if params.checked else '-1' }}"
  data-value="{{ params.value }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.name %} name="{{ params.name }}"{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
></button>
{%- endmacro -%}
