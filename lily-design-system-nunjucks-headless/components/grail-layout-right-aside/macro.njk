{#
  GrailLayoutRightAside macro — the right sidebar region of a grail layout.

  HTML tag: <aside>
  CSS class: grail-layout-right-aside
  Accessibility: <aside> is the complementary landmark. Give it an
    accessible name via params.label so users can distinguish it
    from the left aside.

  Params:
    label       string   Accessible name (aria-label).
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: related content, ads, table of contents, etc. via caller().
#}
{%- macro grailLayoutRightAside(params) -%}
{%- set p = params | default({}) -%}
<aside
  class="grail-layout-right-aside{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</aside>
{%- endmacro -%}
