{#
  CodeBlock macro — a block of formatted code with optional line numbers
    and line highlighting.

  HTML tag: <pre><code>
  CSS class: code-block on the <pre>; nested <code> carries the
    language class for syntax highlighters.
  Accessibility:
    - <pre> preserves whitespace, which matters for source code.
    - params.label sets an aria-label on the <pre> so screen readers
      announce the block's purpose.

  Params:
    text        string   Plain text content (escaped). Newlines preserved.
    html        string   Raw HTML content (for pre-highlighted code).
    language    string   Language token (e.g. "js"). Rendered as
                         "language-{token}" on the inner <code>,
                         matching Prism and highlight.js conventions.
    label       string   Accessible name (aria-label).
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/code-block/macro.njk" import codeBlock %}
    {{ codeBlock({
      language: "js",
      text: "const nhs = readNhsNumber();"
    }) }}
#}
{%- macro codeBlock(params) -%}
<pre
  class="code-block{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><code
  {%- if params.language %} class="language-{{ params.language }}"{% endif -%}
>{%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}</code></pre>
{%- endmacro -%}
