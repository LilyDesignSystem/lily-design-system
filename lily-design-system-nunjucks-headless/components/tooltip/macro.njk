{#
  Tooltip macro — a small popup showing descriptive text on hover
    or focus.

  HTML tag: <span role="tooltip">
  CSS class: tooltip
  Accessibility:
    - role="tooltip" marks this element as the tooltip content.
    - The controlling element should reference the tooltip's id
      via aria-describedby so the tooltip is announced when the
      control is focused.
    - Tooltip visibility is controlled by the consumer (CSS on
      hover/focus-within, or JS on keyboard focus). The macro
      itself is hidden by default via the `hidden` attribute.

  Params:
    id          string   Element id. Required so the control can
                         link via aria-describedby.
    text        string   Tooltip text (escaped).
    html        string   Raw HTML content.
    hidden      boolean  Whether to render the hidden attribute.
                         Default true.
    classes     string
    attributes  object

  Usage:
    {% from "components/tooltip/macro.njk" import tooltip %}
    <button aria-describedby="t1">Save</button>
    {{ tooltip({ id: "t1", text: "Save the current draft" }) }}
#}
{%- macro tooltip(params) -%}
{%- set hide = params.hidden -%}
<span
  class="tooltip{% if params.classes %} {{ params.classes }}{% endif %}"
  role="tooltip"
  id="{{ params.id }}"
  {%- if hide or hide is not defined %} hidden{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</span>
{%- endmacro -%}
