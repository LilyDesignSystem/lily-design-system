{#
  MaltaNationalIdentificationNumberView macro — a read-only display of Malta's
    Malta National Identification Number.

  HTML tag: <span>
  CSS class: malta-national-identification-number-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/malta-national-identification-number-view/macro.njk" import maltaNationalIdentificationNumberView %}
    {{ maltaNationalIdentificationNumberView({ value: "sample", label: "Malta National Identification Number" }) }}
#}
{%- macro maltaNationalIdentificationNumberView(params) -%}
<span
  class="malta-national-identification-number-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
