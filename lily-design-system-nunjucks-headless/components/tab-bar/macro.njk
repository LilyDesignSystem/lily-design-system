{#
  TabBar macro — a group of tabs for switching between content panels.

  HTML tag: <div role="tablist">
  CSS class: tab-bar

  Params:
    label       string   Accessible name.
    labelledBy  string
    orientation string   "horizontal" (default) | "vertical".
    id          string
    classes     string
    attributes  object

  Body content: TabBarButton children via caller().
#}
{%- macro tabBar(params) -%}
{%- set p = params | default({}) -%}
<div
  class="tab-bar{% if p.classes %} {{ p.classes }}{% endif %}"
  role="tablist"
  aria-orientation="{{ p.orientation | default('horizontal') }}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
