{#
  ThemePickerButton macro — one button inside a ThemePicker.

  HTML tag: <button role="radio">
  CSS class: theme-picker-button

  Params:
    theme        string   Theme identifier (required).
    text         string   Visible label. Default: theme.
    checked      boolean
    disabled     boolean
    label        string   aria-label override.
    id           string
    name         string
    classes      string
    attributes   object
#}
{%- macro themePickerButton(params) -%}
{%- set p = params | default({}) -%}
<button
  class="theme-picker-button{% if p.classes %} {{ p.classes }}{% endif %}"
  type="button"
  role="radio"
  aria-checked="{{ 'true' if p.checked else 'false' }}"
  tabindex="{{ '0' if p.checked else '-1' }}"
  data-theme="{{ p.theme }}"
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ p.text | default(p.theme) }}</button>
{%- endmacro -%}
