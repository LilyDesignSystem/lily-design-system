{#
  DialGroup macro — a group of dial components.

  HTML tag: <div role="group">
  CSS class: dial-group

  Params: label, labelledBy, id, classes, attributes. Caller provides Dials.
#}
{%- macro dialGroup(params) -%}
{%- set p = params | default({}) -%}
<div
  class="dial-group{% if p.classes %} {{ p.classes }}{% endif %}"
  role="group"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Dials') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
