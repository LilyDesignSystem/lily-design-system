{#
  SuomiHenkilotunnusView macro — a read-only display of Finland's
    Henkilötunnus (HETU).

  HTML tag: <span>
  CSS class: suomi-henkilotunnus-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/suomi-henkilotunnus-view/macro.njk" import suomiHenkilotunnusView %}
    {{ suomiHenkilotunnusView({ value: "sample", label: "Personal Identity Code" }) }}
#}
{%- macro suomiHenkilotunnusView(params) -%}
<span
  class="suomi-henkilotunnus-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
