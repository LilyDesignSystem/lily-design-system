{#
  EestiIsikukoodView macro — a read-only display of Estonia's
    Isikukood (IK).

  HTML tag: <span>
  CSS class: eesti-isikukood-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/eesti-isikukood-view/macro.njk" import eestiIsikukoodView %}
    {{ eestiIsikukoodView({ value: "sample", label: "Personal Identification Code" }) }}
#}
{%- macro eestiIsikukoodView(params) -%}
<span
  class="eesti-isikukood-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
