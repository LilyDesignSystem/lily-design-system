{#
  ImageCropper macro — a container for cropping and resizing an image to a
    selected region.

  HTML tag: <div>
  CSS class: image-cropper

  Params:
    label       string   Accessible name (aria-label). Required.
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    id          string
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value.

  Content:
    The image and crop overlay surface (image, canvas, SVG, or a
    cropping-library output) is supplied by the caller.
#}
{%- macro imageCropper(params) -%}
{%- set p = params | default({}) -%}
<div
  class="image-cropper{% if p.classes %} {{ p.classes }}{% endif %}"
  role="application"
  aria-label="{{ p.label | default('Image cropper') }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
