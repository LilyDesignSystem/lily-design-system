{#
  VitalSignBodyFatAsPercentageInput macro — a number input for
    body fat as a percentage, to one decimal place.

  HTML tag: <input type="number">
  CSS class: vital-sign-body-fat-as-percentage-input
  Clinical range: defaults to 2–80 % (essential fat to severe
    obesity). Step 0.1 for decimal precision.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, min (2), max (80), step (0.1),
    classes, attributes.
#}
{%- macro vitalSignBodyFatAsPercentageInput(params) -%}
<input
  class="vital-sign-body-fat-as-percentage-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="number"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  min="{{ params.min | default(2) }}"
  max="{{ params.max | default(80) }}"
  step="{{ params.step | default(0.1) }}"
  inputmode="decimal"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
