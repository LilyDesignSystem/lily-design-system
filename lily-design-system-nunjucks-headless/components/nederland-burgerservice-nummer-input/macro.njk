{#
  NederlandBurgerserviceNummerInput macro — an input for entering Netherlands's
    Burgerservicenummer (BSN).

  HTML tag: <input type="text">
  CSS class: nederland-burgerservice-nummer-input
  Format: 9-digit number issued via the Personal Records Database (BRP); validated with a variant of the eleven-test (Luhn) algorithm
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/nederland-burgerservice-nummer-input/macro.njk" import nederlandBurgerserviceNummerInput %}
    {{ nederlandBurgerserviceNummerInput({ id: "field-id", label: "Citizen Service Number" }) }}
#}
{%- macro nederlandBurgerserviceNummerInput(params) -%}
<input
  class="nederland-burgerservice-nummer-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
