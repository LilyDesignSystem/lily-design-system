{#
  ClipboardCopyButton macro — a button that copies text to the clipboard.

  HTML tag: <button>
  CSS class: clipboard-copy-button
  Data attributes:
    - data-clipboard-text="..." when the text to copy is known up-front.
    - data-clipboard-target="#some-id" when the text should be read
      from another element's value or textContent at click time.
  Accessibility:
    - Visible label describes the action ("Copy" / "Copy code" etc.).
    - Consumer JS should announce success (e.g. toggle
      aria-live="polite" text) after a successful copy.

  Params:
    text          string   Visible button label. Default "Copy".
    html          string   Raw HTML label.
    clipboardText string   Literal text to copy (data-clipboard-text).
    target        string   CSS selector for source element
                           (data-clipboard-target).
    disabled      boolean
    label         string   aria-label override.
    id            string
    classes       string
    attributes    object

  Usage:
    {% from "components/clipboard-copy-button/macro.njk" import clipboardCopyButton %}
    {{ clipboardCopyButton({
      text: "Copy NHS number",
      clipboardText: "4857773456",
      label: "Copy NHS number to clipboard"
    }) }}
#}
{%- macro clipboardCopyButton(params) -%}
<button
  class="clipboard-copy-button{% if params.classes %} {{ params.classes }}{% endif %}"
  type="{{ params.type | default('button') }}"
  data-module="clipboard-copy-button"
  {%- if params.clipboardText %} data-clipboard-text="{{ params.clipboardText }}"{% endif %}
  {%- if params.target %} data-clipboard-target="{{ params.target }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- else -%}Copy
  {%- endif -%}
</button>
{%- endmacro -%}
