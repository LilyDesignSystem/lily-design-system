{#
  Expander macro — a control that expands to reveal more content.

  HTML tag: <details>
  CSS class: expander

  Params: summary, open, id, classes, attributes.
#}
{%- macro expander(params) -%}
{%- set p = params | default({}) -%}
<details
  class="expander{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.open %} open{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <summary class="expander-summary">{{ p.summary | default("More") }}</summary>
  <div class="expander-body">
    {%- if p.html -%}{{ p.html | safe }}
    {%- elif p.text -%}{{ p.text }}
    {%- elif caller -%}{{ caller() }}
    {%- endif -%}
  </div>
</details>
{%- endmacro -%}
