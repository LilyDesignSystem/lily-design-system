{#
  ErrorMessage macro — an error message associated with a form field.

  HTML tag: <span>
  CSS class: error-message
  Accessibility:
    - Rendered as <span> so it can be placed inside <label>, inside
      the field wrapper, or anywhere else in flow.
    - The associated input should reference this element's id via
      aria-errormessage (preferred) or aria-describedby, and set
      aria-invalid="true".
    - A visually-hidden prefix ("Error:" by default) is announced to
      screen readers so the error's role is unambiguous.

  Params:
    id                  string   Element id. Strongly recommended
                                 so inputs can link to it via
                                 aria-errormessage.
    text                string   Plain text content (escaped).
    html                string   Raw HTML content (rendered via `| safe`).
    visuallyHiddenText  string   Screen-reader prefix. Default "Error:".
    classes             string   Consumer-provided extra CSS classes.
    attributes          object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/error-message/macro.njk" import errorMessage %}
    {{ errorMessage({
      id: "nhs-number-error",
      text: "Enter an NHS number"
    }) }}
#}
{%- macro errorMessage(params) -%}
<span
  class="error-message{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <span class="visually-hidden">{{ params.visuallyHiddenText | default("Error:") }}</span>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</span>
{%- endmacro -%}
