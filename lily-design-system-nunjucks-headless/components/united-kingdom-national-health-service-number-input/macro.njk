{#
  UnitedKingdomNationalHealthServiceNumberInput macro — an input for
    entering a UK NHS number.

  HTML tag: <input type="text">
  CSS class: united-kingdom-national-health-service-number-input
  Accessibility:
    - NHS numbers are 10 digits, conventionally displayed as
      three groups "XXX XXX XXXX".
    - inputmode="numeric" hints the numeric keypad on mobile.
    - autocomplete is deliberately "off" because browsers do not
      have a standardised token for medical record numbers.
    - Pair with a Hint that explains the 10-digit format.

  Params:
    id            string   Element id. Required.
    name          string
    value         string   Current value (raw or grouped).
    label         string
    describedBy   string
    errormessage  string
    invalid       boolean
    required      boolean
    disabled      boolean
    readonly      boolean
    classes       string
    attributes    object

  Usage:
    {% from "components/united-kingdom-national-health-service-number-input/macro.njk" import nhsNumberInput %}
    {{ nhsNumberInput({ id: "nhs-nbr" }) }}
#}
{%- macro unitedKingdomNationalHealthServiceNumberInput(params) -%}
<input
  class="united-kingdom-national-health-service-number-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  inputmode="numeric"
  pattern="[0-9 \-]{10,13}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
