{#
  Table macro — a table with rows and columns.

  HTML tag: <table>
  CSS class: table
  Accessibility:
    - Prefer a visible <caption>: pass params.caption or
      params.captionHtml. The caption is the table's accessible
      name for screen readers.
    - If no caption is given, pass params.label to set aria-label.
    - Use params.labelledBy to point at an existing heading.

  Params:
    caption       string   Visible caption text (escaped).
    captionHtml   string   Visible caption raw HTML.
    label         string   Accessible name (aria-label) when no
                           caption is given.
    labelledBy    string   aria-labelledby target.
    id            string   Element id.
    classes       string   Consumer-provided extra CSS classes.
    attributes    object   Extra HTML attributes as key/value pairs.

  Body content: TableHead, TableBody, TableFoot via caller().

  Usage:
    {% from "components/calendar-table/macro.njk" import calendarTable %}
    {% from "components/calendar-table-head/macro.njk" import calendarTableHead %}
    {% from "components/calendar-table-body/macro.njk" import calendarTableBody %}
    {% from "components/calendar-table-row/macro.njk" import calendarTableRow %}
    {% from "components/calendar-table-col/macro.njk" import calendarTableTD %}
    {% from "components/calendar-table-td/macro.njk" import calendarTableTD %}

    {% call calendarTable({ caption: "Your appointments" }) %}
      {% call calendarTableHead() %}
        {% call calendarTableRow() %}
          {{ calendarTableTD({ text: "Date" }) }}
          {{ calendarTableTD({ text: "Type" }) }}
        {% endcall %}
      {% endcall %}
      {% call calendarTableBody() %}
        {% call calendarTableRow() %}
          {{ calendarTableTD({ text: "27 April" }) }}
          {{ calendarTableTD({ text: "GP review" }) }}
        {% endcall %}
      {% endcall %}
    {% endcall %}
#}
{%- macro calendarTable(params) -%}
{%- set p = params | default({}) -%}
<table
  class="calendar-table{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if not p.caption and not p.captionHtml -%}
    {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
    {%- elif p.label %} aria-label="{{ p.label }}"{% endif -%}
  {%- endif -%}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.captionHtml %}
  <caption class="calendar-table-caption">{{ p.captionHtml | safe }}</caption>
  {%- elif p.caption %}
  <caption class="calendar-table-caption">{{ p.caption }}</caption>
  {%- endif %}
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</table>
{%- endmacro -%}
