{#
  Hero macro — a large box or image with a title and description.

  HTML tag: <section>
  CSS class: hero
  Accessibility: the visible heading is the accessible name via
    aria-labelledby.

  Params:
    heading       string   Visible heading.
    headingLevel  number   Heading level 1–3. Default 1.
    headingId     string   Override the heading id.
    description   string   Body text (escaped).
    descriptionHtml string  Body raw HTML.
    label         string   aria-label when no heading.
    id            string
    classes       string
    attributes    object

  Body content: optional extra content (e.g. a call-to-action) via
    caller().

  Usage:
    {% from "components/hero/macro.njk" import hero %}
    {{ hero({
      heading: "Your NHS health records",
      description: "Book appointments, order prescriptions, and review your history."
    }) }}
#}
{%- macro hero(params) -%}
{%- set level = params.headingLevel | default(1) -%}
{%- set headingId = params.headingId or (params.id ~ "-heading" if params.id and params.heading) -%}
<section
  class="hero{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if headingId %} aria-labelledby="{{ headingId }}"
  {%- elif params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <div class="hero-inner">
    {%- if params.heading %}
    <h{{ level }} class="hero-heading"{% if headingId %} id="{{ headingId }}"{% endif %}>{{ params.heading }}</h{{ level }}>
    {%- endif %}
    {%- if params.descriptionHtml %}
    <div class="hero-description">{{ params.descriptionHtml | safe }}</div>
    {%- elif params.description %}
    <p class="hero-description">{{ params.description }}</p>
    {%- endif %}
    {%- if caller %}
    <div class="hero-extras">{{ caller() }}</div>
    {%- endif %}
  </div>
</section>
{%- endmacro -%}
