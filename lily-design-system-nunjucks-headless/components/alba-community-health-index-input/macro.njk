{#
  AlbaCommunityHealthIndexInput macro — an input for entering Scotland's
    Community Health Index (CHI).

  HTML tag: <input type="text">
  CSS class: alba-community-health-index-input
  Format: 10 digits encoding date of birth (DDMMYY) + two random digits + a sex digit (odd male, even female) + a Modulus-11 check digit
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/alba-community-health-index-input/macro.njk" import albaCommunityHealthIndexInput %}
    {{ albaCommunityHealthIndexInput({ id: "field-id", label: "Community Health Index" }) }}
#}
{%- macro albaCommunityHealthIndexInput(params) -%}
<input
  class="alba-community-health-index-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
