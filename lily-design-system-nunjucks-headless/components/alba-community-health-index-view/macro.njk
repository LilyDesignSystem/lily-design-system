{#
  AlbaCommunityHealthIndexView macro — a read-only display of Scotland's
    Community Health Index (CHI).

  HTML tag: <span>
  CSS class: alba-community-health-index-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/alba-community-health-index-view/macro.njk" import albaCommunityHealthIndexView %}
    {{ albaCommunityHealthIndexView({ value: "sample", label: "Community Health Index" }) }}
#}
{%- macro albaCommunityHealthIndexView(params) -%}
<span
  class="alba-community-health-index-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
