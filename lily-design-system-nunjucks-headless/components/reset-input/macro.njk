{#
  ResetInput macro — a button input that resets a form to default values.

  HTML tag: <input type="reset">
  CSS class: reset-input
  Note: reset buttons are rarely useful and often surprise users;
    prefer a dedicated <button type="button"> with explicit
    behaviour. Provided here for parity with legacy forms.
  Accessibility: the visible label is the value attribute.

  Params:
    id          string
    name        string
    value       string   Visible label text. Default "Reset".
    disabled    boolean
    label       string   aria-label override.
    classes     string
    attributes  object

  Usage:
    {% from "components/reset-input/macro.njk" import resetInput %}
    {{ resetInput({ value: "Start over" }) }}
#}
{%- macro resetInput(params) -%}
<input
  class="reset-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="reset"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.name %} name="{{ params.name }}"{% endif %}
  value="{{ params.value | default('Reset') }}"
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
