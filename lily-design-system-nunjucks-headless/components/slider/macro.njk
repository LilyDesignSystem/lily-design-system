{#
  Slider macro — a draggable control for selecting a value along a track.
    Built on the native <input type="range"> for zero-JS accessibility.

  HTML tag: <input type="range">
  CSS class: slider

  Params:
    id, name, value, min (default 0), max (default 100), step (default 1),
    label, disabled, required, classes, attributes.
#}
{%- macro slider(params) -%}
{%- set p = params | default({}) -%}
<input
  class="slider{% if p.classes %} {{ p.classes }}{% endif %}"
  type="range"
  min="{{ p.min | default(0) }}"
  max="{{ p.max | default(100) }}"
  step="{{ p.step | default(1) }}"
  value="{{ p.value | default(0) }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
