{#
  ToggleGroup macro — a group of toggle buttons for selecting options.

  HTML tag: <div role="group">
  CSS class: toggle-group
  Accessibility:
    - role="group" plus an accessible name scopes the collection
      for assistive tech.
    - Each child ToggleButton tracks its own aria-pressed state.
    - For mutually-exclusive selection (radio behaviour), prefer
      SegmentGroup or a radiogroup wrapper instead.

  Params:
    label        string   Accessible name (aria-label).
    labelledBy   string
    id           string
    classes      string
    attributes   object

  Body content: ToggleButton children via caller().

  Usage:
    {% from "components/toggle-group/macro.njk" import toggleGroup %}
    {% from "components/toggle-button/macro.njk" import toggleButton %}
    {% call toggleGroup({ label: "Text formatting" }) %}
      {{ toggleButton({ text: "B", label: "Bold", pressed: true }) }}
      {{ toggleButton({ text: "I", label: "Italic" }) }}
    {% endcall %}
#}
{%- macro toggleGroup(params) -%}
{%- set p = params | default({}) -%}
<div
  class="toggle-group{% if p.classes %} {{ p.classes }}{% endif %}"
  role="group"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
