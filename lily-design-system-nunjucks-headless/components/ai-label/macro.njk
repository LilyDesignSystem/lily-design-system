{#
  AiLabel macro — an indicator of AI instances that is a pathway to
    AI explainability.

  HTML tag: <span>
  CSS class: ai-label
  Accessibility:
    - Screen readers announce "AI" or the custom text by default.
    - params.describedBy can point at a longer explanation of what
      the AI is doing, supporting AI transparency.
    - Default text is "AI"; override via params.text or params.html.

  Params:
    text        string   Visible label text. Default "AI".
    html        string   Raw HTML content.
    label       string   Accessible name override.
    describedBy string   id of an explanation (e.g. inline help).
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/ai-label/macro.njk" import aiLabel %}
    {{ aiLabel({ describedBy: "ai-explanation" }) }}
    <span id="ai-explanation">Generated by our clinical summary model.</span>
#}
{%- macro aiLabel(params) -%}
{%- set p = params | default({}) -%}
<span
  class="ai-label{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.describedBy %} aria-describedby="{{ p.describedBy }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- else -%}AI
  {%- endif -%}
</span>
{%- endmacro -%}
