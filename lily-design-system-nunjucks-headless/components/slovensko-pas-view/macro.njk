{#
  SlovenskoPasView macro — a read-only display of Slovakia's
    Pas.

  HTML tag: <span>
  CSS class: slovensko-pas-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/slovensko-pas-view/macro.njk" import slovenskoPasView %}
    {{ slovenskoPasView({ value: "sample", label: "Slovak Passport" }) }}
#}
{%- macro slovenskoPasView(params) -%}
<span
  class="slovensko-pas-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
