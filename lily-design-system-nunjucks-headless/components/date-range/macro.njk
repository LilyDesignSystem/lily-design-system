{#
  DateRange macro — a display of a start and end date range.

  HTML tag: <span>
  CSS class: date-range

  Params:
    start, startText, end, endText, separator (default "–"),
    label, id, classes, attributes.
#}
{%- macro dateRange(params) -%}
{%- set p = params | default({}) -%}
<span
  class="date-range{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <time class="date-range-start"{% if p.start %} datetime="{{ p.start }}"{% endif %}>{{ p.startText | default(p.start) }}</time>
  <span class="date-range-separator" aria-hidden="true">{{ p.separator | default('–') }}</span>
  <time class="date-range-end"{% if p.end %} datetime="{{ p.end }}"{% endif %}>{{ p.endText | default(p.end) }}</time>
</span>
{%- endmacro -%}
