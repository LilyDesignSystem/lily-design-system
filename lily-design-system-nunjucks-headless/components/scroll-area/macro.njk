{#
  ScrollArea macro — a scrollable container.

  HTML tag: <div>
  CSS class: scroll-area

  Params: label, id, classes, attributes.
#}
{%- macro scrollArea(params) -%}
{%- set p = params | default({}) -%}
<div
  class="scroll-area{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  tabindex="0"
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
