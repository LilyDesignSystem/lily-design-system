{#
  Citation macro — a citation acknowledging the relevance of another
    work.

  HTML tag: <cite>
  CSS class: citation

  Params:
    text        string
    html        string
    id          string
    classes     string
    attributes  object
#}
{%- macro citation(params) -%}
{%- set p = params | default({}) -%}
<cite
  class="citation{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</cite>
{%- endmacro -%}
