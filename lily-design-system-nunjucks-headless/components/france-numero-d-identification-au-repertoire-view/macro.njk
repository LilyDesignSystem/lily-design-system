{#
  FranceNumeroDIdentificationAuRepertoireView macro — a read-only
    display of a France numéro d'identification au répertoire (NIR).

  HTML tag: <span>
  CSS class: france-numero-d-identification-au-repertoire-view
  Formatting: when params.value reduces to exactly 15 characters
    (digits, or digits with A/B for Corsica), the macro groups
    them as "G YY MM CC VVV SSS KK". Any other value renders as-is.

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/france-numero-d-identification-au-repertoire-view/macro.njk" import franceNumeroDIdentificationAuRepertoireView %}
    {{ franceNumeroDIdentificationAuRepertoireView({
      value: "185127846310038",
      label: "Numéro INSEE"
    }) }}
#}
{%- macro franceNumeroDIdentificationAuRepertoireView(params) -%}
{%- set raw = params.value | default("") -%}
{%- set stripped = raw | replace(" ", "") | replace("-", "") -%}
{%- set isFifteen = (stripped | length) == 15 and stripped.match("^[0-9AB]{15}$") -%}
<span
  class="france-numero-d-identification-au-repertoire-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if isFifteen -%}
    {{ stripped.slice(0, 1) }} {{ stripped.slice(1, 3) }} {{ stripped.slice(3, 5) }} {{ stripped.slice(5, 7) }} {{ stripped.slice(7, 10) }} {{ stripped.slice(10, 13) }} {{ stripped.slice(13, 15) }}
  {%- else -%}
    {{ raw }}
  {%- endif -%}
</span>
{%- endmacro -%}
