{#
  Menu macro — a list of actions or options triggered by a button.

  HTML tag: <ul role="menu">
  CSS class: menu

  Params:
    label       string   Accessible name. Default "Menu".
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: MenuItem children via caller().
#}
{%- macro menu(params) -%}
{%- set p = params | default({}) -%}
<ul
  class="menu{% if p.classes %} {{ p.classes }}{% endif %}"
  role="menu"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Menu') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</ul>
{%- endmacro -%}
