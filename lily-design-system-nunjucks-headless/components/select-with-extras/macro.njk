{#
  SelectWithExtras macro — a native <select> wrapped for additional
    features (search, grouping) handled by consumer JS.

  HTML tag: <select>
  CSS class: select-with-extras

  Params: id, name, value, label, required, disabled, multiple, classes, attributes.
    Caller provides <option> children.
#}
{%- macro selectWithExtras(params) -%}
{%- set p = params | default({}) -%}
<select
  class="select-with-extras{% if p.classes %} {{ p.classes }}{% endif %}"
  data-module="select-with-extras"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.multiple %} multiple{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</select>
{%- endmacro -%}
