{#
  HrvatskaOsobniIdentifikacijskiBrojView macro — a read-only display of Croatia's
    Osobni identifikacijski broj (OIB).

  HTML tag: <span>
  CSS class: hrvatska-osobni-identifikacijski-broj-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/hrvatska-osobni-identifikacijski-broj-view/macro.njk" import hrvatskaOsobniIdentifikacijskiBrojView %}
    {{ hrvatskaOsobniIdentifikacijskiBrojView({ value: "sample", label: "Personal Identification Number" }) }}
#}
{%- macro hrvatskaOsobniIdentifikacijskiBrojView(params) -%}
<span
  class="hrvatska-osobni-identifikacijski-broj-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
