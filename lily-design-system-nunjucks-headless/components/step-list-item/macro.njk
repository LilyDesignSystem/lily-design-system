{#
  StepListItem macro — one step in a step list with status of
    waiting, in progress, finished, or error.

  HTML tag: <li>
  CSS class: step-list-item
  Accessibility:
    - aria-current="step" is rendered when current=true.
    - aria-label is optional; supply when the visible content is
      ambiguous.
    - data-status reflects the lifecycle state for consumer CSS.

  Params:
    status       string   "waiting" | "in-progress" | "finished" |
                          "error". Default "waiting".
    current      boolean  When true, renders aria-current="step".
                          Default false.
    label        string   Optional aria-label override.
    text         string   Plain text content (escaped).
    html         string   Raw HTML content (rendered via `| safe`).
    classes      string   Consumer-provided extra CSS classes.
    attributes   object   Extra HTML attributes.

  Usage:
    {% from "components/step-list-item/macro.njk" import stepListItem %}
    {{ stepListItem({
      status: "in-progress",
      current: true,
      html: "<strong>Shipping</strong><span>Choose a carrier</span>"
    }) }}
#}
{%- macro stepListItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="step-list-item{% if p.classes %} {{ p.classes }}{% endif %}"
  data-status="{{ p.status | default('waiting') }}"
  {%- if p.current %} aria-current="step"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</li>
{%- endmacro -%}
