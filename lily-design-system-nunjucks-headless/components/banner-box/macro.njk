{#
  BannerBox macro — a banner box inside a banner component, using
    flexbox horizontal layout.

  HTML tag: <div>
  CSS class: banner-box

  Params:
    text        string   Plain text content.
    html        string   Raw HTML content.
    label       string   Accessible name (aria-label).
    id          string
    classes     string
    attributes  object

  Body content: content via caller().
#}
{%- macro bannerBox(params) -%}
{%- set p = params | default({}) -%}
<div
  class="banner-box{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
