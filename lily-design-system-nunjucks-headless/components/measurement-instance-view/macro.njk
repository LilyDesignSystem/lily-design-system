{#
  MeasurementInstanceView macro — a read-only display of a measurement
    value and unit.

  HTML tag: <span>
  CSS class: measurement-instance-view

  Params:
    value       number|string  The numeric value.
    unit        string         Unit symbol ("cm", "kg", etc.).
    unitLabel   string         Unit long name for screen readers.
    label       string         aria-label override.
    id          string
    classes     string
    attributes  object
#}
{%- macro measurementInstanceView(params) -%}
{%- set p = params | default({}) -%}
<span
  class="measurement-instance-view{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <span class="measurement-instance-view-value">{{ p.value | default('') }}</span>&nbsp;<abbr class="measurement-instance-view-unit"{% if p.unitLabel %} title="{{ p.unitLabel }}"{% endif %}>{{ p.unit | default('') }}</abbr>
</span>
{%- endmacro -%}
