{#
  TaskBarButton macro — one item in a task bar.

  HTML tag: <button>
  CSS class: task-bar-button

  Params:
    text        string
    html        string
    label       string
    pressed     boolean  aria-pressed (for toggle buttons).
    disabled    boolean
    id          string
    classes     string
    attributes  object
#}
{%- macro taskBarButton(params) -%}
{%- set p = params | default({}) -%}
<button
  class="task-bar-button{% if p.classes %} {{ p.classes }}{% endif %}"
  type="button"
  {%- if p.pressed != undefined %} aria-pressed="{{ 'true' if p.pressed else 'false' }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</button>
{%- endmacro -%}
