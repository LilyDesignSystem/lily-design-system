{#
  Hint macro — hint text providing guidance for a form field.

  HTML tag: <div>
  CSS class: hint
  Accessibility: paired with a form field via aria-describedby.
    The field's aria-describedby should reference params.id so
    screen readers announce the hint together with the field.

  Params:
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    id          string   Element id. Commonly referenced by the
                         associated input's aria-describedby.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/hint/macro.njk" import hint %}
    <label for="nhs-number">NHS number</label>
    {{ hint({
      id: "nhs-number-hint",
      text: "It is a 10-digit number on any letter from the NHS."
    }) }}
    <input id="nhs-number" aria-describedby="nhs-number-hint" …>
#}
{%- macro hint(params) -%}
<div
  class="hint{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
