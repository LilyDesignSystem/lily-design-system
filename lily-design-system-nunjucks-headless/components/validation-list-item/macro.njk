{#
  ValidationListItem macro — one validation rule in a validation list
    with a status of pending, passed, or failed.

  HTML tag: <li>
  CSS class: validation-list-item
  Accessibility:
    - data-status conveys status to consumer styling.
    - aria-label optionally overrides the announced name.
    - The parent ValidationList's aria-live="polite" causes status
      changes to be announced.

  Params:
    text         string   Plain text rule content (escaped).
    html         string   Raw HTML rule content (rendered via `| safe`).
    status       string   "pending" | "passed" | "failed". Default "pending".
    label        string   Optional aria-label override.
    id           string
    classes      string
    attributes   object

  Usage:
    {% from "components/validation-list-item/macro.njk" import validationListItem %}
    {{ validationListItem({
      text: "At least 8 characters",
      status: "pending"
    }) }}
#}
{%- macro validationListItem(params) -%}
{%- set p = params | default({}) -%}
{%- set status = p.status | default("pending") -%}
<li
  class="validation-list-item{% if p.classes %} {{ p.classes }}{% endif %}"
  data-status="{{ status }}"
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</li>
{%- endmacro -%}
