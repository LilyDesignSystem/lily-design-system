{#
  PolskaNumerIdentyfikacjiPodatkowejInput macro — an input for entering Poland's
    Numer Identyfikacji Podatkowej (NIP).

  HTML tag: <input type="text">
  CSS class: polska-numer-identyfikacji-podatkowej-input
  Format: 10 numeric digits used for tax identification
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/polska-numer-identyfikacji-podatkowej-input/macro.njk" import polskaNumerIdentyfikacjiPodatkowejInput %}
    {{ polskaNumerIdentyfikacjiPodatkowejInput({ id: "field-id", label: "Tax Identification Number" }) }}
#}
{%- macro polskaNumerIdentyfikacjiPodatkowejInput(params) -%}
<input
  class="polska-numer-identyfikacji-podatkowej-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
