{#
  SlovenskoRodneCisloView macro — a read-only display of Slovakia's
    Rodné číslo (RČ).

  HTML tag: <span>
  CSS class: slovensko-rodne-cislo-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/slovensko-rodne-cislo-view/macro.njk" import slovenskoRodneCisloView %}
    {{ slovenskoRodneCisloView({ value: "sample", label: "Slovak Personal Number" }) }}
#}
{%- macro slovenskoRodneCisloView(params) -%}
<span
  class="slovensko-rodne-cislo-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
