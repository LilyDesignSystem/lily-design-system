{#
  CeskoRodneCisloView macro — a read-only display of Czech Republic's
    Rodné číslo (RČ).

  HTML tag: <span>
  CSS class: cesko-rodne-cislo-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/cesko-rodne-cislo-view/macro.njk" import ceskoRodneCisloView %}
    {{ ceskoRodneCisloView({ value: "sample", label: "Czech Personal Number" }) }}
#}
{%- macro ceskoRodneCisloView(params) -%}
<span
  class="cesko-rodne-cislo-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
