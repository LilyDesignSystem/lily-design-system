{#
  Character macro — a single character display element.

  HTML tag: <span>
  CSS class: character
  Accessibility:
    - When decorative, set params.decorative to true so the
      character is hidden from assistive tech.
    - When meaningful (e.g. a stylised glyph), set params.label
      so screen readers announce the intended meaning.

  Params:
    text        string   The character (or short glyph sequence).
    html        string   Raw HTML content.
    label       string   Accessible name (aria-label).
    decorative  boolean  If true, aria-hidden="true" is set.
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/character/macro.njk" import character %}
    {{ character({ text: "A", decorative: true }) }}
    {{ character({ text: "€", label: "Euro sign" }) }}
#}
{%- macro character(params) -%}
<span
  class="character{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.decorative %} aria-hidden="true"
  {%- elif params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</span>
{%- endmacro -%}
