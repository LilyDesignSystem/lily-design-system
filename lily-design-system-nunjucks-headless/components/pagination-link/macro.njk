{#
  PaginationLink macro — one pagination link in the trail.

  HTML tag: <a>
  CSS class: pagination-link
  Data attribute: data-direction on the root when params.direction
    is set. Values: "previous" | "next".
  Accessibility:
    - When params.current is true, aria-current="page" marks the
      current page link.
    - When params.direction is set, a visually-hidden suffix
      "page: N of M" style string (params.hiddenLabel) can clarify
      where the link leads for screen readers.

  Params:
    href          string   Target URL. Default "#".
    text          string   Visible label (e.g. a page number or
                           "Previous" / "Next").
    html          string   Raw HTML label (rendered via `| safe`).
    current       boolean  Marks this as the current page.
    direction     string   "previous" | "next".
    hiddenLabel   string   Additional visually-hidden text appended
                           to the link (e.g. "Results: page 3").
    label         string   aria-label override for the link.
    id            string   Element id.
    classes       string   Consumer-provided extra CSS classes.
    attributes    object   Extra HTML attributes as key/value pairs.

  Usage: see PaginationNav.
#}
{%- macro paginationLink(params) -%}
<a
  class="pagination-link{% if params.classes %} {{ params.classes }}{% endif %}"
  href="{{ params.href | default('#') }}"
  {%- if params.current %} aria-current="page"{% endif %}
  {%- if params.direction %} data-direction="{{ params.direction }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
  {%- if params.hiddenLabel %}<span class="visually-hidden"> {{ params.hiddenLabel }}</span>{% endif -%}
</a>
{%- endmacro -%}
