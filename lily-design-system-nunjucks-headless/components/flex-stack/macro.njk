{#
  FlexStack macro — a flex layout container for vertical or
    horizontal stacking with consistent gap.

  HTML tag: <div>
  CSS class: flex-stack
  Behavior: Inline style `display: flex; flex-direction: {direction};
    gap: {gap}` plus optional `align-items` / `justify-content`.
    Sets `data-direction` for CSS hooks.

  Params:
    text         string   Plain text content (escaped).
    html         string   Raw HTML content (rendered via `| safe`).
    direction    string   "row" | "column". Default "column".
    gap          string   Gap CSS value. Default "1rem".
    align        string   Optional align-items value.
    justify      string   Optional justify-content value.
    label        string   Optional aria-label.
    id           string
    classes      string
    attributes   object

  Usage:
    {% from "components/flex-stack/macro.njk" import flexStack %}
    {% call flexStack({ direction: "row", gap: "0.5rem" }) %}
      <button>One</button><button>Two</button>
    {% endcall %}
#}
{%- macro flexStack(params) -%}
{%- set direction = params.direction | default("column") -%}
{%- set gap = params.gap | default("1rem") -%}
<div
  class="flex-stack{% if params.classes %} {{ params.classes }}{% endif %}"
  data-direction="{{ direction }}"
  style="display: flex; flex-direction: {{ direction }}; gap: {{ gap }};{% if params.align %} align-items: {{ params.align }};{% endif %}{% if params.justify %} justify-content: {{ params.justify }};{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
