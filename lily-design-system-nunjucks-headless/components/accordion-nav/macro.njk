{#
  AccordionNav macro — a navigation container for collapsible
    accordion information.

  HTML tag: <nav>
  CSS class: accordion-nav
  Accessibility:
    - role="navigation" is implicit on <nav>.
    - params.label becomes aria-label. The default is "Accordion".

  Params:
    label       string   Accessible name. Default "Accordion".
    labelledBy  string   Id of an element that names this nav.
                         Use instead of `label` if a heading is visible.
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Body content: typically an AccordionList, passed via caller().

  Usage:
    {% from "components/accordion-nav/macro.njk" import accordionNav %}
    {% from "components/accordion-list/macro.njk" import accordionList %}
    {% from "components/accordion-list-item/macro.njk" import accordionListItem %}
    {% from "components/accordion-link/macro.njk" import accordionLink %}

    {% call accordionNav() %}
      {% call accordionList() %}
        {% call accordionListItem({ summary: "Section 1" }) %}
          {{ accordionLink({ href: "/a", text: "Page A" }) }}
        {% endcall %}
      {% endcall %}
    {% endcall %}
#}
{%- macro accordionNav(params) -%}
{%- set p = params | default({}) -%}
<nav
  class="accordion-nav{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Accordion') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</nav>
{%- endmacro -%}
