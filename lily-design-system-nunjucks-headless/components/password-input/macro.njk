{#
  PasswordInput macro — an input for entering a password with obscured text.

  HTML tag: <input type="password">
  CSS class: password-input
  Accessibility: see TextInput for aria-describedby, aria-errormessage,
    and aria-invalid conventions.
  Security note:
    - Avoid pre-filling password inputs unless absolutely required.
      This macro leaves params.value out of the rendered markup by
      default; pass autocomplete="current-password" or "new-password"
      so browsers and password managers can assist correctly.

  Params:
    id            string   Element id. Required.
    name          string   Name attribute. Defaults to id.
    label         string   Accessible name (aria-label).
    describedBy   string   aria-describedby id list.
    errormessage  string   aria-errormessage id.
    invalid       boolean  Sets aria-invalid="true" when truthy.
    required      boolean
    disabled      boolean
    readonly      boolean
    placeholder   string
    autocomplete  string   "current-password" | "new-password" | …
    minlength     number
    maxlength     number
    pattern       string
    classes       string
    attributes    object

  Usage:
    {% from "components/password-input/macro.njk" import passwordInput %}
    {{ passwordInput({ id: "password", autocomplete: "new-password" }) }}
#}
{%- macro passwordInput(params) -%}
<input
  class="password-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="password"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.placeholder %} placeholder="{{ params.placeholder }}"{% endif %}
  {%- if params.autocomplete %} autocomplete="{{ params.autocomplete }}"{% endif %}
  {%- if params.minlength %} minlength="{{ params.minlength }}"{% endif %}
  {%- if params.maxlength %} maxlength="{{ params.maxlength }}"{% endif %}
  {%- if params.pattern %} pattern="{{ params.pattern }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
