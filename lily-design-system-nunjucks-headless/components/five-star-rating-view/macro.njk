{#
  FiveStarRatingView macro — a read-only display of a five-star rating.

  HTML tag: <span>
  CSS class: five-star-rating-view
  Data attributes:
    - data-value: the current rating (0–5, integer or half).
    - data-max: the maximum rating (default 5).
  Accessibility:
    - The filled and empty stars are drawn by CSS pseudo-elements
      from data-value; screen readers are given the rating via
      aria-label like "Rating: 4 out of 5 stars".

  Params:
    value       number   0–5 rating.
    max         number   Maximum. Default 5.
    label       string   aria-label override.
    id          string
    classes     string
    attributes  object
#}
{%- macro fiveStarRatingView(params) -%}
{%- set max = params.max | default(5) -%}
{%- set label = params.label | default("Rating: " ~ (params.value | default(0)) ~ " out of " ~ max ~ " stars") -%}
<span
  class="five-star-rating-view{% if params.classes %} {{ params.classes }}{% endif %}"
  role="img"
  aria-label="{{ label }}"
  data-value="{{ params.value | default(0) }}"
  data-max="{{ max }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
></span>
{%- endmacro -%}
