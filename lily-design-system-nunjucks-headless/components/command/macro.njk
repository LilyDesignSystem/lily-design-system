{#
  Command macro — a command palette for searching and executing actions.

  HTML tag: <div role="dialog" aria-modal="true">
  CSS class: command

  Params: label (required accessible name), open (default false),
    id, classes, attributes. Caller provides the input and listbox.
#}
{%- macro command(params) -%}
{%- set p = params | default({}) -%}
<div
  class="command{% if p.classes %} {{ p.classes }}{% endif %}"
  role="dialog"
  aria-modal="true"
  aria-label="{{ p.label | default('Command palette') }}"
  {%- if not p.open %} hidden{% endif %}
  data-module="command"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
