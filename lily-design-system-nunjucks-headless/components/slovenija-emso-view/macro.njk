{#
  SlovenijaEmsoView macro — a read-only display of Slovenia's
    Enotna Matična Številka Občana (EMŠO).

  HTML tag: <span>
  CSS class: slovenija-emso-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/slovenija-emso-view/macro.njk" import slovenijaEmsoView %}
    {{ slovenijaEmsoView({ value: "sample", label: "Unique Master Citizen Number" }) }}
#}
{%- macro slovenijaEmsoView(params) -%}
<span
  class="slovenija-emso-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
