{#
  scrollerVideo macro — scroll-driven video with foreground steps.

  HTML tag: <div>
  CSS class: scroller-video

  Params:
    src        string  REQUIRED. Video source URL.
    label      string  REQUIRED. aria-label for the video story.
    alt        string  REQUIRED. Text alternative describing the video.
    offset     number  Default 0.5.
    text       string  Foreground step content.
    html       string  Foreground step content (raw).
    classes    string
    attributes object
#}
{%- macro scrollerVideo(params) -%}
{%- set offset = params.offset | default(0.5) -%}
<div
  class="scroller-video{% if params.classes %} {{ params.classes }}{% endif %}"
  data-offset="{{ offset }}"
  aria-label="{{ params.label }}"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <div
    class="scroller-video-background"
    role="img"
    aria-roledescription="scrollable video"
    aria-label="{{ params.alt }}"
  >
    <video class="scroller-video-element" src="{{ params.src }}" muted playsinline preload="auto"></video>
  </div>
  <div class="scroller-video-foreground scroller-base" data-offset="{{ offset }}">
    {%- if params.html -%}
      {{ params.html | safe }}
    {%- elif params.text -%}
      {{ params.text }}
    {%- elif caller -%}
      {{ caller() }}
    {%- endif -%}
  </div>
</div>
{%- endmacro -%}
