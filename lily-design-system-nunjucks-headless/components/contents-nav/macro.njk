{#
  ContentsNav macro — a navigation landmark for a list of contents
    (table of contents within a page or document).

  HTML tag: <nav>
  CSS class: contents-nav

  Params:
    label       string   Accessible name. Default "Contents".
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: typically a ContentsList, via caller().
#}
{%- macro contentsNav(params) -%}
{%- set p = params | default({}) -%}
<nav
  class="contents-nav{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Contents') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</nav>
{%- endmacro -%}
