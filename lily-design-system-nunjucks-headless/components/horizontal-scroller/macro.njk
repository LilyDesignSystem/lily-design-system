{#
  horizontalScroller macro — see components/horizontal-scroller/index.md for canonical documentation.

  HTML tag: <div>
  CSS class: horizontal-scroller

  Params:
    text       string  Plain text content.
    html       string  Raw HTML content (rendered via | safe).
    label      string  REQUIRED. aria-label.
    classes    string
    attributes object
#}
{%- macro horizontalScroller(params) -%}
<div
  class="horizontal-scroller{% if params.classes %} {{ params.classes }}{% endif %}" role="region"
  tabindex="0"
  aria-label="{{ params.label }}"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}
    {{ params.html | safe }}
  {%- elif params.text -%}
    {{ params.text }}
  {%- elif caller -%}
    {{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
