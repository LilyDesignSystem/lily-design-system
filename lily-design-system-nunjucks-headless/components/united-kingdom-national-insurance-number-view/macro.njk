{#
  UnitedKingdomNationalInsuranceNumberView macro — a read-only display of United Kingdom's
    National Insurance Number (NINO).

  HTML tag: <span>
  CSS class: united-kingdom-national-insurance-number-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/united-kingdom-national-insurance-number-view/macro.njk" import unitedKingdomNationalInsuranceNumberView %}
    {{ unitedKingdomNationalInsuranceNumberView({ value: "sample", label: "National Insurance Number" }) }}
#}
{%- macro unitedKingdomNationalInsuranceNumberView(params) -%}
<span
  class="united-kingdom-national-insurance-number-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
