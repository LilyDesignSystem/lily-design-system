{#
  MenuBarButton macro — one item in a menu bar.

  HTML tag: <button role="menuitem">
  CSS class: menu-bar-button

  Params:
    text        string
    html        string
    label       string
    expanded    boolean  aria-expanded (when the button opens a submenu).
    controls    string   id of the submenu it controls.
    disabled    boolean
    id          string
    classes     string
    attributes  object
#}
{%- macro menuBarButton(params) -%}
{%- set p = params | default({}) -%}
<button
  class="menu-bar-button{% if p.classes %} {{ p.classes }}{% endif %}"
  type="button"
  role="menuitem"
  {%- if p.expanded != undefined %} aria-expanded="{{ 'true' if p.expanded else 'false' }}"{% endif %}
  {%- if p.controls %} aria-controls="{{ p.controls }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</button>
{%- endmacro -%}
