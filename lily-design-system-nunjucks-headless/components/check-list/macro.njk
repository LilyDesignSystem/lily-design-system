{#
  CheckList macro — an ordered list of check list item components.

  HTML tag: <ol>
  CSS class: check-list

  Params:
    label       string   Accessible name.
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: CheckListItem children via caller().
#}
{%- macro checkList(params) -%}
{%- set p = params | default({}) -%}
<ol
  class="check-list{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</ol>
{%- endmacro -%}
