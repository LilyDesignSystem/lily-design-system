{#
  VitalSignRespiratoryRateAsBreathsPerMinuteView macro — a read-only
    display of respiratory rate in breaths per minute.

  HTML tag: <span>
  CSS class: vital-sign-respiratory-rate-as-breaths-per-minute-view
  Accessibility: unit wrapped in <abbr title="breaths per minute">.

  Params: value, label, id, classes, attributes.
#}
{%- macro vitalSignRespiratoryRateAsBreathsPerMinuteView(params) -%}
<span
  class="vital-sign-respiratory-rate-as-breaths-per-minute-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><span class="vital-sign-value">{{ params.value | default('') }}</span>&nbsp;<abbr class="vital-sign-unit" title="breaths per minute">br/min</abbr></span>
{%- endmacro -%}
