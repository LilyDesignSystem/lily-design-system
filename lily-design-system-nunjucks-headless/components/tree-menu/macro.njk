{#
  TreeMenu macro — a hierarchical tree menu with expandable branches.
    Unlike TreeNav (which is a static navigation), TreeMenu is an
    interactive menu of commands — typically used as a file-menu or
    settings tree with expand/collapse.

  HTML tag: <div role="tree">
  CSS class: tree-menu

  Params:
    label       string   Accessible name. Default "Menu".
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: TreeListItem children via caller() (no intermediate
    TreeList — the tree-menu itself is the tree).
#}
{%- macro treeMenu(params) -%}
{%- set p = params | default({}) -%}
<div
  class="tree-menu{% if p.classes %} {{ p.classes }}{% endif %}"
  role="tree"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Menu') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
