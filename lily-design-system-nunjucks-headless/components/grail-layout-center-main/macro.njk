{#
  GrailLayoutCenterMain macro — the main content region of a grail layout.

  HTML tag: <main>
  CSS class: grail-layout-center-main
  Accessibility: <main> is the main landmark. There should be only
    one per page. Skip links commonly target the id of this region.

  Params:
    id          string   Commonly "main-content" to match a skip link.
    label       string   Accessible name (aria-label) when needed.
    labelledBy  string
    classes     string
    attributes  object

  Body content: the primary page content via caller().
#}
{%- macro grailLayoutCenterMain(params) -%}
{%- set p = params | default({}) -%}
<main
  class="grail-layout-center-main{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</main>
{%- endmacro -%}
