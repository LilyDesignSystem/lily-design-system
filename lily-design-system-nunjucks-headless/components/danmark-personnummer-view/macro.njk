{#
  DanmarkPersonnummerView macro — a read-only display of Denmark's
    Personnummer (CPR-nummer) (CPR).

  HTML tag: <span>
  CSS class: danmark-personnummer-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/danmark-personnummer-view/macro.njk" import danmarkPersonnummerView %}
    {{ danmarkPersonnummerView({ value: "sample", label: "Personal Identity Code" }) }}
#}
{%- macro danmarkPersonnummerView(params) -%}
<span
  class="danmark-personnummer-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
