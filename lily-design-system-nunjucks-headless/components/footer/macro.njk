{#
  Footer macro — a page or section footer area.

  HTML tag: <footer>
  CSS class: footer

  Params:
    label       string   aria-label (useful when multiple footers).
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: via caller().
#}
{%- macro footer(params) -%}
{%- set p = params | default({}) -%}
<footer
  class="footer{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</footer>
{%- endmacro -%}
