{#
  Sonner macro — a toast notification manager.

  HTML tag: <div role="region">
  CSS class: sonner

  Params: label (default "Notifications"), id, classes, attributes.
    Caller provides Toast children.
#}
{%- macro sonner(params) -%}
{%- set p = params | default({}) -%}
<div
  class="sonner{% if p.classes %} {{ p.classes }}{% endif %}"
  role="region"
  aria-label="{{ p.label | default('Notifications') }}"
  aria-live="polite"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
