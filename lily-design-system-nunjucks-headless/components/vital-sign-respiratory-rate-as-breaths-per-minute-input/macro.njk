{#
  VitalSignRespiratoryRateAsBreathsPerMinuteInput macro — a number
    input for respiratory rate in breaths per minute.

  HTML tag: <input type="number">
  CSS class: vital-sign-respiratory-rate-as-breaths-per-minute-input
  Clinical range: defaults to 4–60 breaths/min.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, min (4), max (60), step (1),
    classes, attributes.
#}
{%- macro vitalSignRespiratoryRateAsBreathsPerMinuteInput(params) -%}
<input
  class="vital-sign-respiratory-rate-as-breaths-per-minute-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="number"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  min="{{ params.min | default(4) }}"
  max="{{ params.max | default(60) }}"
  step="{{ params.step | default(1) }}"
  inputmode="numeric"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
