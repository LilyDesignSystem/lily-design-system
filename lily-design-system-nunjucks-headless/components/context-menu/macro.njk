{#
  ContextMenu macro — a menu that appears on right-click or long-press.

  HTML tag: <ul role="menu">
  CSS class: context-menu
  Accessibility:
    - Intended to be anchored to an element via JavaScript.
    - Consumers control show/hide; this macro only emits the markup.

  Params:
    label       string   Accessible name. Default "Context menu".
    labelledBy  string
    open        boolean  Whether the menu is visible. Default false.
    id          string
    classes     string
    attributes  object

  Body content: ContextMenuItem children via caller().
#}
{%- macro contextMenu(params) -%}
{%- set p = params | default({}) -%}
<ul
  class="context-menu{% if p.classes %} {{ p.classes }}{% endif %}"
  role="menu"
  {%- if not p.open %} hidden{% endif %}
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Context menu') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</ul>
{%- endmacro -%}
