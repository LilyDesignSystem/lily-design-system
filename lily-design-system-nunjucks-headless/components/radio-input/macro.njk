{#
  RadioInput macro — a single radio button input.

  HTML tag: <input type="radio">
  CSS class: radio-input
  Accessibility:
    - Pair with a <label for="..."> that names this specific option.
    - Radio buttons with the same name attribute form a single
      keyboard group automatically; arrows move between them.
    - Inside a RadioGroup or Fieldset for a group-level name.

  Params:
    id            string   Element id. Required.
    name          string   Name attribute. Required for grouping.
    value         string   Submitted value when selected.
    checked       boolean  Whether the radio is initially selected.
    required      boolean
    disabled      boolean
    label         string   Accessible name (aria-label). Use only
                           when no <label for="..."> is associated.
    describedBy   string   aria-describedby id list.
    classes       string   Consumer-provided extra CSS classes.
    attributes    object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/radio-input/macro.njk" import radioInput %}
    {% from "components/label/macro.njk" import label %}

    {{ radioInput({ id: "where-yes", name: "where", value: "yes" }) }}
    {{ label({ for: "where-yes", text: "Yes" }) }}
#}
{%- macro radioInput(params) -%}
<input
  class="radio-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="radio"
  id="{{ params.id }}"
  name="{{ params.name }}"
  {%- if params.value is defined %} value="{{ params.value }}"{% endif %}
  {%- if params.checked %} checked{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
