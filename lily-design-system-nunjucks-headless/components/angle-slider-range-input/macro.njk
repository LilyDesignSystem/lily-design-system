{#
  AngleSliderRangeInput macro — a range input for selecting an angle in degrees.

  HTML tag: <input type="range">
  CSS class: angle-slider-range-input

  Params:
    id, name, value (0-360), min (default 0), max (default 360), step (default 1),
    label (aria-label), disabled, required, classes, attributes.
#}
{%- macro angleSliderRangeInput(params) -%}
{%- set p = params | default({}) -%}
<input
  class="angle-slider-range-input{% if p.classes %} {{ p.classes }}{% endif %}"
  type="range"
  min="{{ p.min | default(0) }}"
  max="{{ p.max | default(360) }}"
  step="{{ p.step | default(1) }}"
  value="{{ p.value | default(0) }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
