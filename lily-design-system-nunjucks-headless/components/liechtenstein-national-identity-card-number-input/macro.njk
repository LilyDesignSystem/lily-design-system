{#
  LiechtensteinNationalIdentityCardNumberInput macro — an input for entering Liechtenstein's
    Liechtenstein National Identity Card Number.

  HTML tag: <input type="text">
  CSS class: liechtenstein-national-identity-card-number-input
  Format: 2 letters followed by 8 digits (e.g. ID022143586); changes with each renewed card
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/liechtenstein-national-identity-card-number-input/macro.njk" import liechtensteinNationalIdentityCardNumberInput %}
    {{ liechtensteinNationalIdentityCardNumberInput({ id: "field-id", label: "Liechtenstein National Identity Card Number" }) }}
#}
{%- macro liechtensteinNationalIdentityCardNumberInput(params) -%}
<input
  class="liechtenstein-national-identity-card-number-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
