{#
  NorgeFodselsnummerView macro — a read-only display of Norway's
    Fødselsnummer.

  HTML tag: <span>
  CSS class: norge-fodselsnummer-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/norge-fodselsnummer-view/macro.njk" import norgeFodselsnummerView %}
    {{ norgeFodselsnummerView({ value: "sample", label: "Norwegian Birth Number" }) }}
#}
{%- macro norgeFodselsnummerView(params) -%}
<span
  class="norge-fodselsnummer-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
