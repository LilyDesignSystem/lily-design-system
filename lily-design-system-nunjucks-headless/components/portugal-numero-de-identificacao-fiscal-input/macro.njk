{#
  PortugalNumeroDeIdentificacaoFiscalInput macro — an input for entering Portugal's
    Número de Identificação Fiscal (NIF).

  HTML tag: <input type="text">
  CSS class: portugal-numero-de-identificacao-fiscal-input
  Format: 9 digits; the leading digit(s) encode the kind of taxpayer (1-3 personal, 45 non-resident citizen, 5 legal person, etc.)
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/portugal-numero-de-identificacao-fiscal-input/macro.njk" import portugalNumeroDeIdentificacaoFiscalInput %}
    {{ portugalNumeroDeIdentificacaoFiscalInput({ id: "field-id", label: "Tax Identification Number" }) }}
#}
{%- macro portugalNumeroDeIdentificacaoFiscalInput(params) -%}
<input
  class="portugal-numero-de-identificacao-fiscal-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
