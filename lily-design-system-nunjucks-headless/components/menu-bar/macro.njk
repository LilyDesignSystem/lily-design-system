{#
  MenuBar macro — a horizontal bar of menu triggers.

  HTML tag: <div role="menubar">
  CSS class: menu-bar

  Params:
    label       string   Accessible name. Default "Menu bar".
    labelledBy  string
    id          string
    classes     string
    attributes  object

  Body content: MenuBarButton children via caller().
#}
{%- macro menuBar(params) -%}
{%- set p = params | default({}) -%}
<div
  class="menu-bar{% if p.classes %} {{ p.classes }}{% endif %}"
  role="menubar"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Menu bar') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
