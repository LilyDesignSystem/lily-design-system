{#
  ContainerWithFluidWidth macro — a full-width content wrapper with
    horizontal padding.

  HTML tag: <div>
  CSS class: container-with-fluid-width
  Behavior: Sets inline style `width: 100%; padding-inline: {paddingInline};`.
    Sets `data-padding-inline` attribute for consumer CSS hooks.

  Params:
    text           string   Plain text content (escaped).
    html           string   Raw HTML content (rendered via `| safe`).
    paddingInline  string   Horizontal padding CSS value. Default "1rem".
    label          string   Optional aria-label.
    id             string
    classes        string
    attributes     object

  Usage:
    {% from "components/container-with-fluid-width/macro.njk" import containerWithFluidWidth %}
    {% call containerWithFluidWidth({ paddingInline: "2rem" }) %}
      <p>Full-bleed content.</p>
    {% endcall %}
#}
{%- macro containerWithFluidWidth(params) -%}
{%- set paddingInline = params.paddingInline | default("1rem") -%}
<div
  class="container-with-fluid-width{% if params.classes %} {{ params.classes }}{% endif %}"
  data-padding-inline="{{ paddingInline }}"
  style="width: 100%; padding-inline: {{ paddingInline }};"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
