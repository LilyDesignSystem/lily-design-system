{#
  Figure macro — a self-contained figure with optional caption.

  HTML tag: <figure>
  CSS class: figure

  Params:
    caption     string   Caption text (escaped).
    captionHtml string   Raw caption HTML.
    id          string
    classes     string
    attributes  object

  Body content: the figure content (typically an Image), via caller().
#}
{%- macro figure(params) -%}
{%- set p = params | default({}) -%}
<figure
  class="figure{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
  {%- if p.captionHtml %}
  <figcaption class="figure-caption">{{ p.captionHtml | safe }}</figcaption>
  {%- elif p.caption %}
  <figcaption class="figure-caption">{{ p.caption }}</figcaption>
  {%- endif %}
</figure>
{%- endmacro -%}
