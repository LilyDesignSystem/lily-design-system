{#
  PortugalPassaporteView macro — a read-only display of Portugal's
    Passaporte.

  HTML tag: <span>
  CSS class: portugal-passaporte-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/portugal-passaporte-view/macro.njk" import portugalPassaporteView %}
    {{ portugalPassaporteView({ value: "sample", label: "Portuguese Passport" }) }}
#}
{%- macro portugalPassaporteView(params) -%}
<span
  class="portugal-passaporte-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
