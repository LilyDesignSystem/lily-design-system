{#
  BreadcrumbLink macro — one breadcrumb link in the trail.

  HTML tag: <a>
  CSS class: breadcrumb-link
  Accessibility: a plain hyperlink. The enclosing BreadcrumbListItem
    may set aria-current="page" when the link represents the current
    page (rare; usually the current item is rendered as text).

  Params:
    href        string   Target URL. Default "#".
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    label       string   Accessible name (aria-label).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/breadcrumb-link/macro.njk" import breadcrumbLink %}
    {{ breadcrumbLink({ href: "/", text: "Home" }) }}
#}
{%- macro breadcrumbLink(params) -%}
<a
  class="breadcrumb-link{% if params.classes %} {{ params.classes }}{% endif %}"
  href="{{ params.href | default('#') }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</a>
{%- endmacro -%}
