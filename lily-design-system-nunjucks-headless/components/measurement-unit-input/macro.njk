{#
  MeasurementUnitInput macro — an input for selecting a measurement unit.

  HTML tag: <select>
  CSS class: measurement-unit-input

  Params:
    value       string   Current selection.
    units       array    List of {value, text} unit options.
    name        string
    required    boolean
    disabled    boolean
    label       string
    id          string
    classes     string
    attributes  object
#}
{%- macro measurementUnitInput(params) -%}
{%- set p = params | default({}) -%}
<select
  class="measurement-unit-input{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- for u in p.units | default([]) %}
  <option value="{{ u.value }}"{% if u.value == p.value %} selected{% endif %}>{{ u.text | default(u.value) }}</option>
  {%- endfor %}
</select>
{%- endmacro -%}
