{#
  HoverCard macro — tooltip overlay.

  HTML tag: <div role="tooltip">
  CSS class: hover-card

  Params: label (required), open (default false), id, classes, attributes. Caller provides content.
#}
{%- macro hoverCard(params) -%}
{%- set p = params | default({}) -%}
<div
  class="hover-card{% if p.classes %} {{ p.classes }}{% endif %}"
  role="tooltip"
  aria-label="{{ p.label | default('') }}"
  {%- if not p.open %} hidden{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
