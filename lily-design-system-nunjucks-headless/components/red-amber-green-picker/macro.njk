{#
  RedAmberGreenPicker macro — a picker for selecting a red/amber/green status.

  HTML tag: <div role="radiogroup">
  CSS class: red-amber-green-picker
  Accessibility: role="radiogroup" with an accessible name; children
    are RedAmberGreenPickerButton macros.

  Params:
    label        string   Accessible name (aria-label).
    labelledBy   string
    id           string
    classes      string
    attributes   object

  Body content: RedAmberGreenPickerButton children via caller().
#}
{%- macro redAmberGreenPicker(params) -%}
{%- set p = params | default({}) -%}
<div
  class="red-amber-green-picker{% if p.classes %} {{ p.classes }}{% endif %}"
  role="radiogroup"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
