{#
  MaltaPassportNumberView macro — a read-only display of Malta's
    Malta Passport Number.

  HTML tag: <span>
  CSS class: malta-passport-number-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/malta-passport-number-view/macro.njk" import maltaPassportNumberView %}
    {{ maltaPassportNumberView({ value: "sample", label: "Malta Passport Number" }) }}
#}
{%- macro maltaPassportNumberView(params) -%}
<span
  class="malta-passport-number-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
