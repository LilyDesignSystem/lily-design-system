{#
  VitalSignTotalSleepTimeAsMinPerDayView macro — a read-only display
    of total sleep time as minutes per day.

  HTML tag: <span>
  CSS class: vital-sign-total-sleep-time-as-min-per-day-view
  Accessibility: unit wrapped in <abbr title="minutes per day">.

  Params: value, label, id, classes, attributes.
#}
{%- macro vitalSignTotalSleepTimeAsMinPerDayView(params) -%}
<span
  class="vital-sign-total-sleep-time-as-min-per-day-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><span class="vital-sign-value">{{ params.value | default('') }}</span>&nbsp;<abbr class="vital-sign-unit" title="minutes per day">min/day</abbr></span>
{%- endmacro -%}
