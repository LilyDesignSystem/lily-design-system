{#
  NorthernIrelandHealthAndCareNumberInput macro — an input for
    entering a Northern Ireland Health and Care (H&C) Number.

  HTML tag: <input type="text">
  CSS class: northern-ireland-health-and-care-number-input
  Format: ten digits, canonically grouped "XXX XXX XXXX" (same
    format as the NHS Number used in the rest of the UK).
  Accessibility: inputmode="numeric", autocomplete="off",
    spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/northern-ireland-health-and-care-number-input/macro.njk" import northernIrelandHealthAndCareNumberInput %}
    {{ northernIrelandHealthAndCareNumberInput({ id: "hc" }) }}
#}
{%- macro northernIrelandHealthAndCareNumberInput(params) -%}
<input
  class="northern-ireland-health-and-care-number-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  inputmode="numeric"
  pattern="[0-9 \-]{10,13}"
  maxlength="13"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
