{#
  HrvatskaOsobniIdentifikacijskiBrojInput macro — an input for entering Croatia's
    Osobni identifikacijski broj (OIB).

  HTML tag: <input type="text">
  CSS class: hrvatska-osobni-identifikacijski-broj-input
  Format: 11 digits — 10 random digits plus a check digit; permanent, unique, and assigned to every Croatian citizen and legal person
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/hrvatska-osobni-identifikacijski-broj-input/macro.njk" import hrvatskaOsobniIdentifikacijskiBrojInput %}
    {{ hrvatskaOsobniIdentifikacijskiBrojInput({ id: "field-id", label: "Personal Identification Number" }) }}
#}
{%- macro hrvatskaOsobniIdentifikacijskiBrojInput(params) -%}
<input
  class="hrvatska-osobni-identifikacijski-broj-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
