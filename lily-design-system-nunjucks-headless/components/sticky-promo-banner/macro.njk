{#
  StickyPromoBanner macro — a fixed-position promotional banner with
    a dismiss button.

  HTML tag: <aside>
  CSS class: sticky-promo-banner
  Accessibility:
    - role="complementary" with aria-label exposes the banner as a
      named landmark.
    - The dismiss button has its own aria-label.
    - When `open` is false the banner is rendered with `hidden`.
  Inline style:
    - This is the only Lily headless component that emits inline
      styles. We need them because consumers cannot otherwise pin
      the banner without JavaScript or framework-specific CSS.
    - `position: fixed; left: 0; right: 0;` plus either
      `top: 0;` or `bottom: 0;` based on `params.position`.

  Params:
    label         string   REQUIRED. aria-label for the aside region.
    open          boolean  Default true. When false the banner is hidden.
    position      string   "top" | "bottom". Default "bottom". Sticky edge.
    dismissLabel  string   REQUIRED to render the dismiss button. The
                           button is omitted when this param is falsy.
    text          string   Plain text content (escaped).
    html          string   Raw HTML content (rendered via `| safe`).
    id            string
    classes       string
    attributes    object

  Usage:
    {% from "components/sticky-promo-banner/macro.njk" import stickyPromoBanner %}
    {% call stickyPromoBanner({
      label: "Promotion",
      position: "bottom",
      dismissLabel: "Dismiss promotion"
    }) %}
      <p>50% off everything this weekend.</p>
    {% endcall %}
#}
{%- macro stickyPromoBanner(params) -%}
{%- set position = params.position | default("bottom") -%}
{%- set open = true if params.open == undefined else params.open -%}
{%- set edgeStyle = "top: 0;" if position == "top" else "bottom: 0;" -%}
<aside
  class="sticky-promo-banner{% if params.classes %} {{ params.classes }}{% endif %}"
  role="complementary"
  data-position="{{ position }}"
  style="position: fixed; left: 0; right: 0; {{ edgeStyle }}"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if not open %} hidden{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <div class="sticky-promo-banner-content">
    {%- if params.html -%}{{ params.html | safe }}
    {%- elif params.text -%}{{ params.text }}
    {%- elif caller -%}{{ caller() }}
    {%- endif -%}
  </div>
  {%- if params.dismissLabel %}
  <button
    type="button"
    class="sticky-promo-banner-dismiss"
    aria-label="{{ params.dismissLabel }}"
  >&times;</button>
  {%- endif %}
</aside>
{%- endmacro -%}
