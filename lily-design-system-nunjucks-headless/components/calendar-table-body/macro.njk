{#
  TableBody macro — the <tbody> of a table.

  HTML tag: <tbody>
  CSS class: table-body

  Params:
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Body content: TableRow children via caller().

  Usage: see Table.
#}
{%- macro calendarTableBody(params) -%}
{%- set p = params | default({}) -%}
<tbody
  class="calendar-table-body{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</tbody>
{%- endmacro -%}
