{#
  Details macro — a disclosure widget that shows and hides content.

  HTML tag: <details>
  CSS class: details
  Accessibility: uses the native <details>/<summary> element, which
    provides keyboard behaviour and expanded/collapsed state for
    free. No JavaScript required.

  Params:
    summary     string   The summary label. Required.
    open        boolean  Whether the widget is initially open.
    text        string   Plain text content inside the body.
    html        string   Raw HTML content inside the body
                         (rendered via `| safe`).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/details/macro.njk" import details %}
    {{ details({
      summary: "Where can I find my NHS number?",
      text: "Your NHS number is on any letter from the NHS."
    }) }}
#}
{%- macro details(params) -%}
<details
  class="details{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.open %} open{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <summary class="details-summary">
    <span class="details-summary-text">{{ params.summary }}</span>
  </summary>
  <div class="details-text">
    {%- if params.html -%}{{ params.html | safe }}
    {%- elif params.text -%}<p>{{ params.text }}</p>
    {%- elif caller -%}{{ caller() }}
    {%- endif -%}
  </div>
</details>
{%- endmacro -%}
