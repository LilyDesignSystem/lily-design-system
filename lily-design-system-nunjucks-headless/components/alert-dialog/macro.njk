{#
  AlertDialog macro — a modal dialog for urgent messages requiring
    user acknowledgment.

  HTML tag: <dialog role="alertdialog">
  CSS class: alert-dialog
  Accessibility:
    - role="alertdialog" tells assistive tech this dialog contains
      an urgent message that must be acknowledged.
    - params.label or params.labelledBy names the dialog.
    - params.describedBy points at the message body so screen
      readers announce the content on open.
    - Always include at least one action button.

  Params:
    label         string   Accessible name (aria-label).
    labelledBy    string   aria-labelledby target.
    describedBy   string   aria-describedby target.
    open          boolean  Render with the `open` attribute set.
    id            string
    classes       string
    attributes    object

  Body content: heading, message body, and action controls via caller().

  Usage:
    {% from "components/alert-dialog/macro.njk" import alertDialog %}
    {% call alertDialog({
      id: "confirm-delete",
      labelledBy: "delete-title",
      describedBy: "delete-desc"
    }) %}
      <h2 id="delete-title">Delete record?</h2>
      <p id="delete-desc">This action cannot be undone.</p>
      <button autofocus>Cancel</button>
      <button>Delete</button>
    {% endcall %}
#}
{%- macro alertDialog(params) -%}
{%- set p = params | default({}) -%}
<dialog
  class="alert-dialog{% if p.classes %} {{ p.classes }}{% endif %}"
  role="alertdialog"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.describedBy %} aria-describedby="{{ p.describedBy }}"{% endif %}
  {%- if p.open %} open{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</dialog>
{%- endmacro -%}
