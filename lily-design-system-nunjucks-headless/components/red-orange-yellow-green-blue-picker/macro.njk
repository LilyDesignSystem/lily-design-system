{#
  RedOrangeYellowGreenBluePicker macro — a picker for selecting one
    of five colour-status options (red, orange, yellow, green, blue).

  HTML tag: <div role="radiogroup">
  CSS class: red-orange-yellow-green-blue-picker
  Accessibility: role="radiogroup" with an accessible name; children
    are RedOrangeYellowGreenBluePickerButton macros.

  Params:
    label        string   Accessible name (aria-label).
    labelledBy   string
    id           string
    classes      string
    attributes   object

  Body content: RedOrangeYellowGreenBluePickerButton children via caller().
#}
{%- macro redOrangeYellowGreenBluePicker(params) -%}
{%- set p = params | default({}) -%}
<div
  class="red-orange-yellow-green-blue-picker{% if p.classes %} {{ p.classes }}{% endif %}"
  role="radiogroup"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
