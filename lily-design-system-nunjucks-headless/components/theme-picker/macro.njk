{#
  ThemePicker macro — a picker for selecting a visual theme.

  HTML tag: <div role="radiogroup">
  CSS class: theme-picker

  Params:
    label        string   Accessible name. Default "Theme".
    labelledBy   string
    id           string
    classes      string
    attributes   object

  Body content: ThemePickerButton children via caller().
#}
{%- macro themePicker(params) -%}
{%- set p = params | default({}) -%}
<div
  class="theme-picker{% if p.classes %} {{ p.classes }}{% endif %}"
  role="radiogroup"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Theme') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
