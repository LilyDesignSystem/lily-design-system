{#
  Cascader macro — a multi-level dropdown for selecting a value from
    a hierarchy.

  HTML tag: <div> with role="combobox"
  CSS class: cascader
  Accessibility:
    - role="combobox", aria-haspopup="tree".
    - aria-expanded reflects the panel state.
    - aria-label is REQUIRED. The trigger button is the focusable
      control; consumers should label nested options separately.

  Params:
    label        string   REQUIRED. aria-label for the combobox.
    expanded     boolean  Whether the panel is open. Default false.
    disabled     boolean  Disables the trigger button.
    placeholder  string   Placeholder text on the trigger when no
                          value is selected.
    value        string   Display value (consumer formats path).
    text         string   Plain text content for the panel (escaped).
    html         string   Raw HTML content for the panel (rendered
                          via `| safe`).
    classes      string   Consumer-provided extra CSS classes.
    attributes   object   Extra HTML attributes as key/value pairs on
                          the root element.

  Usage:
    {% from "components/cascader/macro.njk" import cascader %}
    {% call cascader({
      label: "Choose region",
      placeholder: "Select…",
      expanded: true
    }) %}
      <ul role="tree">…</ul>
    {% endcall %}
#}
{%- macro cascader(params) -%}
{%- set p = params | default({}) -%}
<div
  class="cascader{% if p.classes %} {{ p.classes }}{% endif %}"
  role="combobox"
  aria-haspopup="tree"
  aria-expanded="{{ 'true' if p.expanded else 'false' }}"
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <button
    class="cascader-trigger"
    type="button"
    {%- if p.disabled %} disabled{% endif %}
  >
    {%- if p.value -%}{{ p.value }}
    {%- elif p.placeholder -%}{{ p.placeholder }}
    {%- endif -%}
  </button>
  <div
    class="cascader-panel"
    {%- if not p.expanded %} hidden{% endif %}
  >
    {%- if p.html -%}{{ p.html | safe }}
    {%- elif p.text -%}{{ p.text }}
    {%- elif caller -%}{{ caller() }}
    {%- endif -%}
  </div>
</div>
{%- endmacro -%}
