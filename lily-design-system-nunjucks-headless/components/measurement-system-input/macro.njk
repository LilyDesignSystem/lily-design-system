{#
  MeasurementSystemInput macro — an input for selecting a measurement
    system (metric, imperial, us customary).

  HTML tag: <select>
  CSS class: measurement-system-input

  Params:
    value       string   Current selection.
    systems     array    List of {value, text} system options.
    name        string
    required    boolean
    disabled    boolean
    label       string
    id          string
    classes     string
    attributes  object
#}
{%- macro measurementSystemInput(params) -%}
{%- set p = params | default({}) -%}
<select
  class="measurement-system-input{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.name %} name="{{ p.name }}"{% endif %}
  {%- if p.required %} required{% endif %}
  {%- if p.disabled %} disabled{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- for s in p.systems | default([]) %}
  <option value="{{ s.value }}"{% if s.value == p.value %} selected{% endif %}>{{ s.text | default(s.value) }}</option>
  {%- endfor %}
</select>
{%- endmacro -%}
