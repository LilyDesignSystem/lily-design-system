{#
  BelgiqueNumeroDeRegistreNationalView macro — a read-only display of Belgium's
    Numéro de Registre National / Rijksregisternummer (NRN).

  HTML tag: <span>
  CSS class: belgique-numero-de-registre-national-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/belgique-numero-de-registre-national-view/macro.njk" import belgiqueNumeroDeRegistreNationalView %}
    {{ belgiqueNumeroDeRegistreNationalView({ value: "sample", label: "National Register Number" }) }}
#}
{%- macro belgiqueNumeroDeRegistreNationalView(params) -%}
<span
  class="belgique-numero-de-registre-national-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
