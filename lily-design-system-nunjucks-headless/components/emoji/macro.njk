{#
  Emoji macro — a single emoji character with an accessible name.

  HTML tag: <span>
  CSS class: emoji
  Accessibility:
    - Emojis are pictographic; assistive tech support varies by
      platform and device. Always provide params.label so the
      meaning is explicit regardless of device behaviour.
    - role="img" scopes the element to its aria-label.
    - Pass decorative: true for purely decorative emojis that are
      adjacent to text already carrying the meaning.

  Params:
    text        string   The emoji character.
    html        string   Raw HTML content.
    label       string   Accessible name (aria-label). Required
                         unless decorative.
    decorative  boolean  If true, aria-hidden="true" is set and
                         role="img" is omitted.
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/emoji/macro.njk" import emoji %}
    {{ emoji({ text: "🚑", label: "Ambulance" }) }}
    Call 999 {{ emoji({ text: "📞", decorative: true }) }}
#}
{%- macro emoji(params) -%}
<span
  class="emoji{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.decorative %} aria-hidden="true"
  {%- else %} role="img" aria-label="{{ params.label | default('') }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</span>
{%- endmacro -%}
