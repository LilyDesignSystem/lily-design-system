{#
  ColorInput macro — an input for selecting a color value.

  HTML tag: <input type="color">
  CSS class: color-input
  Accessibility: browser-native color picker.
  Format: value is a seven-character hex colour (#rrggbb).

  Params:
    id            string   Element id. Required.
    name          string
    value         string   Hex colour (#rrggbb). Default #000000.
    label         string
    describedBy   string
    errormessage  string
    invalid       boolean
    required      boolean
    disabled      boolean
    readonly      boolean
    list          string   Id of a <datalist> with preset colours.
    classes       string
    attributes    object

  Usage:
    {% from "components/color-input/macro.njk" import colorInput %}
    {{ colorInput({ id: "brand", value: "#005eb8" }) }}
#}
{%- macro colorInput(params) -%}
<input
  class="color-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="color"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('#000000') }}"
  {%- if params.list %} list="{{ params.list }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
