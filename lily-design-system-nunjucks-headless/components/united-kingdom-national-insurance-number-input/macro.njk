{#
  UnitedKingdomNationalInsuranceNumberInput macro — an input for entering United Kingdom's
    National Insurance Number (NINO).

  HTML tag: <input type="text">
  CSS class: united-kingdom-national-insurance-number-input
  Format: two prefix letters, six digits, and a suffix letter (A, B, C, or D) — e.g. AB123456A; the letters D, F, I, Q, U, V and the prefix-2 letter O are excluded
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/united-kingdom-national-insurance-number-input/macro.njk" import unitedKingdomNationalInsuranceNumberInput %}
    {{ unitedKingdomNationalInsuranceNumberInput({ id: "field-id", label: "National Insurance Number" }) }}
#}
{%- macro unitedKingdomNationalInsuranceNumberInput(params) -%}
<input
  class="united-kingdom-national-insurance-number-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
