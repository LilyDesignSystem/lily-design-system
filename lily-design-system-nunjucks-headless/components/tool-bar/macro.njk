{#
  ToolBar macro — a horizontal bar of tool actions.

  HTML tag: <div role="toolbar">
  CSS class: tool-bar

  Params:
    label       string   Accessible name. Default "Tool bar".
    labelledBy  string
    orientation string   "horizontal" (default) | "vertical".
    id          string
    classes     string
    attributes  object

  Body content: ToolBarButton children via caller().
#}
{%- macro toolBar(params) -%}
{%- set p = params | default({}) -%}
<div
  class="tool-bar{% if p.classes %} {{ p.classes }}{% endif %}"
  role="toolbar"
  aria-orientation="{{ p.orientation | default('horizontal') }}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Tool bar') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
