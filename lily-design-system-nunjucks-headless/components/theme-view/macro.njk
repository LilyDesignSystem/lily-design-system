{#
  ThemeView macro — a read-only display of the current theme.

  HTML tag: <span>
  CSS class: theme-view

  Params:
    theme       string   Theme identifier.
    text        string   Visible label. Default: theme.
    label       string   aria-label override.
    id          string
    classes     string
    attributes  object
#}
{%- macro themeView(params) -%}
{%- set p = params | default({}) -%}
<span
  class="theme-view{% if p.classes %} {{ p.classes }}{% endif %}"
  data-theme="{{ p.theme | default('') }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ p.text | default(p.theme) }}</span>
{%- endmacro -%}
