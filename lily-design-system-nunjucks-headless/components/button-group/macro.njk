{#
  ButtonGroup macro — a wrapper that groups related buttons together.

  HTML tag: <div role="group">
  CSS class: button-group
  Accessibility:
    - role="group" plus aria-label names the group of related buttons
      so assistive technology can announce the grouping.

  Params:
    label        string   REQUIRED. aria-label for the group.
    text         string   Plain text content (escaped).
    html         string   Raw HTML content (rendered via `| safe`).
    id           string
    classes      string
    attributes   object

  Body content: related buttons via caller().

  Usage:
    {% from "components/button-group/macro.njk" import buttonGroup %}
    {% call buttonGroup({ label: "Form actions" }) %}
      <button type="submit">Save</button>
      <button type="button">Cancel</button>
    {% endcall %}
#}
{%- macro buttonGroup(params) -%}
{%- set p = params | default({}) -%}
<div
  class="button-group{% if p.classes %} {{ p.classes }}{% endif %}"
  role="group"
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
