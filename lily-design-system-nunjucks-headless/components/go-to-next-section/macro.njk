{# GoToNextSection macro — a link that takes users to the next section of the current page. #}
{%- macro goToNextSection(params) -%}
<a
  class="go-to-next-section{% if params.classes %} {{ params.classes }}{% endif %}"
  href="{{ params.href }}"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
>{{ params.label }}</a>
{%- endmacro -%}
