{#
  RedOrangeYellowGreenBlueView macro — a read-only display of a
    five-level colour status (red | orange | yellow | green | blue).

  HTML tag: <span>
  CSS class: red-orange-yellow-green-blue-view
  Data attribute: data-status on the root; one of
    "red" | "orange" | "yellow" | "green" | "blue" | "unknown".
    Default "unknown".
  Accessibility:
    - The colour alone is not enough; the macro emits a visible
      text label alongside the visual status so assistive tech
      speaks the meaning.

  Params:
    status      string   "red" | "orange" | "yellow" | "green" | "blue" | "unknown".
    text        string   Visible label override. When omitted the
                         status name (capitalised) is used.
    label       string   Accessible name (aria-label).
    id          string
    classes     string
    attributes  object

  Usage:
    {% from "components/red-orange-yellow-green-blue-view/macro.njk" import redOrangeYellowGreenBlueView %}
    {{ redOrangeYellowGreenBlueView({ status: "yellow", text: "Warning" }) }}
#}
{%- macro redOrangeYellowGreenBlueView(params) -%}
{%- set status = params.status | default("unknown") -%}
{%- set defaultText = { red: "Red", orange: "Orange", yellow: "Yellow", green: "Green", blue: "Blue", unknown: "Unknown" } -%}
{%- set text = params.text | default(defaultText[status]) -%}
<span
  class="red-orange-yellow-green-blue-view{% if params.classes %} {{ params.classes }}{% endif %}"
  data-status="{{ status }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <span class="red-orange-yellow-green-blue-view-indicator" aria-hidden="true"></span>
  <span class="red-orange-yellow-green-blue-view-text">{{ text }}</span>
</span>
{%- endmacro -%}
