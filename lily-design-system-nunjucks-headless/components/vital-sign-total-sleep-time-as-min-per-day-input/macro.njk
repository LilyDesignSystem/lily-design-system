{#
  VitalSignTotalSleepTimeAsMinPerDayInput macro — a number input for
    total sleep time as minutes per day.

  HTML tag: <input type="number">
  CSS class: vital-sign-total-sleep-time-as-min-per-day-input
  Clinical range: defaults to 0–1440 minutes (i.e. 0–24 hours).

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, min (0), max (1440), step (1),
    classes, attributes.
#}
{%- macro vitalSignTotalSleepTimeAsMinPerDayInput(params) -%}
<input
  class="vital-sign-total-sleep-time-as-min-per-day-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="number"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  min="{{ params.min | default(0) }}"
  max="{{ params.max | default(1440) }}"
  step="{{ params.step | default(1) }}"
  inputmode="numeric"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
