{#
  VitalSignCholesterolAsHdlMmolPerLitreInput macro — a number input
    for cholesterol HDL ("good cholesterol") in millimoles per litre,
    to one decimal place.

  HTML tag: <input type="number">
  CSS class: vital-sign-cholesterol-as-hdl-mmol-per-litre-input
  Clinical range: defaults to 0.1–5.0 mmol/L. Step 0.1.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, min (0.1), max (5), step (0.1),
    classes, attributes.
#}
{%- macro vitalSignCholesterolAsHdlMmolPerLitreInput(params) -%}
<input
  class="vital-sign-cholesterol-as-hdl-mmol-per-litre-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="number"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  min="{{ params.min | default(0.1) }}"
  max="{{ params.max | default(5) }}"
  step="{{ params.step | default(0.1) }}"
  inputmode="decimal"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
