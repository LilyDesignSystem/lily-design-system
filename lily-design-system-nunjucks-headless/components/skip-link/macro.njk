{#
  SkipLink macro — a hidden link for keyboard users to skip to main content.

  HTML tag: <a>
  CSS class: skip-link
  Accessibility: the link is visually hidden until it receives
    keyboard focus, at which point the CSS reveals it. Targets the
    id of the main content region.

  Params:
    href        string   Fragment identifier for the main content.
                         Default "#main-content".
    text        string   Plain text content (escaped).
                         Default "Skip to main content".
    html        string   Raw HTML content (rendered via `| safe`).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/skip-link/macro.njk" import skipLink %}
    {{ skipLink() }}
    {{ skipLink({ href: "#content", text: "Skip to content" }) }}
#}
{%- macro skipLink(params) -%}
{%- set p = params | default({}) -%}
<a
  class="skip-link{% if p.classes %} {{ p.classes }}{% endif %}"
  href="{{ p.href | default('#main-content') }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- else -%}Skip to main content
  {%- endif -%}
</a>
{%- endmacro -%}
