{#
  Organization macro — an organization component that contains other
    organization-related information (name, description, contact).

  HTML tag: <div>
  CSS class: organization

  Params:
    name        string   Organization name.
    description string
    label       string   aria-label override.
    text        string
    html        string
    id          string
    classes     string
    attributes  object
#}
{%- macro organization(params) -%}
{%- set p = params | default({}) -%}
<div
  class="organization{% if p.classes %} {{ p.classes }}{% endif %}"
  role="group"
  aria-label="{{ p.label | default(p.name) }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.name %}<span class="organization-name">{{ p.name }}</span>{% endif %}
  {%- if p.description %}<span class="organization-description">{{ p.description }}</span>{% endif %}
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
