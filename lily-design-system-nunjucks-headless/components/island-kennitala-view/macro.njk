{#
  IslandKennitalaView macro — a read-only display of Iceland's
    Kennitala.

  HTML tag: <span>
  CSS class: island-kennitala-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/island-kennitala-view/macro.njk" import islandKennitalaView %}
    {{ islandKennitalaView({ value: "sample", label: "Personal Identity Code" }) }}
#}
{%- macro islandKennitalaView(params) -%}
<span
  class="island-kennitala-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
