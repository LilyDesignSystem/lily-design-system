{#
  DateInput macro — an input for entering a date value.

  HTML tag: <input type="date">
  CSS class: date-input
  Accessibility: browser-native date control. See TextInput for
    aria-describedby/errormessage/invalid.
  Format note:
    - The date value submitted is always ISO 8601 (YYYY-MM-DD), but
      the native picker displays dates in the user's locale.
    - For structured day/month/year triples with no native picker,
      prefer DateField.

  Params:
    id            string   Element id. Required.
    name          string   Name attribute. Defaults to id.
    value         string   ISO date (YYYY-MM-DD).
    min           string   Earliest allowed ISO date.
    max           string   Latest allowed ISO date.
    step          number   Allowed increment in days. Default 1.
    label         string
    describedBy   string
    errormessage  string
    invalid       boolean
    required      boolean
    disabled      boolean
    readonly      boolean
    autocomplete  string
    classes       string
    attributes    object

  Usage:
    {% from "components/date-input/macro.njk" import dateInput %}
    {{ dateInput({ id: "dob", max: "2026-04-19" }) }}
#}
{%- macro dateInput(params) -%}
<input
  class="date-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="date"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  {%- if params.min %} min="{{ params.min }}"{% endif %}
  {%- if params.max %} max="{{ params.max }}"{% endif %}
  {%- if params.step %} step="{{ params.step }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.autocomplete %} autocomplete="{{ params.autocomplete }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
