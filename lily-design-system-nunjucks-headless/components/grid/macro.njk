{#
  Grid macro — a CSS grid layout container with configurable columns
    and gap.

  HTML tag: <div>
  CSS class: grid
  Behavior: If `columns` is a number, uses
    `repeat({columns}, minmax(0, 1fr))`; if it is a string, uses the
    value as-is for `grid-template-columns`. Sets `data-columns`.

  Params:
    text         string         Plain text content (escaped).
    html         string         Raw HTML content (rendered via `| safe`).
    columns      number|string  Column count or grid-template-columns
                                value. Default 12.
    gap          string         Gap CSS value. Default "1rem".
    label        string         Optional aria-label.
    id           string
    classes      string
    attributes   object

  Usage:
    {% from "components/grid/macro.njk" import grid %}
    {% call grid({ columns: 3, gap: "1.5rem" }) %}
      <div>One</div><div>Two</div><div>Three</div>
    {% endcall %}
#}
{%- macro grid(params) -%}
{%- set columns = params.columns | default(12) -%}
{%- set gap = params.gap | default("1rem") -%}
{%- if columns is number -%}
  {%- set template = "repeat(" + columns + ", minmax(0, 1fr))" -%}
{%- else -%}
  {%- set template = columns -%}
{%- endif -%}
<div
  class="grid{% if params.classes %} {{ params.classes }}{% endif %}"
  data-columns="{{ columns }}"
  style="display: grid; grid-template-columns: {{ template }}; gap: {{ gap }};"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
