{#
  ContentsListItem macro — one contents list item component linking
    to a page section.

  HTML tag: <li>
  CSS class: contents-list-item
  Accessibility: when params.current is true, aria-current="location"
    is set so screen readers announce the current section.

  Params:
    current     boolean  Whether this item represents the current
                         section. Sets aria-current="location".
    text        string
    html        string
    id          string
    classes     string
    attributes  object
#}
{%- macro contentsListItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="contents-list-item{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.current %} aria-current="location"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</li>
{%- endmacro -%}
