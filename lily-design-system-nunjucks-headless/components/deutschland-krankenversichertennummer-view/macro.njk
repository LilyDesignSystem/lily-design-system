{#
  DeutschlandKrankenversichertennummerView macro — a read-only display of Germany's
    Krankenversichertennummer (KVNR).

  HTML tag: <span>
  CSS class: deutschland-krankenversichertennummer-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/deutschland-krankenversichertennummer-view/macro.njk" import deutschlandKrankenversichertennummerView %}
    {{ deutschlandKrankenversichertennummerView({ value: "sample", label: "Health Insurance Number" }) }}
#}
{%- macro deutschlandKrankenversichertennummerView(params) -%}
<span
  class="deutschland-krankenversichertennummer-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
