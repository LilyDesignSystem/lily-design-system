{#
  SummaryList macro — an ordered list of key-value summary pairs.

  HTML tag: <dl>
  CSS class: summary-list
  Note on semantics: NHS.UK and WCAG both recommend a description
    list (<dl>) for key/value summaries (check-your-answers),
    because the semantic pairing of term and description is
    meaningful to assistive tech. Lily's general "-list" suffix
    maps to <ol>, but this component is explicitly a description
    list. Consumers nest SummaryListItem children, each of which
    emits a grouping <div> with <dt> and <dd>.

  Params:
    label       string   Accessible name (aria-label).
    labelledBy  string   aria-labelledby target (preferred).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Body content: SummaryListItem children via caller().

  Usage:
    {% from "components/summary-list/macro.njk" import summaryList %}
    {% from "components/summary-list-item/macro.njk" import summaryListItem %}

    {% call summaryList({ label: "Your answers" }) %}
      {{ summaryListItem({ key: "Name", value: "Jane Smith" }) }}
      {{ summaryListItem({
        key: "Date of birth",
        value: "1985-04-27",
        actions: [ { text: "Change", href: "/dob" } ]
      }) }}
    {% endcall %}
#}
{%- macro summaryList(params) -%}
{%- set p = params | default({}) -%}
<dl
  class="summary-list{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</dl>
{%- endmacro -%}
