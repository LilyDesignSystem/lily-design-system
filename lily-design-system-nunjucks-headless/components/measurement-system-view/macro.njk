{#
  MeasurementSystemView macro — a read-only display of a measurement system
    (e.g. "Metric", "Imperial", "US customary").

  HTML tag: <span>
  CSS class: measurement-system-view

  Params:
    system      string   System identifier.
    text        string   Visible label. Default: system.
    label       string   aria-label override.
    id          string
    classes     string
    attributes  object
#}
{%- macro measurementSystemView(params) -%}
{%- set p = params | default({}) -%}
<span
  class="measurement-system-view{% if p.classes %} {{ p.classes }}{% endif %}"
  data-system="{{ p.system | default('') }}"
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ p.text | default(p.system) }}</span>
{%- endmacro -%}
