{#
  EnglandNationalHealthServiceNumberView macro — a read-only display of England's
    National Health Service Number (NHS).

  HTML tag: <span>
  CSS class: england-national-health-service-number-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/england-national-health-service-number-view/macro.njk" import englandNationalHealthServiceNumberView %}
    {{ englandNationalHealthServiceNumberView({ value: "sample", label: "National Health Service Number" }) }}
#}
{%- macro englandNationalHealthServiceNumberView(params) -%}
<span
  class="england-national-health-service-number-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
