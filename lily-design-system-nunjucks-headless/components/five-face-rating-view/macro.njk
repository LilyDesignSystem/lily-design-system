{#
  FiveFaceRatingView macro — a read-only display of a five-face
    satisfaction rating (1 = very unhappy, 5 = very happy).

  HTML tag: <span>
  CSS class: five-face-rating-view
  Data attribute: data-value (1–5).
  Accessibility: role="img" + aria-label with the verbal rating
    ("Very unhappy", "Unhappy", "Neutral", "Happy", "Very happy").

  Params:
    value       number   1–5 rating.
    label       string   aria-label override.
    id          string
    classes     string
    attributes  object
#}
{%- macro fiveFaceRatingView(params) -%}
{%- set value = params.value | default(3) -%}
{%- set phrase = "Neutral" -%}
{%- if value == 1 -%}{%- set phrase = "Very unhappy" -%}
{%- elif value == 2 -%}{%- set phrase = "Unhappy" -%}
{%- elif value == 3 -%}{%- set phrase = "Neutral" -%}
{%- elif value == 4 -%}{%- set phrase = "Happy" -%}
{%- elif value == 5 -%}{%- set phrase = "Very happy" -%}
{%- endif -%}
{%- set label = params.label | default("Rating: " ~ phrase) -%}
<span
  class="five-face-rating-view{% if params.classes %} {{ params.classes }}{% endif %}"
  role="img"
  data-value="{{ value }}"
  aria-label="{{ label }}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
></span>
{%- endmacro -%}
