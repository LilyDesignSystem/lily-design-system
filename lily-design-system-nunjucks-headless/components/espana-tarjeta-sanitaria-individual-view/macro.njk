{#
  EspanaTarjetaSanitariaIndividualView macro — a read-only display
    of a España Tarjeta Sanitaria Individual (TSI) code.

  HTML tag: <span>
  CSS class: espana-tarjeta-sanitaria-individual-view
  Formatting: because the TSI's exact format varies by autonomous
    community, the view renders the value as-is without automatic
    grouping. Consumers may apply community-specific formatting in
    advance.

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/espana-tarjeta-sanitaria-individual-view/macro.njk" import espanaTarjetaSanitariaIndividualView %}
    {{ espanaTarjetaSanitariaIndividualView({
      value: "BBBB090810C003",
      label: "Tarjeta Sanitaria Individual"
    }) }}
#}
{%- macro espanaTarjetaSanitariaIndividualView(params) -%}
<span
  class="espana-tarjeta-sanitaria-individual-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default('') }}</span>
{%- endmacro -%}
