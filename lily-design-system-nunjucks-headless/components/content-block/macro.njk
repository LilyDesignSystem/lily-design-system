{#
  contentBlock macro — content width constraint container.

  HTML tag: <div>
  CSS class: content-block

  Params:
    width      string  "narrower" | "narrow" | "normal" | "wide" | "wider" | "widest" | "fluid". Default "normal".
    text       string
    html       string
    classes    string
    attributes object
#}
{%- macro contentBlock(params) -%}
{%- set width = params.width | default("normal") -%}
<div
  class="content-block{% if params.classes %} {{ params.classes }}{% endif %}"
  data-width="{{ width }}"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}
    {{ params.html | safe }}
  {%- elif params.text -%}
    {{ params.text }}
  {%- elif caller -%}
    {{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
