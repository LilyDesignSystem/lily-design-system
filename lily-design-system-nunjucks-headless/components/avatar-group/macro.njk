{#
  AvatarGroup macro — a group of avatar components (e.g. collaborators).

  HTML tag: <div>
  CSS class: avatar-group
  Accessibility:
    - role="group" with an accessible name scopes the collection
      for screen readers.
    - params.label should describe the group (e.g. "Care team").

  Params:
    label        string   Accessible name (aria-label).
    labelledBy   string
    id           string
    classes      string
    attributes   object

  Body content: Avatar macros via caller().

  Usage:
    {% from "components/avatar-group/macro.njk" import avatarGroup %}
    {% call avatarGroup({ label: "Care team" }) %}
      …Avatar macros…
    {% endcall %}
#}
{%- macro avatarGroup(params) -%}
{%- set p = params | default({}) -%}
<div
  class="avatar-group{% if p.classes %} {{ p.classes }}{% endif %}"
  role="group"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
