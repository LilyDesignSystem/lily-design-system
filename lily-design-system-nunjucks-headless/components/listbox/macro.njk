{#
  Listbox macro — a list of selectable options with keyboard navigation.

  HTML tag: <ul role="listbox">
  CSS class: listbox

  Params: label, labelledBy, multiselectable, id, classes, attributes.
    Caller provides option elements with role="option".
#}
{%- macro listbox(params) -%}
{%- set p = params | default({}) -%}
<ul
  class="listbox{% if p.classes %} {{ p.classes }}{% endif %}"
  role="listbox"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Listbox') }}"{% endif %}
  {%- if p.multiselectable %} aria-multiselectable="true"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</ul>
{%- endmacro -%}
