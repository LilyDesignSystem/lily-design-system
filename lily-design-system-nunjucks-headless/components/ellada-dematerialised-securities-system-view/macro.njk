{#
  ElladaDematerialisedSecuritiesSystemView macro — a read-only display of Greece's
    Dematerialised Securities System (DSS).

  HTML tag: <span>
  CSS class: ellada-dematerialised-securities-system-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/ellada-dematerialised-securities-system-view/macro.njk" import elladaDematerialisedSecuritiesSystemView %}
    {{ elladaDematerialisedSecuritiesSystemView({ value: "sample", label: "Dematerialised Securities System" }) }}
#}
{%- macro elladaDematerialisedSecuritiesSystemView(params) -%}
<span
  class="ellada-dematerialised-securities-system-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
