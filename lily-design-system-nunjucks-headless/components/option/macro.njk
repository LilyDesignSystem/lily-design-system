{#
  Option macro — an option element within a select dropdown.

  HTML tag: <option>
  CSS class: option
  Accessibility: browser-native; no extra ARIA required.

  Params:
    value       string   Submitted value when selected.
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    selected    boolean  Whether the option is initially selected.
    disabled    boolean  Disable the option (e.g. for placeholders).
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/option/macro.njk" import option %}
    {% from "components/select/macro.njk" import select %}

    {% call select({ id: "country" }) %}
      {{ option({ value: "", text: "Choose a country", disabled: true }) }}
      {{ option({ value: "gb", text: "United Kingdom", selected: true }) }}
      {{ option({ value: "ie", text: "Ireland" }) }}
    {% endcall %}
#}
{%- macro option(params) -%}
<option
  {%- if params.classes %} class="option {{ params.classes }}"{% else %} class="option"{% endif %}
  {%- if params.value is defined %} value="{{ params.value }}"{% endif %}
  {%- if params.selected %} selected{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- endif -%}
</option>
{%- endmacro -%}
