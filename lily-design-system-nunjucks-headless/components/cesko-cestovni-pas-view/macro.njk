{#
  CeskoCestovniPasView macro — a read-only display of Czech Republic's
    Cestovní pas.

  HTML tag: <span>
  CSS class: cesko-cestovni-pas-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/cesko-cestovni-pas-view/macro.njk" import ceskoCestovniPasView %}
    {{ ceskoCestovniPasView({ value: "sample", label: "Czech Passport" }) }}
#}
{%- macro ceskoCestovniPasView(params) -%}
<span
  class="cesko-cestovni-pas-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
