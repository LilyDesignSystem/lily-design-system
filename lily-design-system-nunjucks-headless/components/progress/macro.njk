{#
  Progress macro — a horizontal progress bar showing completion.

  HTML tag: <progress>
  CSS class: progress
  Accessibility:
    - <progress> natively exposes role="progressbar" and its value
      to assistive tech. No extra ARIA is required when the element
      has value and max.
    - For indeterminate progress, omit params.value (the element
      renders in indeterminate state).
    - params.label gives the progress bar an accessible name.

  Params:
    value       number   Current progress value. Omit for
                         indeterminate state.
    max         number   Maximum value. Default 100.
    label       string   Accessible name (aria-label).
    labelledBy  string   aria-labelledby target.
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Body content: fallback text shown by browsers that do not support
    <progress> (rare). Typically "{value}%" via caller().

  Usage:
    {% from "components/progress/macro.njk" import progress %}
    {{ progress({ value: 40, max: 100, label: "Upload progress" }) }}
#}
{%- macro progress(params) -%}
{%- set p = params | default({}) -%}
<progress
  class="progress{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.value is defined %} value="{{ p.value }}"{% endif %}
  max="{{ p.max | default(100) }}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"
  {%- elif p.label %} aria-label="{{ p.label }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- elif p.value is defined -%}{{ p.value }}%
  {%- endif -%}
</progress>
{%- endmacro -%}
