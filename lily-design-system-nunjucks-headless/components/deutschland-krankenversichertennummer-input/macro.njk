{#
  DeutschlandKrankenversichertennummerInput macro — an input for entering Germany's
    Krankenversichertennummer (KVNR).

  HTML tag: <input type="text">
  CSS class: deutschland-krankenversichertennummer-input
  Format: a random capital letter followed by eight random digits and a Luhn check digit
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/deutschland-krankenversichertennummer-input/macro.njk" import deutschlandKrankenversichertennummerInput %}
    {{ deutschlandKrankenversichertennummerInput({ id: "field-id", label: "Health Insurance Number" }) }}
#}
{%- macro deutschlandKrankenversichertennummerInput(params) -%}
<input
  class="deutschland-krankenversichertennummer-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
