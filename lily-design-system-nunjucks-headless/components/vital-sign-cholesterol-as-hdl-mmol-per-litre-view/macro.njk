{#
  VitalSignCholesterolAsHdlMmolPerLitreView macro — a read-only display
    of cholesterol HDL in millimoles per litre.

  HTML tag: <span>
  CSS class: vital-sign-cholesterol-as-hdl-mmol-per-litre-view
  Accessibility: unit wrapped in <abbr title="millimoles per litre">.

  Params: value, label, id, classes, attributes.
#}
{%- macro vitalSignCholesterolAsHdlMmolPerLitreView(params) -%}
<span
  class="vital-sign-cholesterol-as-hdl-mmol-per-litre-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
><span class="vital-sign-value">{{ params.value | default('') }}</span>&nbsp;<abbr class="vital-sign-unit" title="millimoles per litre">mmol/L</abbr></span>
{%- endmacro -%}
