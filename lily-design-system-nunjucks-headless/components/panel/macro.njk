{#
  Panel macro — a generic content panel with optional heading.

  HTML tag: <section> when a heading or label exposes the panel as
    a region; <div> otherwise (a region landmark requires an
    accessible name).
  CSS class: panel
  Accessibility:
    - Prefer a visible heading paired with params.labelledBy (the
      heading's id).
    - Fall back to params.label for an aria-label when no heading
      is present.

  Params:
    heading       string   Visible heading text. Rendered in a
                           <header class="panel-header"> above the
                           body, using the h-level from params.
    headingLevel  number   Heading level 2–6. Default 2.
    headingId     string   Id of the heading; auto-derived from
                           params.id when provided.
    text          string   Plain text body (escaped).
    html          string   Raw HTML body.
    label         string   Accessible name when no heading is shown.
    labelledBy    string   aria-labelledby target override.
    id            string
    classes       string
    attributes    object

  Usage:
    {% from "components/panel/macro.njk" import panel %}
    {{ panel({
      heading: "Contact us",
      text: "Email support@example.com for help."
    }) }}
#}
{%- macro panel(params) -%}
{%- set level = params.headingLevel | default(2) -%}
{%- set headingId = params.headingId or (params.id ~ "-heading" if params.id and params.heading) -%}
{%- set hasLabel = params.heading or params.label or params.labelledBy -%}
{%- set tag = "section" if hasLabel else "div" -%}
<{{ tag }}
  class="panel{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.labelledBy %} aria-labelledby="{{ params.labelledBy }}"
  {%- elif headingId %} aria-labelledby="{{ headingId }}"
  {%- elif params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.heading %}
  <header class="panel-header">
    <h{{ level }} class="panel-heading"{% if headingId %} id="{{ headingId }}"{% endif %}>{{ params.heading }}</h{{ level }}>
  </header>
  {%- endif %}
  <div class="panel-body">
    {%- if params.html -%}{{ params.html | safe }}
    {%- elif params.text -%}<p>{{ params.text }}</p>
    {%- elif caller -%}{{ caller() }}
    {%- endif -%}
  </div>
</{{ tag }}>
{%- endmacro -%}
