{#
  TableTD macro — a table column header cell.

  HTML tag: <th>
  CSS class: table-col
  Accessibility: scope defaults to "col". Use scope="row" for row
    headers (a <th> that labels a whole row). Use scope="colgroup"
    or "rowgroup" for spanning headers.

  Params:
    text        string   Plain text content (escaped).
    html        string   Raw HTML content (rendered via `| safe`).
    scope       string   "col" (default), "row", "colgroup", "rowgroup".
    colspan     number
    rowspan     number
    abbr        string   Short label used by some assistive tech.
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Usage: see Table.
#}
{%- macro tableCol(params) -%}
<th
  class="table-col{% if params.classes %} {{ params.classes }}{% endif %}"
  scope="{{ params.scope | default('col') }}"
  {%- if params.colspan %} colspan="{{ params.colspan }}"{% endif %}
  {%- if params.rowspan %} rowspan="{{ params.rowspan }}"{% endif %}
  {%- if params.abbr %} abbr="{{ params.abbr }}"{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</th>
{%- endmacro -%}
