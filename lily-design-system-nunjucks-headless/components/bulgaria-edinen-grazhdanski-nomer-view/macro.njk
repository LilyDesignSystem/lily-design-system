{#
  BulgariaEdinenGrazhdanskiNomerView macro — a read-only display of Bulgaria's
    Единен граждански номер / Edinen grazhdanski nomer (EGN).

  HTML tag: <span>
  CSS class: bulgaria-edinen-grazhdanski-nomer-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/bulgaria-edinen-grazhdanski-nomer-view/macro.njk" import bulgariaEdinenGrazhdanskiNomerView %}
    {{ bulgariaEdinenGrazhdanskiNomerView({ value: "sample", label: "Uniform Civil Number" }) }}
#}
{%- macro bulgariaEdinenGrazhdanskiNomerView(params) -%}
<span
  class="bulgaria-edinen-grazhdanski-nomer-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
