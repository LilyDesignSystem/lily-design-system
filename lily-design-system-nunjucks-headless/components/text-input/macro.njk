{#
  TextInput macro — a single-line text input field.

  HTML tag: <input type="text">
  CSS class: text-input
  Accessibility:
    - Link to a <label for="..."> via the input's id.
    - Link hints and error messages via aria-describedby and
      aria-errormessage; set aria-invalid when the input is in
      error state.

  Params:
    id            string   Element id. Required.
    name          string   Name attribute. Defaults to id.
    value         string   Current value.
    label         string   Accessible name (aria-label). Use only
                           when no <label for="..."> is associated.
    describedBy   string   Space-separated id list for aria-describedby.
    errormessage  string   Id for aria-errormessage.
    invalid       boolean  Sets aria-invalid="true" when truthy.
    required      boolean  Marks the field as required.
    disabled      boolean  Disable the field.
    readonly      boolean  Make the field read-only.
    placeholder   string   Placeholder text.
    autocomplete  string   Autocomplete token.
    pattern       string   Validation regex pattern.
    minlength     number
    maxlength     number
    inputmode     string
    spellcheck    boolean
    classes       string   Consumer-provided extra CSS classes.
    attributes    object   Extra HTML attributes as key/value pairs.

  Usage:
    {% from "components/text-input/macro.njk" import textInput %}
    {{ textInput({ id: "name", autocomplete: "name" }) }}
#}
{%- macro textInput(params) -%}
<input
  class="text-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.placeholder %} placeholder="{{ params.placeholder }}"{% endif %}
  {%- if params.autocomplete %} autocomplete="{{ params.autocomplete }}"{% endif %}
  {%- if params.pattern %} pattern="{{ params.pattern }}"{% endif %}
  {%- if params.minlength %} minlength="{{ params.minlength }}"{% endif %}
  {%- if params.maxlength %} maxlength="{{ params.maxlength }}"{% endif %}
  {%- if params.inputmode %} inputmode="{{ params.inputmode }}"{% endif %}
  {%- if params.spellcheck is defined %} spellcheck="{{ params.spellcheck }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
