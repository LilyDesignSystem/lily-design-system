{#
  byline macro — author attribution with optional publish/update timestamps.

  HTML tag: <div>
  CSS class: byline

  Params:
    text             string  Author content (plain text).
    html             string  Author content (raw HTML).
    publishedHtml    string  Raw HTML for the publish date (typically <time>).
    publishedText    string  Plain-text publish date.
    updatedHtml      string  Raw HTML for the updated date.
    updatedText      string  Plain-text updated date.
    classes          string
    attributes       object
#}
{%- macro byline(params) -%}
<div
  class="byline{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  <span class="byline-authors">
    {%- if params.html -%}
      {{ params.html | safe }}
    {%- elif params.text -%}
      {{ params.text }}
    {%- elif caller -%}
      {{ caller() }}
    {%- endif -%}
  </span>
  {%- if params.publishedHtml %}<span class="byline-published">{{ params.publishedHtml | safe }}</span>{% elif params.publishedText %}<span class="byline-published">{{ params.publishedText }}</span>{% endif -%}
  {%- if params.updatedHtml %}<span class="byline-updated">{{ params.updatedHtml | safe }}</span>{% elif params.updatedText %}<span class="byline-updated">{{ params.updatedText }}</span>{% endif -%}
</div>
{%- endmacro -%}
