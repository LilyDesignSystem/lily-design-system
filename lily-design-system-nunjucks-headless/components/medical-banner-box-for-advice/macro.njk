{#
  MedicalBannerBoxForAdvice macro — a medical record banner box for
    advice information (contacts, contexts, plans, care
    instructions, etc.).

  HTML tag: <div>
  CSS class: medical-banner-box-for-advice
  Data attribute: data-severity="advice" on the root so CSS and JS
    can style or filter by severity.

  Params:
    heading       string   Visible heading (e.g. "Care plan").
    headingLevel  number   Heading level 2–6. Default 4.
    text          string
    html          string
    label         string   Accessible name (aria-label).
    id            string
    classes       string
    attributes    object
#}
{%- macro medicalBannerBoxForAdvice(params) -%}
{%- set level = params.headingLevel | default(4) -%}
<div
  class="medical-banner-box-for-advice{% if params.classes %} {{ params.classes }}{% endif %}"
  data-severity="advice"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.heading %}
  <h{{ level }} class="medical-banner-box-heading">{{ params.heading }}</h{{ level }}>
  {%- endif %}
  {%- if params.html %}
  {{ params.html | safe }}
  {%- elif params.text %}
  <p>{{ params.text }}</p>
  {%- elif caller %}
  {{ caller() }}
  {%- endif %}
</div>
{%- endmacro -%}
