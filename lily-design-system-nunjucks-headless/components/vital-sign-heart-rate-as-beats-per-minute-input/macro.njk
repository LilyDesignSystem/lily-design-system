{#
  VitalSignHeartRateAsBeatsPerMinuteInput macro — a number input for
    heart rate in beats per minute (BPM).

  HTML tag: <input type="number">
  CSS class: vital-sign-heart-rate-as-beats-per-minute-input
  Clinical range: defaults to 30–250 bpm (covers bradycardia to
    sinus tachycardia). Consumers may override when an unusual
    range is clinically relevant.
  Accessibility: inputmode="numeric"; pair with a Label and a Hint
    clarifying the unit.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, min (default 30), max (default 250),
    step (default 1), classes, attributes.

  Usage:
    {% from "components/vital-sign-heart-rate-as-beats-per-minute-input/macro.njk" import vitalSignHeartRateAsBeatsPerMinuteInput %}
    {{ vitalSignHeartRateAsBeatsPerMinuteInput({ id: "hr" }) }}
#}
{%- macro vitalSignHeartRateAsBeatsPerMinuteInput(params) -%}
<input
  class="vital-sign-heart-rate-as-beats-per-minute-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="number"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  min="{{ params.min | default(30) }}"
  max="{{ params.max | default(250) }}"
  step="{{ params.step | default(1) }}"
  inputmode="numeric"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
