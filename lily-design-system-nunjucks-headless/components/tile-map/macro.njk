{#
  tileMap macro — a tile cartogram map wrapper.

  HTML tag: <div>
  CSS class: tile-map

  Params:
    label      string  REQUIRED. aria-label describing the map.
    text       string
    html       string  Tile layer markup.
    classes    string
    attributes object

  Keyboard interactions (Arrow keys, Enter/Space, Escape) are the
  consumer's responsibility — Nunjucks renders the markup but does
  not bundle JS.
#}
{%- macro tileMap(params) -%}
<div
  class="tile-map{% if params.classes %} {{ params.classes }}{% endif %}"
  role="img"
  aria-label="{{ params.label }}"
  aria-roledescription="tile map"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.html -%}
    {{ params.html | safe }}
  {%- elif params.text -%}
    {{ params.text }}
  {%- elif caller -%}
    {{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
