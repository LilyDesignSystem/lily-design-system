{#
  graphicBlock macro — wrapper for charts and graphics with structural metadata.

  HTML tag: <figure>
  CSS class: graphic-block

  Params:
    label        string  REQUIRED. aria-label describing the graphic.
    title        string  Title displayed above the graphic.
    description  string  Description text below the title.
    notes        string  Notes/source text below the graphic.
    text         string  Graphic content (text fallback).
    html         string  Graphic content (raw HTML).
    classes      string
    attributes   object
#}
{%- macro graphicBlock(params) -%}
<figure
  class="graphic-block{% if params.classes %} {{ params.classes }}{% endif %}"
  role="img"
  aria-label="{{ params.label }}"
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if params.title or params.description or params.notes -%}
    <figcaption class="graphic-block-caption">
      {%- if params.title %}<div class="graphic-block-title">{{ params.title }}</div>{% endif -%}
      {%- if params.description %}<div class="graphic-block-description">{{ params.description }}</div>{% endif -%}
      {%- if params.notes %}<div class="graphic-block-notes">{{ params.notes }}</div>{% endif -%}
    </figcaption>
  {%- endif -%}
  <div class="graphic-block-content">
    {%- if params.html -%}
      {{ params.html | safe }}
    {%- elif params.text -%}
      {{ params.text }}
    {%- elif caller -%}
      {{ caller() }}
    {%- endif -%}
  </div>
</figure>
{%- endmacro -%}
