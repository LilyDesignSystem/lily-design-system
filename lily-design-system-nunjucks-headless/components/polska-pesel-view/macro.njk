{#
  PolskaPeselView macro — a read-only display of Poland's
    PESEL.

  HTML tag: <span>
  CSS class: polska-pesel-view

  Params:
    value, label, id, classes, attributes.

  Usage:
    {% from "components/polska-pesel-view/macro.njk" import polskaPeselView %}
    {{ polskaPeselView({ value: "sample", label: "PESEL" }) }}
#}
{%- macro polskaPeselView(params) -%}
<span
  class="polska-pesel-view{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>{{ params.value | default("") }}</span>
{%- endmacro -%}
