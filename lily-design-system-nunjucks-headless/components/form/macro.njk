{#
  Form macro — a form element for collecting and submitting user data.

  HTML tag: <form>
  CSS class: form
  Accessibility: params.label becomes the accessible name; use when
    there are multiple forms on the page.

  Params:
    action      string   Submission URL.
    method      string   HTTP method. Default "post".
    enctype     string   Encoding type (e.g. "multipart/form-data").
    novalidate  boolean  Disable browser built-in validation.
    label       string   Accessible name (aria-label).
    labelledBy  string   Id of an element naming the form.
    id          string   Element id.
    classes     string   Consumer-provided extra CSS classes.
    attributes  object   Extra HTML attributes as key/value pairs.

  Body content: fields, via caller().

  Usage:
    {% from "components/form/macro.njk" import form %}
    {% call form({ action: "/submit", method: "post" }) %}
      … fields …
    {% endcall %}
#}
{%- macro form(params) -%}
<form
  class="form{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.action %} action="{{ params.action }}"{% endif %}
  method="{{ params.method | default('post') }}"
  {%- if params.enctype %} enctype="{{ params.enctype }}"{% endif %}
  {%- if params.novalidate %} novalidate{% endif %}
  {%- if params.id %} id="{{ params.id }}"{% endif %}
  {%- if params.labelledBy %} aria-labelledby="{{ params.labelledBy }}"
  {%- elif params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if caller -%}{{ caller() }}{%- endif -%}
</form>
{%- endmacro -%}
