{#
  Sidebar macro — a side panel for navigation or supplementary content.

  HTML tag: <aside>
  CSS class: sidebar

  Params: label (default "Sidebar"), labelledBy, id, classes, attributes.
#}
{%- macro sidebar(params) -%}
{%- set p = params | default({}) -%}
<aside
  class="sidebar{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.labelledBy %} aria-labelledby="{{ p.labelledBy }}"{% else %} aria-label="{{ p.label | default('Sidebar') }}"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</aside>
{%- endmacro -%}
