{#
  TourListItem macro — one step in a tour guide list.

  HTML tag: <li>
  CSS class: tour-list-item
  Accessibility: when params.current is true, aria-current="step"
    marks this step as the one the user is on.

  Params:
    current     boolean  aria-current="step".
    text        string
    html        string
    id          string
    classes     string
    attributes  object
#}
{%- macro tourListItem(params) -%}
{%- set p = params | default({}) -%}
<li
  class="tour-list-item{% if p.classes %} {{ p.classes }}{% endif %}"
  {%- if p.current %} aria-current="step"{% endif %}
  {%- if p.id %} id="{{ p.id }}"{% endif %}
  {%- if p.attributes %}{% for k, v in p.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
  {%- if p.html -%}{{ p.html | safe }}
  {%- elif p.text -%}{{ p.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</li>
{%- endmacro -%}
