{# Question macro — a question is anything that asks for information, invites a response, tests knowledge, etc. #}
{%- macro question(params) -%}
<div
  class="question{% if params.classes %} {{ params.classes }}{% endif %}"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
>
  {%- if params.html -%}{{ params.html | safe }}
  {%- elif params.text -%}{{ params.text }}
  {%- elif caller -%}{{ caller() }}
  {%- endif -%}
</div>
{%- endmacro -%}
