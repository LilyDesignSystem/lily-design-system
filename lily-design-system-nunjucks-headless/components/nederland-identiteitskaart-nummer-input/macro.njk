{#
  NederlandIdentiteitskaartNummerInput macro — an input for entering Netherlands's
    Identiteitskaart Nummer.

  HTML tag: <input type="text">
  CSS class: nederland-identiteitskaart-nummer-input
  Format: 9 characters following the same format as the passport number; 'O' is disallowed but '0' is permitted
  Accessibility: autocomplete="off", spellcheck suppressed.

  Params:
    id, name, value, label, describedBy, errormessage, invalid,
    required, disabled, readonly, classes, attributes.

  Usage:
    {% from "components/nederland-identiteitskaart-nummer-input/macro.njk" import nederlandIdentiteitskaartNummerInput %}
    {{ nederlandIdentiteitskaartNummerInput({ id: "field-id", label: "Dutch National Identity Card Number" }) }}
#}
{%- macro nederlandIdentiteitskaartNummerInput(params) -%}
<input
  class="nederland-identiteitskaart-nummer-input{% if params.classes %} {{ params.classes }}{% endif %}"
  type="text"
  id="{{ params.id }}"
  name="{{ params.name | default(params.id) }}"
  value="{{ params.value | default('') }}"
  autocomplete="off"
  spellcheck="false"
  {%- if params.label %} aria-label="{{ params.label }}"{% endif %}
  {%- if params.describedBy %} aria-describedby="{{ params.describedBy }}"{% endif %}
  {%- if params.errormessage %} aria-errormessage="{{ params.errormessage }}"{% endif %}
  {%- if params.invalid %} aria-invalid="true"{% endif %}
  {%- if params.required %} required{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if params.readonly %} readonly{% endif %}
  {%- if params.attributes %}{% for k, v in params.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- endmacro -%}
