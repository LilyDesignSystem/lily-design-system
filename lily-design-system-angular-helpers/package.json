{
  "name": "lily-design-system-angular-helpers",
  "private": true,
  "type": "module",
  "description": "Lily Design System - Angular 20 helpers catalog (dev/test harness)",
  "scripts": {
    "build": "set -e; for d in lily-design-system-angular-*/; do [ -f \"$d/ng-package.json\" ] || continue; echo \"building ${d%/}\"; ng-packagr -p \"$d/ng-package.json\" -c \"$d/tsconfig.lib.json\"; done",
    "build:one": "ng-packagr",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "1.19.4",
    "@analogjs/vitest-angular": "1.19.4",
    "@angular/build": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.1.0",
    "jsdom": "^25.0.0",
    "ng-packagr": "^20.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zone.js": "^0.15.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "author": "joel@joelparkerhenderson.com",
  "license": "MIT"
}
