title: Measurement Instance Input
description: an input for entering a measurement value and unit
---

{% from "components/measurement-instance-input/macro.njk" import measurementInstanceInput %}

<h2>Weight</h2>
{{ measurementInstanceInput({
  id: "weight",
  name: "weight",
  value: 75,
  unit: "kg",
  units: [
    { value: "kg", text: "kg" },
    { value: "lb", text: "lb" }
  ],
  inputLabel: "Weight value",
  selectLabel: "Weight unit",
  min: 0,
  max: 500,
  step: 0.1
}) }}

<h2>Height</h2>
{{ measurementInstanceInput({
  id: "height",
  name: "height",
  value: 178,
  unit: "cm",
  units: [
    { value: "cm", text: "cm" },
    { value: "in", text: "in" }
  ],
  inputLabel: "Height value",
  selectLabel: "Height unit"
}) }}
