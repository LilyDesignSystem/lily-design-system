---
layout: layouts/component-demo.njk
title: Table
description: a table with rows and columns
nhsuk: https://service-manual.nhs.uk/design-system/components/table
---

{% from "components/table/macro.njk" import table %}
{% from "components/table-head/macro.njk" import tableHead %}
{% from "components/table-body/macro.njk" import tableBody %}
{% from "components/table-foot/macro.njk" import tableFoot %}
{% from "components/table-row/macro.njk" import tableRow %}
{% from "components/table-th/macro.njk" import tableTh %}
{% from "components/table-td/macro.njk" import tableTd %}

<h2>Default — appointment list</h2>
{% call table({ caption: "Your upcoming appointments" }) %}
  {% call tableHead() %}
    {% call tableRow() %}
      {{ tableTh({ text: "Date" }) }}
      {{ tableTh({ text: "Clinician" }) }}
      {{ tableTh({ text: "Type" }) }}
      {{ tableTh({ text: "Location" }) }}
    {% endcall %}
  {% endcall %}
  {% call tableBody() %}
    {% call tableRow() %}
      {{ tableTd({ text: "27 April 2026, 9:30am" }) }}
      {{ tableTd({ text: "Dr Patel" }) }}
      {{ tableTd({ text: "GP review" }) }}
      {{ tableTd({ text: "High Street Surgery" }) }}
    {% endcall %}
    {% call tableRow() %}
      {{ tableTd({ text: "4 May 2026, 2:15pm" }) }}
      {{ tableTd({ text: "Nurse Ahmed" }) }}
      {{ tableTd({ text: "Blood test" }) }}
      {{ tableTd({ text: "Main Clinic" }) }}
    {% endcall %}
    {% call tableRow() %}
      {{ tableTd({ text: "19 May 2026, 11:00am" }) }}
      {{ tableTd({ text: "Dr Smith" }) }}
      {{ tableTd({ text: "Follow-up" }) }}
      {{ tableTd({ text: "High Street Surgery" }) }}
    {% endcall %}
  {% endcall %}
{% endcall %}

<h2>Numeric columns — weather observations</h2>
{% call table({ caption: "Recent weather observations" }) %}
  {% call tableHead() %}
    {% call tableRow() %}
      {{ tableTh({ text: "Date" }) }}
      {{ tableTh({ text: "Temperature (°C)", classes: "table-col-numeric" }) }}
      {{ tableTh({ text: "Rainfall (mm)", classes: "table-col-numeric" }) }}
      {{ tableTh({ text: "Wind (km/h)", classes: "table-col-numeric" }) }}
    {% endcall %}
  {% endcall %}
  {% call tableBody() %}
    {% call tableRow() %}
      {{ tableTd({ text: "12 Apr" }) }}
      {{ tableTd({ text: "14", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "3.2", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "18", classes: "table-data-numeric" }) }}
    {% endcall %}
    {% call tableRow() %}
      {{ tableTd({ text: "19 Apr" }) }}
      {{ tableTd({ text: "16", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "0.0", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "12", classes: "table-data-numeric" }) }}
    {% endcall %}
    {% call tableRow() %}
      {{ tableTd({ text: "26 Apr" }) }}
      {{ tableTd({ text: "15", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "1.4", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "20", classes: "table-data-numeric" }) }}
    {% endcall %}
  {% endcall %}
  {% call tableFoot() %}
    {% call tableRow() %}
      {{ tableTh({ text: "Average", scope: "row" }) }}
      {{ tableTd({ text: "15", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "1.5", classes: "table-data-numeric" }) }}
      {{ tableTd({ text: "17", classes: "table-data-numeric" }) }}
    {% endcall %}
  {% endcall %}
{% endcall %}

<h2>Row headers</h2>
<p>Use <code>tableTd</code> with <code>scope="row"</code> to mark a
  row header, so screen readers announce it together with each data
  cell in the row.</p>
{% call table({ caption: "Dosage schedule" }) %}
  {% call tableHead() %}
    {% call tableRow() %}
      {{ tableTh({ text: "Day" }) }}
      {{ tableTh({ text: "Morning" }) }}
      {{ tableTh({ text: "Evening" }) }}
    {% endcall %}
  {% endcall %}
  {% call tableBody() %}
    {% call tableRow() %}
      {{ tableTh({ text: "Monday", scope: "row" }) }}
      {{ tableTd({ text: "1 tablet" }) }}
      {{ tableTd({ text: "1 tablet" }) }}
    {% endcall %}
    {% call tableRow() %}
      {{ tableTh({ text: "Tuesday", scope: "row" }) }}
      {{ tableTd({ text: "1 tablet" }) }}
      {{ tableTd({ text: "2 tablets" }) }}
    {% endcall %}
  {% endcall %}
{% endcall %}
