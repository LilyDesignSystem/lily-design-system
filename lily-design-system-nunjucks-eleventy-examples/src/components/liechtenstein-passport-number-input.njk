{% from "components/liechtenstein-passport-number-input/macro.njk" import liechtensteinPassportNumberInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/field/macro.njk" import field %}

<h2>Default</h2>
{% call field() %}
  {{ label({ for: "liechtenstein-passport-number-input-demo", text: "Liechtenstein Passport Number" }) }}
