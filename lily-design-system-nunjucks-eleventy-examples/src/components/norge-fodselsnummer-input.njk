{% from "components/norge-fodselsnummer-input/macro.njk" import norgeFodselsnummerInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/field/macro.njk" import field %}

<h2>Default</h2>
{% call field() %}
  {{ label({ for: "norge-fodselsnummer-input-demo", text: "Norwegian Birth Number" }) }}
