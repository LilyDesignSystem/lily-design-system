---
layout: layouts/component-demo.njk
title: Password Input
description: an input for entering a password with obscured text
---

{% from "components/password-input/macro.njk" import passwordInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/hint/macro.njk" import hint %}
{% from "components/field/macro.njk" import field %}

<h2>Sign in</h2>
{% call field() %}
  {{ label({ for: "current", text: "Password" }) }}
  {{ passwordInput({
    id: "current",
    autocomplete: "current-password",
    required: true
  }) }}
{% endcall %}

<h2>Set a new password</h2>
{% call field() %}
  {{ label({ for: "new", text: "Create a password" }) }}
  {{ hint({
    id: "new-hint",
    text: "Use at least 8 characters, including a number."
  }) }}
  {{ passwordInput({
    id: "new",
    autocomplete: "new-password",
    describedBy: "new-hint",
    minlength: 8,
    required: true
  }) }}
{% endcall %}

{% call field() %}
  {{ label({ for: "confirm", text: "Confirm your password" }) }}
  {{ passwordInput({
    id: "confirm",
    autocomplete: "new-password",
    required: true
  }) }}
{% endcall %}

<h2>Security note</h2>
<p>The macro deliberately does not render a <code>value</code>
  attribute for password inputs. Pair with
  <code>autocomplete="current-password"</code> for sign-in and
  <code>autocomplete="new-password"</code> for registration so
  browsers and password managers help correctly.</p>
