{% from "components/belgique-numero-de-registre-national-view/macro.njk" import belgiqueNumeroDeRegistreNationalView %}

<h2>Default</h2>
<dl>
  <dt>National Register Number</dt>
  <dd>{{ belgiqueNumeroDeRegistreNationalView({ value: "sample-value", label: "National Register Number" }) }}</dd>
</dl>

<h2>Format</h2>
<p>11 digits where the first 6 are the date of birth (YYMMDD), the next 3 are an ordering number (uneven for men, even for women) and the last 2 a check digit.</p>

<h2>Reference</h2>
<p>See <a href="https://en.wikipedia.org/wiki/National_identification_number#Belgium">National Register Number</a>.</p>
