{% from "components/belgique-numero-de-registre-national-input/macro.njk" import belgiqueNumeroDeRegistreNationalInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/field/macro.njk" import field %}

<h2>Default</h2>
{% call field() %}
  {{ label({ for: "belgique-numero-de-registre-national-input-demo", text: "National Register Number" }) }}
  {{ belgiqueNumeroDeRegistreNationalInput({ id: "belgique-numero-de-registre-national-input-demo" }) }}
{% endcall %}

<h2>Format</h2>
<p>11 digits where the first 6 are the date of birth (YYMMDD), the next 3 are an ordering number (uneven for men, even for women) and the last 2 a check digit.</p>

<h2>Reference</h2>
<p>See <a href="https://en.wikipedia.org/wiki/National_identification_number#Belgium">National Register Number</a>.</p>
