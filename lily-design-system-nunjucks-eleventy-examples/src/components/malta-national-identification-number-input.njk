{% from "components/malta-national-identification-number-input/macro.njk" import maltaNationalIdentificationNumberInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/field/macro.njk" import field %}

<h2>Default</h2>
{% call field() %}
  {{ label({ for: "malta-national-identification-number-input-demo", text: "Malta National Identification Number" }) }}
  {{ maltaNationalIdentificationNumberInput({ id: "malta-national-identification-number-input-demo" }) }}
