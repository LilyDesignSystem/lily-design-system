{% from "components/vital-sign-blood-pressure-systolic-as-mmhg-view/macro.njk" import vitalSignBloodPressureSystolicAsMmhgView %}
{% from "components/vital-sign-blood-pressure-diastolic-as-mmhg-view/macro.njk" import vitalSignBloodPressureDiastolicAsMmhgView %}

<h2>Default</h2>
<p>{{ vitalSignBloodPressureDiastolicAsMmhgView({
  value: 76,
  label: "Diastolic BP"
}) }}</p>

<h2>Systolic / diastolic pair</h2>
<p>
  {{ vitalSignBloodPressureSystolicAsMmhgView({ value: 118, label: "Systolic" }) }}
  <strong>/</strong>
  {{ vitalSignBloodPressureDiastolicAsMmhgView({ value: 76, label: "Diastolic" }) }}
</p>
