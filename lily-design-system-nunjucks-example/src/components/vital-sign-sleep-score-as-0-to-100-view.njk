{% from "components/vital-sign-sleep-score-as-0-to-100-view/macro.njk" import vitalSignSleepScoreAs0To100View %}

<h2>Excellent</h2>
<p>{{ vitalSignSleepScoreAs0To100View({
  value: 92,
  label: "Sleep score (excellent)"
}) }}</p>

<h2>Good</h2>
<p>{{ vitalSignSleepScoreAs0To100View({
  value: 82,
  label: "Sleep score"
}) }}</p>

<h2>Poor</h2>
<p>{{ vitalSignSleepScoreAs0To100View({
  value: 45,
  label: "Sleep score (poor)",
  classes: "poor"
}) }}</p>
