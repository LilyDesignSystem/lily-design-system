---
layout: layouts/component-demo.njk
title: Vital Sign — Systolic BP Input
description: number input of systolic blood pressure in millimetres of mercury (mmHg)
---

{% from "components/vital-sign-blood-pressure-systolic-as-mmhg-input/macro.njk" import vitalSignBloodPressureSystolicAsMmhgInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/hint/macro.njk" import hint %}
{% from "components/field/macro.njk" import field %}

<h2>Default (50 – 250 mmHg)</h2>
{% call field() %}
  {{ label({ for: "sys", text: "Systolic blood pressure" }) }}
  {{ hint({
    id: "sys-hint",
    text: "In millimetres of mercury."
  }) }}
  {{ vitalSignBloodPressureSystolicAsMmhgInput({
    id: "sys",
    describedBy: "sys-hint"
  }) }}
{% endcall %}

<h2>Pre-filled</h2>
{% call field() %}
  {{ label({ for: "sys-2", text: "Recent measurement" }) }}
  {{ vitalSignBloodPressureSystolicAsMmhgInput({
    id: "sys-2",
    value: 118
  }) }}
{% endcall %}
