---
layout: layouts/component-demo.njk
title: Vital Sign — Heart Rate Input
description: number input of heart rate in beats per minute (BPM)
---

{% from "components/vital-sign-heart-rate-as-beats-per-minute-input/macro.njk" import vitalSignHeartRateAsBeatsPerMinuteInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/hint/macro.njk" import hint %}
{% from "components/field/macro.njk" import field %}

<h2>Default clinical range (30 – 250 bpm)</h2>
{% call field() %}
  {{ label({ for: "hr", text: "Heart rate" }) }}
  {{ hint({ id: "hr-hint", text: "In beats per minute." }) }}
  {{ vitalSignHeartRateAsBeatsPerMinuteInput({
    id: "hr",
    describedBy: "hr-hint"
  }) }}
{% endcall %}

<h2>Pre-filled</h2>
{% call field() %}
  {{ label({ for: "hr-2", text: "Resting heart rate" }) }}
  {{ vitalSignHeartRateAsBeatsPerMinuteInput({ id: "hr-2", value: 72 }) }}
{% endcall %}
