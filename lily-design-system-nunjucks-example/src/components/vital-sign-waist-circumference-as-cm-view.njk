---
layout: layouts/component-demo.njk
title: Vital Sign — Waist Circumference View
description: number display of waist circumference in centimetres
---

{% from "components/vital-sign-waist-circumference-as-cm-view/macro.njk" import vitalSignWaistCircumferenceAsCmView %}

<h2>Default</h2>
<p>{{ vitalSignWaistCircumferenceAsCmView({
  value: 84,
  label: "Waist"
}) }}</p>

<h2>Elevated (above threshold)</h2>
<p>{{ vitalSignWaistCircumferenceAsCmView({
  value: 102,
  label: "Waist (elevated)",
  classes: "elevated"
}) }}</p>
