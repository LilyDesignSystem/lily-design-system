---
layout: layouts/component-demo.njk
title: TextAreaInput
description: a multi-line text input area
nhsuk: https://service-manual.nhs.uk/design-system/components/text-area-input
---

{% from "components/text-area-input/macro.njk" import text-area-input %}
{% from "components/label/macro.njk" import label %}
{% from "components/hint/macro.njk" import hint %}
{% from "components/error-message/macro.njk" import errorMessage %}
{% from "components/field/macro.njk" import field %}

<h2>Default</h2>
{% call field() %}
  {{ label({ for: "feedback", text: "How did we do?" }) }}
  {{ text-area-input({ id: "feedback", rows: 6 }) }}
{% endcall %}

<h2>With hint and maxlength</h2>
{% call field() %}
  {{ label({ for: "symptoms", text: "Describe your symptoms" }) }}
  {{ hint({
    id: "symptoms-hint",
    text: "Up to 1,000 characters."
  }) }}
  {{ text-area-input({
    id: "symptoms",
    rows: 8,
    maxlength: 1000,
    describedBy: "symptoms-hint"
  }) }}
{% endcall %}

<h2>Invalid</h2>
{% call field({ error: "Describe the problem" }) %}
  {{ label({ for: "issue", text: "Describe the problem" }) }}
  {{ errorMessage({ id: "issue-error", text: "Describe the problem" }) }}
  {{ text-area-input({
    id: "issue",
    errormessage: "issue-error",
    invalid: true,
    rows: 5
  }) }}
{% endcall %}
