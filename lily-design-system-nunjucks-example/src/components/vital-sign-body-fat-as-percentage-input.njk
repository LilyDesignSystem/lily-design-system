{% from "components/vital-sign-body-fat-as-percentage-input/macro.njk" import vitalSignBodyFatAsPercentageInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/hint/macro.njk" import hint %}
{% from "components/field/macro.njk" import field %}

<h2>Default (2 – 80 %, step 0.1)</h2>
{% call field() %}
  {{ label({ for: "bf", text: "Body fat percentage" }) }}
  {{ hint({
    id: "bf-hint",
    text: "To one decimal place."
  }) }}
  {{ vitalSignBodyFatAsPercentageInput({
    id: "bf",
    describedBy: "bf-hint"
  }) }}
{% endcall %}
