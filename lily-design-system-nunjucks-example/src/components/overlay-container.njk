---
layout: layouts/component-demo.njk
title: Overlay Container
description: a full-viewport overlay backdrop for modals and sheets
---

{% from "components/overlay-container/macro.njk" import overlayContainer %}

<h2>Closed (hidden)</h2>
{% call overlayContainer({ open: false, label: "Closed overlay" }) %}
  <div style="background: var(--nhsuk-white); padding: 1rem; max-width: 24rem; margin: 4rem auto;">
    Modal content (hidden).
  </div>
{% endcall %}

<h2>Open</h2>
<p>Toggle on the demo page to see open state.</p>
{% call overlayContainer({ open: true, label: "Open overlay" }) %}
  <div style="background: var(--nhsuk-white); padding: 1rem; max-width: 24rem; margin: 4rem auto; border: 1px solid #ccc;">
    Modal content visible inside the overlay.
  </div>
{% endcall %}
