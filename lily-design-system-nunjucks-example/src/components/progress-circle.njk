---
layout: layouts/component-demo.njk
title: Progress Circle
description: a circular progress indicator
---

{% from "components/progress-circle/macro.njk" import progressCircle %}

<h2>Determinate</h2>
<div style="display: flex; gap: var(--nhsuk-spacing-4); align-items: center;">
  {{ progressCircle({ value: 25, label: "25% complete" }) }}
  {{ progressCircle({ value: 50, label: "50% complete" }) }}
  {{ progressCircle({ value: 75, label: "75% complete" }) }}
  {{ progressCircle({ value: 100, label: "100% complete" }) }}
</div>

<h2>Custom range</h2>
<p>Step 3 of 5:</p>
{{ progressCircle({ value: 3, min: 0, max: 5, label: "Step 3 of 5" }) }}

<h2>Indeterminate</h2>
<p>Omit <code>value</code> and the circle animates a continuous
  spin.</p>
{{ progressCircle({ label: "Loading" }) }}
