{% from "components/vital-sign-respiratory-rate-as-breaths-per-minute-input/macro.njk" import vitalSignRespiratoryRateAsBreathsPerMinuteInput %}
{% from "components/label/macro.njk" import label %}
{% from "components/hint/macro.njk" import hint %}
{% from "components/field/macro.njk" import field %}

<h2>Default (4 – 60 breaths/min)</h2>
{% call field() %}
  {{ label({ for: "rr", text: "Respiratory rate" }) }}
  {{ hint({
    id: "rr-hint",
    text: "Counted over 60 seconds."
  }) }}
  {{ vitalSignRespiratoryRateAsBreathsPerMinuteInput({
    id: "rr",
    describedBy: "rr-hint"
  }) }}
{% endcall %}
