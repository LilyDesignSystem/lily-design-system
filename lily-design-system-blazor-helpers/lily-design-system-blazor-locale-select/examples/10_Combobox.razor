@*
    10. Combobox with native <datalist> type-ahead.

    For long locale lists (50+) where the default <select> is too
    tedious to scroll. Uses an <input list> +
    <datalist> for native, accessible type-ahead. The select
    validates the typed value against the supported set before
    applying.

    Outcome: type "Fr" — the combobox shows "Français", "Français
    (Canada)", "Frisian", etc. Pick one and the select applies.

    Browser support note: native <datalist> is widely supported but
    iOS Safari's UX is limited. For a fully APG-compliant combobox,
    swap in Lily's headless Combobox primitive or a Blazor combobox
    library (FluentUI, MudBlazor).
*@

@page "/examples/locale-select/combobox"
@rendermode InteractiveServer
@using LilyDesignSystem.Blazor.Helpers

<LocaleSelect
    Label="Language"
    Locales="@allLocales"
    @bind-Value="locale"
    StorageKey="combobox-locale">
    <ChildContent Context="ctx">
        <input type="text"
               list="locale-options"
               placeholder="Start typing a language…"
               aria-label="Language"
               value="@(inputValue.Length > 0 ? inputValue : ctx.LabelFor(ctx.Value))"
               @oninput="OnInput"
               @onchange="@(async e => await OnSubmit(e, ctx))" />
        <datalist id="locale-options">
            @foreach (var l in ctx.Locales)
            {
                <option value="@ctx.LabelFor(l)" lang="@ctx.TagFor(l)">@l</option>
            }
        </datalist>
    </ChildContent>
</LocaleSelect>

<p>
    Selected locale: <code>@locale</code>
    (@Locales.LocaleName(locale))
</p>

@code {
    private string locale = "en";
    private string inputValue = "";

    private readonly string[] allLocales =
        Locales.DefaultLocaleLabels.Keys.ToArray();

    private void OnInput(ChangeEventArgs e)
    {
        inputValue = e.Value?.ToString() ?? "";
    }

    private async Task OnSubmit(ChangeEventArgs e, LocaleSelectContext ctx)
    {
        var typed = e.Value?.ToString() ?? "";
        var match = ctx.Locales.FirstOrDefault(l =>
            string.Equals(ctx.LabelFor(l), typed, StringComparison.OrdinalIgnoreCase));
        if (match is not null)
        {
            await ctx.SetLocale(match);
            inputValue = "";
        }
    }
}
