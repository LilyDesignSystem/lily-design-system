@namespace LilyDesignSystem.Blazor.Helpers

@*
    LocaleSelect — Blazor helper component.
    Single source of truth: spec/index.md (§1–§9).

    Renders an accessible native <select> of available locales. On every
    selection it sets `lang` (BCP 47 hyphen form) and `dir`
    (`ltr`/`rtl`) on the document root, optionally persists to
    `localStorage`, and invokes OnChange / ValueChanged with the
    original consumer-form code.

    All DOM writes happen through IJSRuntime inside OnAfterRenderAsync,
    so the component is SSR / prerender safe.
*@

<select class="@RootClass"
        aria-label="@Label"
        name="@Name"
        @ref="_selectElement"
        @onchange="OnSelectAsync"
        @attributes="AdditionalAttributes">
    @*
        The placeholder option is component-owned and is always the selected
        option, so the closed <select> reads `Placeholder ?? Label` rather
        than the active locale name. It is the first child in BOTH the
        default and the custom-ChildContent code paths. It is not a locale,
        so it carries no `lang`. The real selection lives in `Value`, not in
        the <select>'s own DOM value.
    *@
    <option class="locale-select-option locale-select-placeholder"
            value=""
            selected>@PlaceholderText</option>
    @if (ChildContent is not null)
    {
        @ChildContent(BuildContext())
    }
    else
    {
        @foreach (var locale in Locales)
        {
            <option class="locale-select-option"
                    value="@locale"
                    lang="@TagFor(locale)">@LabelFor(locale)</option>
        }
    }
</select>
