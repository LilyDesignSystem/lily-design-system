@*
    Example 2 — Two-way binding + change handler.

    `@bind-Value` exposes the active slug to surrounding code. `OnChange`
    fires after each apply, which is the right hook for analytics, telling
    the server, or notifying a sibling component.
*@

@page "/examples/theme-select/two-way-binding"
@rendermode InteractiveServer
@using LilyDesignSystem.Blazor.Helpers

<ThemeSelect
    Label="Theme"
    ThemesUrl="/assets/themes/"
    Themes="@(new[] { "light", "dark", "abyss" })"
    @bind-Value="theme"
    OnChange="OnThemeChange" />

<p>Current theme: <strong>@(string.IsNullOrEmpty(theme) ? "(resolving…)" : theme)</strong></p>

@code {
    private string theme = "";

    private void OnThemeChange(string slug)
    {
        // e.g. analytics or server sync
        Console.WriteLine($"theme changed: {slug}");
    }
}
