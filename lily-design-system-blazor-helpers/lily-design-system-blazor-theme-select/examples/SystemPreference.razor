@*
    Example 8 — Follow the OS `prefers-color-scheme`.

    The select has no opinion about light vs. dark; it just owns the
    selection contract. To make the first-visit default follow the OS,
    resolve the media query in OnAfterRenderAsync and pass it as
    DefaultValue. The user can still pick anything they like afterwards,
    and the choice persists via StorageKey.
*@

@page "/examples/theme-select/system-preference"
@rendermode InteractiveServer
@using LilyDesignSystem.Blazor.Helpers
@inject IJSRuntime JS

<ThemeSelect
    Label="Theme"
    ThemesUrl="/assets/themes/"
    Themes="@(new[] { "light", "dark" })"
    DefaultValue="@osPreference"
    StorageKey="my-app:theme" />

@code {
    private string? osPreference;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var dark = await JS.InvokeAsync<bool>(
                "eval",
                "window.matchMedia?.('(prefers-color-scheme: dark)').matches === true");
            osPreference = dark ? "dark" : "light";
            StateHasChanged();
        }
        catch
        {
            // ignore
        }
    }
}
