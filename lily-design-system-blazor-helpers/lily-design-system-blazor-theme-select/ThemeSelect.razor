@namespace LilyDesignSystem.Blazor.Helpers

@*
    ThemeSelect — Blazor helper component.
    Single source of truth: spec/index.md (§1–§9).

    Renders an accessible native <select> of available themes. On every
    selection it (1) swaps the href of a managed <link> in <head>,
    (2) sets data-theme on <html>, (3) optionally persists to
    localStorage, and (4) invokes OnChange / ValueChanged.

    All DOM writes happen through IJSRuntime inside OnAfterRenderAsync,
    so the component is SSR / prerender safe.
*@

<select class="@RootClass"
        aria-label="@Label"
        name="@Name"
        @ref="_selectElement"
        @onchange="OnSelectAsync"
        @attributes="AdditionalAttributes">
    @*
        The placeholder option is component-owned and is always the selected
        option, so the closed <select> reads `Placeholder ?? Label` rather
        than the active theme name. It is the first child in BOTH the
        default and the custom-ChildContent code paths. The real selection
        lives in `Value`, not in the <select>'s own DOM value.
    *@
    <option class="theme-select-option theme-select-placeholder"
            value=""
            selected>@PlaceholderText</option>
    @if (ChildContent is not null)
    {
        @ChildContent(BuildContext())
    }
    else
    {
        @foreach (var theme in Themes)
        {
            <option class="theme-select-option"
                    value="@theme">@LabelFor(theme)</option>
        }
    }
</select>
