@namespace LilyDesignSystem.Blazor.Helpers

@*
    LocaleChooser — Blazor helper component.
    Single source of truth: spec/index.md (§1–§9).

    Renders an icon button that opens a dropdown listbox of available
    locales (WAI-ARIA APG listbox pattern). On every selection it sets
    `lang` (BCP 47 hyphen form) and `dir` (`ltr`/`rtl`) on the document
    root, optionally persists to `localStorage`, and invokes OnChange /
    ValueChanged with the original consumer-form code.

    All DOM writes happen through IJSRuntime inside OnAfterRenderAsync,
    so the component is SSR / prerender safe.
*@

<div class="@RootClass"
     @onfocusout="OnRootFocusOutAsync"
     @attributes="AdditionalAttributes">

    @* Preserves form participation; the listbox itself is not a form control. *@
    <input type="hidden" name="@Name" value="@Value" />

    <button type="button"
            class="locale-chooser-button"
            @ref="_buttonElement"
            aria-label="@Label"
            aria-haspopup="listbox"
            aria-expanded="@(_open ? "true" : "false")"
            aria-controls="@ListId"
            @onclick="OnButtonClickAsync"
            @onkeydown="OnButtonKeyDownAsync">
        @if (ChildContent is not null)
        {
            @ChildContent(BuildContext())
        }
        else
        {
            @* The glyph is decorative: the accessible name is the button's
               aria-label, never the character itself. *@
            <span class="locale-chooser-icon" aria-hidden="true">@GlobeWithMeridians</span>
        }
    </button>

    @* mousedown default is suppressed so clicking an option does not blur
       the listbox before the click handler runs. *@
    <ul class="locale-chooser-list"
        id="@ListId"
        role="listbox"
        aria-label="@Label"
        aria-activedescendant="@ActiveDescendantId"
        tabindex="-1"
        hidden="@(!_open)"
        @ref="_listElement"
        @onkeydown="OnListKeyDownAsync"
        @onmousedown:preventDefault="true">
        @for (var i = 0; i < Locales.Count; i++)
        {
            var index = i;
            var locale = Locales[index];
            @* Each option carries its own `lang` — WCAG 3.1.2 Language of
               Parts — so "Français" is pronounced with a French voice. *@
            <li class="locale-chooser-option"
                id="@OptionId(index)"
                role="option"
                aria-selected="@(locale == Value ? "true" : "false")"
                data-active="@(index == _activeIndex ? "" : null)"
                lang="@TagFor(locale)"
                @onclick="() => ChooseAsync(index)">@LabelFor(locale)</li>
        }
    </ul>
</div>
