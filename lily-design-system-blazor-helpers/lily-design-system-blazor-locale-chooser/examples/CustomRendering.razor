@*
    Custom rendering — custom button glyph via ChildContent.

    ChildContent replaces the glyph INSIDE the button; it does not render
    the options. The listbox is always the component's own APG listbox, so
    a custom native <select> is no longer possible here — the control is an
    icon button plus a dropdown listbox, not a <select>.

    The fragment receives a LocaleChooserContext with exactly three members:
    Value (active code), Open (is the listbox open?), and LabelFor (code →
    display label). Use it when you want your own artwork or a state-aware
    face instead of the default 🌐.

    Whatever you render must stay aria-hidden="true": the button is
    icon-only and its entire accessible name is the Label parameter.

    Outcome: the same lang/dir/storage lifecycle as the default rendering,
    with an inline SVG globe and a caret that flips as the listbox opens.
*@

@page "/examples/locale-chooser/select"
@rendermode InteractiveServer
@using LilyDesignSystem.Blazor.Helpers

<LocaleChooser
    Label="Language"
    Locales="@(new[]
    {
        "en", "en_US", "en_GB",
        "fr", "fr_CA",
        "es", "es_419",
        "de",
        "zh_Hans", "zh_Hant",
        "ja", "ko",
        "ar", "he", "fa", "ur",
        "hi", "bn",
        "pt", "pt_BR",
        "ru", "tr", "vi",
    })"
    @bind-Value="locale"
    StorageKey="app-locale"
    DetectFromNavigator="true">
    <ChildContent Context="ctx">
        <span class="locale-chooser-icon" aria-hidden="true">
            @* Decorative artwork replacing the default 🌐. An inline SVG
               sidesteps the emoji-font coverage caveat in docs/accessibility.md. *@
            <svg focusable="false" width="16" height="16" viewBox="0 0 16 16">
                <circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5" />
                <ellipse cx="8" cy="8" rx="3" ry="7" fill="none" stroke="currentColor" stroke-width="1.5" />
                <line x1="1" y1="8" x2="15" y2="8" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="locale-chooser-face-caret">@(ctx.Open ? "▴" : "▾")</span>
        </span>
    </ChildContent>
</LocaleChooser>

<p class="locale-chooser-status" aria-live="polite">
    Selected locale: <code>@locale</code>
    <span lang="@Locales.Bcp47LocaleTag(locale)">@Locales.LocaleName(locale)</span>
</p>

@code {
    private string locale = "en";
}
