@*
    With ResX — wiring per-component .resx files.

    Instead of a shared SharedResources.resx, each component owns its
    own resource files. Blazor's IStringLocalizer<TComponent> resolves
    to e.g. WithResX.fr.resx automatically.

    Filesystem layout:
        examples/WithResX.razor
        examples/WithResX.resx       (English defaults)
        examples/WithResX.fr.resx
        examples/WithResX.ar.resx

    Outcome: choosing a locale flips CultureInfo and the strings
    re-resolve against this component's own resource files.
*@

@page "/examples/locale-chooser/with-resx"
@rendermode InteractiveServer
@using System.Globalization
@using LilyDesignSystem.Blazor.Helpers
@using Microsoft.Extensions.Localization

@inject IStringLocalizer<WithResXDemo> Loc

<LocaleChooser
    Label="@Loc["language"]"
    Locales="@(new[] { "en", "fr", "ar" })"
    @bind-Value="locale"
    OnChange="OnLocaleChange" />

<h1>@Loc["title"]</h1>
<p>@Loc["paragraph"]</p>

@code {
    private string locale = "en";

    private void OnLocaleChange(string code)
    {
        var ci = new CultureInfo(Locales.Bcp47LocaleTag(code));
        CultureInfo.DefaultThreadCurrentCulture = ci;
        CultureInfo.DefaultThreadCurrentUICulture = ci;
        StateHasChanged();
    }
}

@code {
    @* In a real project this lives in a separate .cs file. *@
    public sealed class WithResXDemo { }
}
