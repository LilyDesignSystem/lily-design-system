@*
    Example 3 — localStorage persistence.

    Pass `StorageKey` to make the picker remember the user's choice across
    reloads. On a fresh interactive mount the picker reads the stored slug
    and re-applies it before the user interacts. Quota / private-mode
    errors are silently swallowed.
*@

@page "/examples/theme-picker/persistence"
@rendermode InteractiveServer
@using LilyDesignSystem.Blazor.Helpers

<ThemePicker
    Label="Theme"
    ThemesUrl="/assets/themes/"
    Themes="@(new[] { "light", "dark", "abyss" })"
    StorageKey="my-app:theme" />
