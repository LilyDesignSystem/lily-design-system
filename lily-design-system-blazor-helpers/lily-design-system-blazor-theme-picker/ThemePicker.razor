@namespace LilyDesignSystem.Blazor.Helpers

@*
    ThemePicker — Blazor helper component.
    Single source of truth: spec.md (§1–§9).

    Renders an accessible radio group of available themes. On every
    selection it (1) swaps the href of a managed <link> in <head>,
    (2) sets data-theme on <html>, (3) optionally persists to
    localStorage, and (4) invokes OnChange / ValueChanged.

    All DOM writes happen through IJSRuntime inside OnAfterRenderAsync,
    so the component is SSR / prerender safe.
*@

<fieldset class="@RootClass"
          role="radiogroup"
          aria-label="@Label"
          @attributes="AdditionalAttributes">
    @if (ChildContent is not null)
    {
        @ChildContent(BuildContext())
    }
    else
    {
        @foreach (var theme in Themes)
        {
            <label class="theme-picker-option">
                <input type="radio"
                       name="@Name"
                       value="@theme"
                       checked="@(Value == theme)"
                       @onchange="@(_ => OnInputChangeAsync(theme))" />
                <span class="theme-picker-option-label">@LabelFor(theme)</span>
            </label>
        }
    }
</fieldset>
