{# The canonical function-href API, recovered on the client.

   The macro needs resolved strings, but the CLIENT can take functions —
   which is what you want when the page URL is not known at render time:
   client-side routing, a cached fragment reused across URLs, or a page
   served under several paths.

   The client matches targets to anchors by data-target-id and rewrites
   each href from the live URL, at init and again on every open.
   Anchors you do not name keep their server-rendered href, so mixing
   the two is fine.
#}
{% from "share-button.njk" import shareButton %}

{{ shareButton({
    label: "Share this page",
    targets: [
        {
            id: "mastodon",
            label: "Mastodon",
            href: "https://mastodon.example/share?url=PLACEHOLDER"
        },
        {
            id: "docs",
            label: "Our docs",
            href: "https://docs.example/permalink"
        }
    ],
    copyLabel: "Copy link",
    copiedLabel: "Link copied",
    copyFailedLabel: "Could not copy — select the address bar and copy from there"
}) }}

<script type="module">
    import { autoInit } from "/js/share-button.client.js";

    autoInit({
        // No `url` here either: it falls back to location.href, resolved
        // lazily at share time, so it tracks client-side navigation.
        title: document.title,
        targets: [
            {
                id: "mastodon",
                href: (url, title) =>
                    `https://mastodon.example/share?url=${encodeURIComponent(url)}` +
                    `&text=${encodeURIComponent(title)}`,
            },
            // "docs" is absent, so its server-rendered permalink stands.
        ],
    });
</script>
