{#
  Example 02 — Native <select> with pretty labels.

  The default localeSelect macro already renders a native <select>,
  so this example just feeds it a longer locale list plus a
  `localeLabels` map for human-readable option text. Best for >~12
  locales or when the design system uses dropdowns for setting
  controls.

  Outcome: a single <select> populated with one <option> per locale,
  each carrying its own BCP 47 `lang`. The client.js drives
  lang/dir/onChange off the <select>'s "change" event.
#}
{% from "../locale-select.njk" import localeSelect %}

{% set LOCALES = ["en", "en_US", "en_GB", "fr", "fr_CA", "es", "es_419", "de", "zh_Hans", "zh_Hant", "ja", "ko", "ar", "he", "fa", "ur", "hi", "bn", "pt", "pt_BR", "ru", "tr", "vi"] %}
{% set LABELS = {
    en: "English", en_US: "English (US)", en_GB: "English (UK)",
    fr: "Français", fr_CA: "Français (Canada)",
    es: "Español", es_419: "Español (Latinoamérica)",
    de: "Deutsch", zh_Hans: "简体中文", zh_Hant: "繁體中文",
    ja: "日本語", ko: "한국어",
    ar: "العربية", he: "עברית", fa: "فارسی", ur: "اردو",
    hi: "हिन्दी", bn: "বাংলা",
    pt: "Português", pt_BR: "Português (Brasil)",
    ru: "Русский", tr: "Türkçe", vi: "Tiếng Việt"
} %}

{{ localeSelect({
    label: "Language",
    locales: LOCALES,
    localeLabels: LABELS,
    value: "en",
    storageKey: "app-locale",
    detectFromNavigator: true
}) }}

<p>Selected locale: <code id="current-locale">en</code></p>

<script type="module">
    import { autoInit } from "../locale-select.client.js";
    autoInit({
        onChange(code) {
            document.getElementById("current-locale").textContent = code;
        },
    });
</script>
