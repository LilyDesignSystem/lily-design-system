{#
  Example 10 — A 57-locale list, and the built-in typeahead.

  This is an APG listbox, not a combobox: there is no text input to
  filter on, so the typeahead moves the active option rather than
  narrowing the list.

  For long locale lists, the client's typeahead is the fast path:
  with the listbox open, printable characters accumulate into a
  buffer and move the active option to the first label with that
  prefix. Typing "fran" jumps straight to "Français". The buffer
  resets 500 ms after the last keystroke, so a pause starts a fresh
  search. Modifier chords (Ctrl / Meta / Alt) are excluded, so
  browser and OS shortcuts still work.

  The typeahead matches on the OPTION LABEL, not the locale code, so
  a good `localeLabels` map is what makes a long list usable.

  Outcome: open the listbox, type "fran" — the active option lands on
  "Français". Enter or Space commits it and applies lang/dir.

  Scale note: the listbox renders all 57 options in the DOM. If you
  need filtering (typing narrows the list rather than jumping within
  it), that is a combobox, which this helper does not implement —
  hand-write conforming markup with the same
  `data-lily-locale-select-*` hooks, or reach for Lily's upstream
  `Combobox` headless primitive.
#}
{% from "../locale-select.njk" import localeSelect %}

{% set LOCALES = [
    "en", "en-US", "en-GB", "en-AU", "en-CA", "en-IE", "en-IN", "en-NZ", "en-ZA",
    "fr", "fr-CA", "fr-BE", "fr-CH",
    "es", "es-419", "es-MX", "es-AR", "es-CL", "es-CO",
    "de", "de-AT", "de-CH",
    "pt", "pt-BR", "pt-PT",
    "it", "nl", "pl", "ru", "tr", "vi", "uk", "cs", "hu", "sv", "da", "fi", "no", "el", "ro", "bg",
    "zh-Hans", "zh-Hant", "ja", "ko",
    "ar", "he", "fa", "ur",
    "hi", "bn", "ta", "te", "ml", "th", "id", "ms"
] %}

{% set LABELS = {
    "en": "English", "en-US": "English (US)", "en-GB": "English (UK)",
    "en-AU": "English (Australia)", "en-CA": "English (Canada)",
    "en-IE": "English (Ireland)", "en-IN": "English (India)",
    "en-NZ": "English (New Zealand)", "en-ZA": "English (South Africa)",
    "fr": "Français", "fr-CA": "Français (Canada)",
    "fr-BE": "Français (Belgique)", "fr-CH": "Français (Suisse)",
    "es": "Español", "es-419": "Español (Latinoamérica)",
    "es-MX": "Español (México)", "es-AR": "Español (Argentina)",
    "es-CL": "Español (Chile)", "es-CO": "Español (Colombia)",
    "de": "Deutsch", "de-AT": "Deutsch (Österreich)",
    "de-CH": "Deutsch (Schweiz)",
    "pt": "Português", "pt-BR": "Português (Brasil)",
    "pt-PT": "Português (Portugal)",
    "it": "Italiano", "nl": "Nederlands", "pl": "Polski",
    "ru": "Русский", "tr": "Türkçe", "vi": "Tiếng Việt",
    "uk": "Українська", "cs": "Čeština", "hu": "Magyar",
    "sv": "Svenska", "da": "Dansk", "fi": "Suomi",
    "no": "Norsk", "el": "Ελληνικά", "ro": "Română", "bg": "Български",
    "zh-Hans": "简体中文", "zh-Hant": "繁體中文",
    "ja": "日本語", "ko": "한국어",
    "ar": "العربية", "he": "עברית", "fa": "فارسی", "ur": "اردو",
    "hi": "हिन्दी", "bn": "বাংলা", "ta": "தமிழ்", "te": "తెలుగు",
    "ml": "മലയാളം", "th": "ไทย", "id": "Bahasa Indonesia",
    "ms": "Bahasa Melayu"
} %}

{{ localeSelect({
    label: "Language",
    locales: LOCALES,
    localeLabels: LABELS,
    value: "en",
    storageKey: "long-list-locale",
    id: "long-list-locale"
}) }}

{#
  The closed trigger shows only a glyph, so the active locale goes in
  a status region. With 57 options this matters more, not less: a
  screen-reader user needs to hear the result of a typeahead commit.
#}
<p class="locale-select-status" aria-live="polite"></p>
<p>Selected locale: <code id="current-locale">en</code></p>

<script type="module">
    import { autoInit, localeName } from "../locale-select.client.js";

    const status = document.querySelector(".locale-select-status");

    autoInit({
        onChange(code) {
            document.getElementById("current-locale").textContent = code;
            status.textContent = `Active language: ${localeName(code)}`;
        },
    });
</script>
