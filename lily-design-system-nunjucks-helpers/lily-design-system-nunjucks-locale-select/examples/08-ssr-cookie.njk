{#
  Example 08 — Cookie-resolved value, server-rendered.

  The select accepts `opts.value` so the matching option renders
  `selected` server-side. Combine with a cookie-resolved value in
  the template context and you get a flicker-free render: the
  `<html lang dir>` arrives with the right values from byte zero,
  and the select shows the right option selected from the first
  paint.

  This example assumes the consumer's host (Express, Eleventy
  edge function, Cloudflare Workers) has already resolved the
  cookie and put the locale into the template context as
  `locale`, `lang`, and `dir`. See docs/ssr.md for the full
  Express + cookie-parser recipe and the Eleventy + edge-function
  recipe.

  Outcome: the page first paints in the cookie-resolved locale.
  Picking a different locale writes the cookie back, then
  reloads so the next request paints in the new locale.
#}
{% from "../locale-select.njk" import localeSelect %}

{# Demo defaults — in production these come from the host. #}
{% set locale = locale or "fr" %}
{% set lang = lang or (locale | replace("_", "-")) %}
{% set dir = dir or "ltr" %}
{% set supported = supported or ["en", "fr", "ar"] %}

<!doctype html>
<html lang="{{ lang }}" dir="{{ dir }}">
    <head>
        <meta charset="utf-8" />
        <title>SSR cookie demo</title>
    </head>
    <body>
        {{ localeSelect({
            label: "Language",
            locales: supported,
            value: locale,
            localeLabels: {
                en: "English", fr: "Français", ar: "العربية"
            }
        }) }}

        <main>
            <h1>This page paints with <code>{{ lang }}</code> from byte zero.</h1>
            <p>Cookie-resolved server side. No flash.</p>
        </main>

        <script type="module">
            import { autoInit } from "../locale-select.client.js";
            autoInit({
                onChange(code) {
                    // Write a 1-year cookie and reload so the server
                    // renders the next request with the new locale.
                    document.cookie =
                        `locale=${code}; path=/; max-age=31536000; SameSite=Lax`;
                    location.reload();
                },
            });
        </script>
    </body>
</html>

{#
    Companion server-side wiring (Express + cookie-parser):

    import express from "express";
    import nunjucks from "nunjucks";
    import cookieParser from "cookie-parser";
    import {
        bcp47LocaleTag, isRtlLocale,
    } from "./locale-select.client.js";

    const SUPPORTED = ["en", "fr", "ar"];
    const app = express();
    app.use(cookieParser());
    nunjucks.configure("views", { express: app, autoescape: true });

    app.get("/", (req, res) => {
        const cookie = req.cookies.locale;
        const locale = (cookie && SUPPORTED.includes(cookie)) ? cookie : "en";
        res.render("08-ssr-cookie.njk", {
            locale,
            supported: SUPPORTED,
            lang: bcp47LocaleTag(locale),
            dir: isRtlLocale(locale) ? "rtl" : "ltr",
        });
    });

    See docs/ssr.md for the matching Eleventy + edge function recipe.
#}
