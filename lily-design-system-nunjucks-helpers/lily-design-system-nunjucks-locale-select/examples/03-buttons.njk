{#
  Example 03 — Toggle-button group via the `{% call %}` block.

  A button group renders the locales inline with `aria-pressed` to
  indicate the active locale. Use it when you want a more prominent,
  tap-friendly affordance than the default <select> on small screens,
  or when you want to render flags / abbreviations.

  Outcome: a horizontal <ul> of <button>s, each with `aria-pressed`
  reflecting the current locale. Click handlers call
  `ctrl.setLocale(code)`, which writes lang/dir, persists if
  storageKey is set, and fires onChange.
#}
{% from "./localeSelectCustom.njk" import localeSelectCustom %}

{% set LOCALES = ["en", "fr", "es", "de", "ar", "he"] %}
{% set SHORT = {
    en: "EN", fr: "FR", es: "ES", de: "DE", ar: "ع", he: "ע"
} %}
{% set FULL = {
    en: "English", fr: "Français", es: "Español",
    de: "Deutsch", ar: "العربية", he: "עברית"
} %}

{% call localeSelectCustom({
    label: "Language",
    locales: LOCALES,
    value: "en"
}) %}
    <ul class="locale-select-list" role="list">
        {% for code in LOCALES %}
        <li>
            <button
                type="button"
                class="locale-select-button"
                data-locale="{{ code }}"
                aria-pressed="{{ 'true' if code == 'en' else 'false' }}"
                lang="{{ code | replace('_', '-') }}"
                title="{{ FULL[code] }}"
            >{{ SHORT[code] }}</button>
        </li>
        {% endfor %}
    </ul>
{% endcall %}

<p>Selected: <code id="current-locale">en</code></p>

<script type="module">
    import { initLocaleSelect } from "../locale-select.client.js";

    document
        .querySelectorAll("[data-lily-locale-select-root]")
        .forEach((root) => {
            const ctrl = initLocaleSelect(root, {
                onChange(code) {
                    document.getElementById("current-locale").textContent = code;
                    root.querySelectorAll(".locale-select-button")
                        .forEach((b) => {
                            b.setAttribute(
                                "aria-pressed",
                                String(b.dataset.locale === code),
                            );
                        });
                },
            });
            root.querySelectorAll(".locale-select-button")
                .forEach((b) => {
                    b.addEventListener("click", () => {
                        ctrl.setLocale(b.dataset.locale);
                    });
                });
        });
</script>
