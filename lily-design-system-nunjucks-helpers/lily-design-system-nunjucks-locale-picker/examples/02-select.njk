{#
  Example 02 — Native <select> via the `{% call %}` block.

  When the default radio-list markup isn't enough, take over the
  inside of the fieldset with a caller block. The outer
  <fieldset role="radiogroup"> is preserved so screen readers
  still announce the group; inside, we render a <select> instead
  of radios.

  Best for >~12 locales or when the design system uses dropdowns
  for setting controls.

  Note: the shipped locale-picker.njk does not currently inspect
  `caller`. To use this pattern, fork the macro into your project
  with the per-option body replaced by `{{ caller() if caller else "" }}`.
  See the sibling theme-picker's `examples/themePickerCustom.njk`
  for the same idea.

  Outcome: a single <select> populated with one <option> per locale,
  each carrying its own BCP 47 `lang`. The client.js still drives
  lang/dir/onChange via the hidden radios pattern below: we render
  a <select>, but also a parallel hidden radio for each option so
  the client.js's "change" listener fires.
#}
{% from "./localePickerCustom.njk" import localePickerCustom %}

{% set LOCALES = ["en", "en_US", "en_GB", "fr", "fr_CA", "es", "es_419", "de", "zh_Hans", "zh_Hant", "ja", "ko", "ar", "he", "fa", "ur", "hi", "bn", "pt", "pt_BR", "ru", "tr", "vi"] %}
{% set LABELS = {
    en: "English", en_US: "English (US)", en_GB: "English (UK)",
    fr: "Français", fr_CA: "Français (Canada)",
    es: "Español", es_419: "Español (Latinoamérica)",
    de: "Deutsch", zh_Hans: "简体中文", zh_Hant: "繁體中文",
    ja: "日本語", ko: "한국어",
    ar: "العربية", he: "עברית", fa: "فارسی", ur: "اردو",
    hi: "हिन्दी", bn: "বাংলা",
    pt: "Português", pt_BR: "Português (Brasil)",
    ru: "Русский", tr: "Türkçe", vi: "Tiếng Việt"
} %}

{% call localePickerCustom({
    label: "Language",
    locales: LOCALES,
    value: "en",
    storageKey: "app-locale",
    detectFromNavigator: true
}) %}
    <select class="locale-picker-select" aria-label="Language" name="locale">
        {% for code in LOCALES %}
        <option value="{{ code }}" lang="{{ code | replace('_', '-') }}">
            {{ LABELS[code] or code }}
        </option>
        {% endfor %}
    </select>
{% endcall %}

<p>Selected locale: <code id="current-locale">en</code></p>

<script type="module">
    import { initLocalePicker } from "../locale-picker.client.js";

    // The custom macro has no radios; we drive the client.js manually
    // via the select's "change" event.
    document
        .querySelectorAll("[data-lily-locale-picker-root]")
        .forEach((root) => {
            const ctrl = initLocalePicker(root, {
                onChange(code) {
                    document.getElementById("current-locale").textContent = code;
                    const sel = root.querySelector("select");
                    if (sel) sel.value = code;
                },
            });
            root.querySelector("select")?.addEventListener("change", (e) => {
                ctrl.setLocale(e.currentTarget.value);
            });
        });
</script>
