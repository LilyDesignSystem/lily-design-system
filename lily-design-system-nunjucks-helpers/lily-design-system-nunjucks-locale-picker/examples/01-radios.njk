{#
  Example 01 — Default radio group.

  The simplest possible mount. Each radio renders with its locale's
  pretty name (from the `localeLabels` opt; falls back to the bare
  code if not provided), wrapped in a `<label lang="…">` so screen
  readers pronounce each in the right language.

  Outcome: a <fieldset role="radiogroup"> with three radios. Picking
  one writes `<html lang="…" dir="…">` and fires `onChange`.
#}
{% from "../locale-picker.njk" import localePicker %}

{{ localePicker({
    label: "Choose your language",
    locales: ["en", "fr", "ar"],
    value: "en"
}) }}

<p>Selected locale: <code id="current-locale">en</code></p>

<script type="module">
    import { autoInit } from "../locale-picker.client.js";
    autoInit({
        onChange(code) {
            document.getElementById("current-locale").textContent = code;
        },
    });
</script>
