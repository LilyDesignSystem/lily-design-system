{#
  Example 05 — NHS UK-style language banner.

  Mirrors the NHS UK Design System's pattern of placing a language
  chooser in a top utility banner. The banner uses native button-
  group markup but with the `locale-picker` class hook so consumer
  CSS can target it without duplication.

  Each option is an endonym — the language's own name in its own
  script — which is the NHS pattern. Per-option `lang` on the
  <button> drives screen reader pronunciation.

  Outcome: a <header> banner with the picker rendered as a horizontal
  button list. Each entry shows the language in its own script.
#}
{% from "./localePickerCustom.njk" import localePickerCustom %}

{% set LOCALES = ["en", "cy", "gd", "ga", "fr", "pl", "ur", "bn", "zh_Hant"] %}
{% set NATIVE = {
    en: "English",
    cy: "Cymraeg",
    gd: "Gàidhlig",
    ga: "Gaeilge",
    fr: "Français",
    pl: "Polski",
    ur: "اردو",
    bn: "বাংলা",
    zh_Hant: "繁體中文"
} %}

<header class="utility-banner" aria-label="Site utilities">
    <span class="brand">NHS</span>

    {% call localePickerCustom({
        label: "Language",
        locales: LOCALES,
        value: "en",
        storageKey: "nhs-locale",
        classes: "utility-banner-languages"
    }) %}
        <ul class="locale-picker-list" role="list">
            {% for code in LOCALES %}
            <li>
                <button
                    type="button"
                    class="locale-picker-button"
                    data-locale="{{ code }}"
                    aria-pressed="{{ 'true' if code == 'en' else 'false' }}"
                    lang="{{ code | replace('_', '-') }}"
                >{{ NATIVE[code] }}</button>
            </li>
            {% endfor %}
        </ul>
    {% endcall %}
</header>

<main>
    <h1>Welcome</h1>
    <p>Current locale: <code id="current-locale">en</code></p>
</main>

<script type="module">
    import { initLocalePicker } from "../locale-picker.client.js";

    document
        .querySelectorAll("[data-lily-locale-picker-root]")
        .forEach((root) => {
            const ctrl = initLocalePicker(root, {
                onChange(code) {
                    document.getElementById("current-locale").textContent = code;
                    root.querySelectorAll(".locale-picker-button")
                        .forEach((b) => {
                            b.setAttribute(
                                "aria-pressed",
                                String(b.dataset.locale === code),
                            );
                        });
                },
            });
            root.querySelectorAll(".locale-picker-button")
                .forEach((b) => {
                    b.addEventListener("click", () => {
                        ctrl.setLocale(b.dataset.locale);
                    });
                });
        });
</script>
