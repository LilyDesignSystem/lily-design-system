{#
  Example 07 — Native Intl.* formatters.

  For apps with a handful of strings and no formal i18n library,
  store the locale and pass it to Intl formatters directly. The
  picker still owns the `lang` / `dir` lifecycle.

  Outcome: picking a locale re-renders the date, currency, and
  number examples in that locale's formatting conventions, all
  without a page reload or any i18n library.
#}
{% from "../locale-picker.njk" import localePicker %}

{{ localePicker({
    label: "Language",
    locales: ["en", "en-US", "en-GB", "fr", "fr-CA", "de", "ar", "ja"],
    value: "en",
    storageKey: "app-locale"
}) }}

<section>
    <h2>Today</h2>
    <p id="today">…</p>

    <h2>Balance</h2>
    <p id="balance">…</p>

    <h2>Population of the United Kingdom</h2>
    <p id="population">…</p>
</section>

<script type="module">
    import {
        autoInit,
        bcp47LocaleTag,
    } from "../locale-picker.client.js";

    function format(code) {
        const tag = bcp47LocaleTag(code);
        const dateFmt = new Intl.DateTimeFormat(tag, { dateStyle: "long" });
        const currencyFmt = new Intl.NumberFormat(tag, {
            style: "currency", currency: "GBP",
        });
        const numFmt = new Intl.NumberFormat(tag);

        document.getElementById("today").textContent =
            dateFmt.format(new Date());
        document.getElementById("balance").textContent =
            currencyFmt.format(1234.56);
        document.getElementById("population").textContent =
            numFmt.format(67_330_000);
    }

    autoInit({ onChange: format });
</script>
