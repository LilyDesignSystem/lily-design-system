{#
  Example 10 — Combobox with native <datalist> type-ahead.

  For long locale lists (50+) where a radio group is impractical
  and a <select> is too tedious to scroll. Uses an <input list> +
  <datalist> for native, accessible type-ahead. We validate the
  typed text against the supported set before calling
  ctrl.setLocale(code).

  Outcome: type "Fr" — the combobox shows "Français", "Français
  (Canada)", etc. Pick one and the picker applies lang/dir.

  Browser support note: native <datalist> is widely supported
  but iOS Safari's UX is limited. For a fully APG-compliant
  combobox, swap in Lily's upstream `Combobox` headless primitive.
#}
{% from "./localePickerCustom.njk" import localePickerCustom %}

{% set LOCALES = [
    "en", "en-US", "en-GB", "en-AU", "en-CA", "en-IE", "en-IN", "en-NZ", "en-ZA",
    "fr", "fr-CA", "fr-BE", "fr-CH",
    "es", "es-419", "es-MX", "es-AR", "es-CL", "es-CO",
    "de", "de-AT", "de-CH",
    "pt", "pt-BR", "pt-PT",
    "it", "nl", "pl", "ru", "tr", "vi", "uk", "cs", "hu", "sv", "da", "fi", "no", "el", "ro", "bg",
    "zh-Hans", "zh-Hant", "ja", "ko",
    "ar", "he", "fa", "ur",
    "hi", "bn", "ta", "te", "ml", "th", "id", "ms"
] %}

{% set LABELS = {
    "en": "English", "en-US": "English (US)", "en-GB": "English (UK)",
    "en-AU": "English (Australia)", "en-CA": "English (Canada)",
    "en-IE": "English (Ireland)", "en-IN": "English (India)",
    "en-NZ": "English (New Zealand)", "en-ZA": "English (South Africa)",
    "fr": "Français", "fr-CA": "Français (Canada)",
    "fr-BE": "Français (Belgique)", "fr-CH": "Français (Suisse)",
    "es": "Español", "es-419": "Español (Latinoamérica)",
    "es-MX": "Español (México)", "es-AR": "Español (Argentina)",
    "es-CL": "Español (Chile)", "es-CO": "Español (Colombia)",
    "de": "Deutsch", "de-AT": "Deutsch (Österreich)",
    "de-CH": "Deutsch (Schweiz)",
    "pt": "Português", "pt-BR": "Português (Brasil)",
    "pt-PT": "Português (Portugal)",
    "it": "Italiano", "nl": "Nederlands", "pl": "Polski",
    "ru": "Русский", "tr": "Türkçe", "vi": "Tiếng Việt",
    "uk": "Українська", "cs": "Čeština", "hu": "Magyar",
    "sv": "Svenska", "da": "Dansk", "fi": "Suomi",
    "no": "Norsk", "el": "Ελληνικά", "ro": "Română", "bg": "Български",
    "zh-Hans": "简体中文", "zh-Hant": "繁體中文",
    "ja": "日本語", "ko": "한국어",
    "ar": "العربية", "he": "עברית", "fa": "فارسی", "ur": "اردو",
    "hi": "हिन्दी", "bn": "বাংলা", "ta": "தமிழ்", "te": "తెలుగు",
    "ml": "മലയാളം", "th": "ไทย", "id": "Bahasa Indonesia",
    "ms": "Bahasa Melayu"
} %}

{% call localePickerCustom({
    label: "Language",
    locales: LOCALES,
    value: "en",
    storageKey: "combobox-locale"
}) %}
    <input
        type="text"
        class="locale-picker-combobox"
        list="locale-options"
        placeholder="Start typing a language…"
        aria-label="Language"
        autocomplete="off"
        value="English"
    />
    <datalist id="locale-options">
        {% for code in LOCALES %}
        <option value="{{ LABELS[code] or code }}" lang="{{ code }}">{{ code }}</option>
        {% endfor %}
    </datalist>
{% endcall %}

<p>Selected locale: <code id="current-locale">en</code></p>

<script type="module">
    import { initLocalePicker } from "../locale-picker.client.js";

    const LABELS = {{ LABELS | dump | safe }};
    const LABEL_TO_CODE = Object.fromEntries(
        Object.entries(LABELS).map(([code, label]) => [label.toLowerCase(), code]),
    );

    document
        .querySelectorAll("[data-lily-locale-picker-root]")
        .forEach((root) => {
            const input = root.querySelector(".locale-picker-combobox");
            const ctrl = initLocalePicker(root, {
                onChange(code) {
                    document.getElementById("current-locale").textContent = code;
                    if (input && document.activeElement !== input) {
                        input.value = LABELS[code] || code;
                    }
                },
            });
            input?.addEventListener("change", (e) => {
                const typed = e.currentTarget.value.trim().toLowerCase();
                const match = LABEL_TO_CODE[typed];
                if (match) ctrl.setLocale(match);
            });
        });
</script>
