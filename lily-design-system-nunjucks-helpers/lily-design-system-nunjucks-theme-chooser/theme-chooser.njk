{#
  ThemeChooser macro — icon button that opens a listbox of themes.

  HTML tag: <div> (root), <button> + <ul role="listbox">
  CSS class: theme-chooser
  Companion runtime: theme-chooser.client.js

  BREAKING (Unreleased): this macro no longer renders a native
  <select>. It renders an icon button (U+25D1 CIRCLE WITH RIGHT HALF
  BLACK) that opens a listbox. The `placeholder` param is GONE — there
  is no <select> left to pin a placeholder onto.

  Params (single `opts` object):
    label         — string, required. aria-label for the button AND the
                    listbox. The button is icon-only, so this is the
                    ONLY accessible name it has.
    themesUrl     — string, required. Base URL of the themes directory.
    themes        — array<string>, required. Available theme slugs.
    value         — string. Initial slug, emitted as
                    data-lily-theme-chooser-value for the client to read.
    defaultValue  — string. Initial slug when nothing else is supplied.
    storageKey    — string. If non-empty, client.js persists to localStorage.
    detectFromSystem — boolean. If true, client.js resolves
                    `prefers-color-scheme` to "dark"/"light" when neither
                    `value` nor storage supplied a slug. Client-only:
                    matchMedia does not exist at render time, so this
                    never affects the server-rendered aria-selected.
    name          — string. Hidden-input `name` AND the discriminator on
                    the managed <link data-lily-theme-chooser="{name}">
                    (default "theme").
    extension     — string. Appended to slug for URL (default ".css").
    themeLabels   — object<string,string>. Pretty label per slug.
    id            — string. Id prefix for the listbox and its options.
                    Defaults to "theme-chooser-{name}". Supply an explicit
                    id when rendering two instances that share a `name`.
    classes       — string. Extra CSS classes on the root <div>.
    attributes    — object. Extra HTML attributes spread onto the root.

  Custom glyph: call the macro with a `{% call %}` block and the block
  body replaces the default glyph inside the button:

    {% call themeChooser({label: "Theme", themesUrl: "/t/", themes: [...]}) %}
      <svg aria-hidden="true">…</svg>
    {% endcall %}

  Usage:
    {% from "./theme-chooser.njk" import themeChooser %}
    {{ themeChooser({
      label: "Theme",
      themesUrl: "/assets/themes/",
      themes: ["light", "dark", "abyss"],
      storageKey: "lily-theme"
    }) }}

  Then load theme-chooser.client.js once and call autoInit().

  NOTE: the button does nothing until theme-chooser.client.js runs. See
  docs/ssr.md — this is a real no-JS regression from the old <select>.

  Spec: spec/index.md §4.1 (macro parameters), §4.2 (DOM contract).
#}
{%- macro themeChooser(opts) -%}
{%- set name = opts.name | default("theme") -%}
{%- set extension = opts.extension | default(".css") -%}
{%- set value = opts.value | default("") -%}
{%- set storageKey = opts.storageKey | default("") -%}
{%- set defaultValue = opts.defaultValue | default("") -%}
{%- set detectFromSystem = opts.detectFromSystem | default(false) -%}
{%- set themeLabels = opts.themeLabels | default({}) -%}
{%- set id = opts.id | default("theme-chooser-" + name) -%}
{%- set listId = id + "-list" -%}
{#- Server-side selected resolution. storage and the system colour-scheme
    preference are client-only — there is no localStorage and no
    matchMedia at render time — so the client may correct this after
    hydration; the point is that the server markup always marks exactly
    one option aria-selected. -#}
{%- set fallback = "light" if "light" in opts.themes else opts.themes[0] -%}
{%- set selected = value or defaultValue or fallback -%}
<div
  class="theme-chooser{% if opts.classes %} {{ opts.classes }}{% endif %}"
  data-lily-theme-chooser-root
  data-lily-theme-chooser-name="{{ name }}"
  data-lily-theme-chooser-themes-url="{{ opts.themesUrl }}"
  data-lily-theme-chooser-extension="{{ extension }}"
  data-lily-theme-chooser-storage-key="{{ storageKey }}"
  data-lily-theme-chooser-default-value="{{ defaultValue }}"
  data-lily-theme-chooser-detect-from-system="{{ 'true' if detectFromSystem else 'false' }}"
  {%- if value %} data-lily-theme-chooser-value="{{ value }}"{% endif %}
  {%- if opts.attributes %}{% for k, v in opts.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
<input type="hidden" name="{{ name }}" value="{{ selected }}" data-lily-theme-chooser-input>
<button type="button" class="theme-chooser-button" aria-label="{{ opts.label }}" aria-haspopup="listbox" aria-expanded="false" aria-controls="{{ listId }}" data-lily-theme-chooser-button>
{%- if caller %}{{ caller() }}{% else %}<span class="theme-chooser-icon" aria-hidden="true">&#9681;</span>{% endif -%}
</button>
<ul class="theme-chooser-list" id="{{ listId }}" role="listbox" aria-label="{{ opts.label }}" tabindex="-1" hidden data-lily-theme-chooser-list>
{%- for slug in opts.themes -%}
  <li class="theme-chooser-option" id="{{ id }}-option-{{ loop.index0 }}" role="option" aria-selected="{{ 'true' if slug == selected else 'false' }}" data-value="{{ slug }}">
    {%- if themeLabels[slug] -%}
      {{ themeLabels[slug] }}
    {%- else -%}
      {{ slug | replace(r/-/g, " ") | title }}
    {%- endif -%}
  </li>
{%- endfor -%}
</ul>
</div>
{%- endmacro -%}
