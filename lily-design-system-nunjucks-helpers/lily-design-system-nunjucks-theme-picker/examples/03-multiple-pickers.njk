{#
  Example 03 — Multiple pickers in one page.

  Each picker gets a distinct `name`. The `name` plays two roles:
    1. It is the radio-input `name`, so the two groups don't share
       state.
    2. It is the discriminator on the managed <link> element, so
       each picker swaps its own stylesheet without stepping on the
       other.

  This is useful for: a "global" theme + a per-section accent theme;
  preview-vs-live theme A/B; or a settings page that compares two
  themes side-by-side.

  Note: the active `data-theme` attribute on <html> is set by
  whichever picker fires last. To make two independent regions, pass
  a per-picker `target` via the client.js init opts (see the script
  below).
#}
{% from "../theme-picker.njk" import themePicker %}

<section class="region region-a">
    <h2>Region A</h2>
    {{ themePicker({
        label: "Region A theme",
        name: "region-a",
        themesUrl: "/assets/themes/",
        themes: ["light", "dark"]
    }) }}
</section>

<section class="region region-b">
    <h2>Region B</h2>
    {{ themePicker({
        label: "Region B theme",
        name: "region-b",
        themesUrl: "/assets/themes/",
        themes: ["abyss", "cupcake", "dracula"]
    }) }}
</section>

<script type="module">
    import { initThemePicker } from "../theme-picker.client.js";

    const a = document.querySelector(
        "[data-lily-theme-picker-root][data-lily-theme-picker-name='region-a']",
    );
    const b = document.querySelector(
        "[data-lily-theme-picker-root][data-lily-theme-picker-name='region-b']",
    );
    if (a) initThemePicker(a, { target: a.closest("section.region-a") });
    if (b) initThemePicker(b, { target: b.closest("section.region-b") });
</script>
