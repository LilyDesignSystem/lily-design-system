{#
  TextSizeSelect macro — accessible native <select> of text sizes.

  HTML tag: <select>
  CSS class: text-size-select
  Companion runtime: text-size-select.client.js

  Params (single `opts` object):
    label         — string, required. aria-label for the <select>.
    sizes         — array<string>, required. Available size slugs.
    value         — string. Initial selected slug (rendered selected).
    defaultValue  — string. Initial slug when nothing else is supplied.
    storageKey    — string. If non-empty, client.js persists to localStorage.
    name          — string. <select> `name` (default "text-size").
    sizeLabels    — object<string,string>. Pretty label per slug.
    classes       — string. Extra CSS classes on the <select> root.
    attributes    — object. Extra HTML attributes spread onto the root.

  The chosen slug is applied to the document root via
  `data-text-size="{slug}"`; the consumer styles each
  `[data-text-size="…"]` to a real typographic scale.

  Spec: spec.md §4.1, §4.2.
#}
{%- macro textSizeSelect(opts) -%}
{%- set name = opts.name | default("text-size") -%}
{%- set value = opts.value | default("") -%}
{%- set storageKey = opts.storageKey | default("") -%}
{%- set defaultValue = opts.defaultValue | default("") -%}
{%- set sizeLabels = opts.sizeLabels | default({}) -%}
<select
  class="text-size-select{% if opts.classes %} {{ opts.classes }}{% endif %}"
  aria-label="{{ opts.label }}"
  name="{{ name }}"
  data-lily-text-size-select-root
  data-lily-text-size-select-name="{{ name }}"
  data-lily-text-size-select-storage-key="{{ storageKey }}"
  data-lily-text-size-select-default-value="{{ defaultValue }}"
  {%- if opts.attributes %}{% for k, v in opts.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- for slug in opts.sizes -%}
  <option class="text-size-select-option" value="{{ slug }}"{% if value == slug %} selected{% endif %}>
    {%- if sizeLabels[slug] -%}
      {{ sizeLabels[slug] }}
    {%- else -%}
      {{ slug | replace(r/-/g, " ") | title }}
    {%- endif -%}
  </option>
{%- endfor -%}
</select>
{%- endmacro -%}
