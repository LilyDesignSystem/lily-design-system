{#
  Example 03 — Multiple selects in one page.

  Each select gets a distinct `name`. The `name` plays two roles:
    1. It is the <select> `name` attribute, so the two controls
       don't share state.
    2. It is the discriminator on the managed <link> element, so
       each select swaps its own stylesheet without stepping on the
       other.

  This is useful for: a "global" theme + a per-section accent theme;
  preview-vs-live theme A/B; or a settings page that compares two
  themes side-by-side.

  Note: the active `data-theme` attribute on <html> is set by
  whichever select fires last. To make two independent regions, pass
  a per-select `target` via the client.js init opts (see the script
  below).
#}
{% from "../theme-select.njk" import themeSelect %}

<section class="region region-a">
    <h2>Region A</h2>
    {{ themeSelect({
        label: "Region A theme",
        name: "region-a",
        themesUrl: "/assets/themes/",
        themes: ["light", "dark"]
    }) }}
</section>

<section class="region region-b">
    <h2>Region B</h2>
    {{ themeSelect({
        label: "Region B theme",
        name: "region-b",
        themesUrl: "/assets/themes/",
        themes: ["abyss", "cupcake", "dracula"]
    }) }}
</section>

<script type="module">
    import { initThemeSelect } from "../theme-select.client.js";

    const a = document.querySelector(
        "[data-lily-theme-select-root][data-lily-theme-select-name='region-a']",
    );
    const b = document.querySelector(
        "[data-lily-theme-select-root][data-lily-theme-select-name='region-b']",
    );
    if (a) initThemeSelect(a, { target: a.closest("section.region-a") });
    if (b) initThemeSelect(b, { target: b.closest("section.region-b") });
</script>
