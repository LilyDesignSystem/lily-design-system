{#
  ThemeSelect macro — accessible native <select> of available themes.

  HTML tag: <select>
  CSS class: theme-select
  Companion runtime: theme-select.client.js

  Params (single `opts` object):
    label         — string, required. aria-label for the <select>.
    themesUrl     — string, required. Base URL of the themes directory.
    themes        — array<string>, required. Available theme slugs.
    value         — string. Initial selected slug (rendered selected).
    defaultValue  — string. Initial slug when nothing else is supplied.
    storageKey    — string. If non-empty, client.js persists to localStorage.
    name          — string. <select> `name` attribute (default "theme").
    extension     — string. Appended to slug for URL (default ".css").
    themeLabels   — object<string,string>. Pretty label per slug.
    classes       — string. Extra CSS classes on the <select> root.
    attributes    — object. Extra HTML attributes spread onto the root.

  Usage:
    {% from "./theme-select.njk" import themeSelect %}
    {{ themeSelect({
      label: "Theme",
      themesUrl: "/assets/themes/",
      themes: ["light", "dark", "abyss"],
      storageKey: "lily-theme"
    }) }}

  Then load theme-select.client.js once and call autoInit().

  Spec: spec/index.md §4.1 (macro parameters), §4.2 (DOM contract).
#}
{%- macro themeSelect(opts) -%}
{%- set name = opts.name | default("theme") -%}
{%- set extension = opts.extension | default(".css") -%}
{%- set value = opts.value | default("") -%}
{%- set storageKey = opts.storageKey | default("") -%}
{%- set defaultValue = opts.defaultValue | default("") -%}
{%- set themeLabels = opts.themeLabels | default({}) -%}
<select
  class="theme-select{% if opts.classes %} {{ opts.classes }}{% endif %}"
  aria-label="{{ opts.label }}"
  name="{{ name }}"
  data-lily-theme-select-root
  data-lily-theme-select-name="{{ name }}"
  data-lily-theme-select-themes-url="{{ opts.themesUrl }}"
  data-lily-theme-select-extension="{{ extension }}"
  data-lily-theme-select-storage-key="{{ storageKey }}"
  data-lily-theme-select-default-value="{{ defaultValue }}"
  {%- if opts.attributes %}{% for k, v in opts.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
{%- for slug in opts.themes -%}
  <option class="theme-select-option" value="{{ slug }}"{% if value == slug %} selected{% endif %}>
    {%- if themeLabels[slug] -%}
      {{ themeLabels[slug] }}
    {%- else -%}
      {{ slug | replace(r/-/g, " ") | title }}
    {%- endif -%}
  </option>
{%- endfor -%}
</select>
{%- endmacro -%}
