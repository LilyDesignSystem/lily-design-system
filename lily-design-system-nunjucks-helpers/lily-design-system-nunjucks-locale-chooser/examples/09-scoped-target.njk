{#
  Example 09 — Scoped target (change locale of one region, not the
  whole page).

  Useful for multilingual content panels: a single page with two
  cards each in a different language. Pass `target: panelEl` so
  the select writes lang/dir to that element instead of <html>.

  Outcome: the surrounding page stays in its document language;
  the chosen panel switches independently. Two panels each scoped
  to their own select.

  Note the explicit `id` on each instance. Listbox and option ids are
  derived from `opts.id`, which defaults to "locale-chooser-{name}" —
  so two instances that share the default `name` would emit duplicate
  ids and break `aria-controls` / `aria-activedescendant`. A Nunjucks
  macro cannot hold a module counter, so passing distinct ids is the
  framework's stable-id mechanism.
#}
{% from "../locale-chooser.njk" import localeChooser %}

<article>
    <h1>Document language stays English; panels switch independently.</h1>

    <section id="panel-a" class="panel" lang="en">
        <h2>Panel A</h2>
        {{ localeChooser({
            label: "Panel A language",
            locales: ["en", "fr", "ar"],
            value: "en",
            id: "panel-a-locale",
            attributes: { "data-scope": "a" }
        }) }}
        <p class="panel-body">Sample content scoped to Panel A.</p>
        <p>Current locale: <code class="panel-locale">en</code></p>
    </section>

    <section id="panel-b" class="panel" lang="fr">
        <h2>Panel B</h2>
        {{ localeChooser({
            label: "Panel B language",
            locales: ["en", "fr", "ar"],
            value: "fr",
            id: "panel-b-locale",
            attributes: { "data-scope": "b" }
        }) }}
        <p class="panel-body">Contenu d'exemple limité au Panneau B.</p>
        <p>Current locale: <code class="panel-locale">fr</code></p>
    </section>
</article>

<script type="module">
    import { initLocaleChooser } from "../locale-chooser.client.js";

    // Wire each select to its enclosing <section> as the target.
    document
        .querySelectorAll("[data-lily-locale-chooser-root]")
        .forEach((root) => {
            const panel = root.closest(".panel");
            initLocaleChooser(root, {
                target: panel,
                onChange(code) {
                    panel.querySelector(".panel-locale").textContent = code;
                },
            });
        });
</script>
