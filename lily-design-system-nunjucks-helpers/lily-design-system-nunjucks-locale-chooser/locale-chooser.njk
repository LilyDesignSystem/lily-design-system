{#
  LocaleChooser macro — icon button that opens a listbox of locales.

  HTML tag: <div> (root), <button> + <ul role="listbox">
  CSS class: locale-chooser
  Companion runtime: locale-chooser.client.js

  BREAKING (Unreleased): this macro no longer renders a native
  <select>. It renders an icon button (U+1F310 GLOBE WITH MERIDIANS + U+FE0E VARIATION SELECTOR-15)
  that opens a listbox. The `placeholder` param is GONE — there is no
  <select> left to pin a placeholder onto.

  Params (single `opts` object):
    label                — string, required. aria-label for the button AND
                           the listbox. The button is icon-only, so this
                           is the ONLY accessible name it has.
    locales              — array<string>, required. Available locale codes.
    value                — string. Initial code, emitted as
                           data-lily-locale-chooser-value for the client.
    defaultValue         — string. Initial code when nothing else is supplied.
    storageKey           — string. If non-empty, client.js persists to localStorage.
    detectFromNavigator  — boolean. If true, client.js resolves navigator.languages.
    name                 — string. Hidden-input `name` (default "locale").
    applyDir             — boolean. If false, client.js never writes `dir`.
    localeLabels         — object<string,string>. Pretty label per code.
    id                   — string. Id prefix for the listbox and its options.
                           Defaults to "locale-chooser-{name}". Supply an
                           explicit id when rendering two instances that
                           share a `name`.
    classes              — string. Extra CSS classes on the root <div>.
    attributes           — object. Extra HTML attributes spread onto the root.

  Each <li role="option"> carries `lang="{tagFor(code)}"` (BCP 47
  hyphen form) so assistive technology pronounces the option text in
  the appropriate language even when the document language differs
  (WCAG 3.1.2, Language of Parts). The button and the listbox do NOT
  carry `lang` — they are chrome, not content.

  Custom glyph: call the macro with a `{% call %}` block and the block
  body replaces the default globe inside the button.

  NOTE: the button does nothing until locale-chooser.client.js runs. See
  docs/ssr.md — this is a real no-JS regression from the old <select>.

  Spec: spec/index.md §4.1, §4.2.
#}
{%- macro localeChooser(opts) -%}
{%- set name = opts.name | default("locale") -%}
{%- set value = opts.value | default("") -%}
{%- set storageKey = opts.storageKey | default("") -%}
{%- set defaultValue = opts.defaultValue | default("") -%}
{%- set detectFromNavigator = opts.detectFromNavigator | default(false) -%}
{%- set applyDir = opts.applyDir if opts.applyDir is sameas(false) else true -%}
{%- set localeLabels = opts.localeLabels | default({}) -%}
{%- set id = opts.id | default("locale-chooser-" + name) -%}
{%- set listId = id + "-list" -%}
{#- Server-side selected resolution. storage / navigator are client-only,
    so the client may correct this after hydration; the point is that the
    server markup always marks exactly one option aria-selected. -#}
{%- set fallback = "en" if "en" in opts.locales else opts.locales[0] -%}
{%- set selected = value or defaultValue or fallback -%}
<div
  class="locale-chooser{% if opts.classes %} {{ opts.classes }}{% endif %}"
  data-lily-locale-chooser-root
  data-lily-locale-chooser-name="{{ name }}"
  data-lily-locale-chooser-storage-key="{{ storageKey }}"
  data-lily-locale-chooser-default-value="{{ defaultValue }}"
  data-lily-locale-chooser-detect-from-navigator="{{ 'true' if detectFromNavigator else 'false' }}"
  data-lily-locale-chooser-apply-dir="{{ 'true' if applyDir else 'false' }}"
  {%- if value %} data-lily-locale-chooser-value="{{ value }}"{% endif %}
  {%- if opts.attributes %}{% for k, v in opts.attributes %} {{ k }}="{{ v }}"{% endfor %}{% endif %}
>
<input type="hidden" name="{{ name }}" value="{{ selected }}" data-lily-locale-chooser-input>
<button type="button" class="locale-chooser-button" aria-label="{{ opts.label }}" aria-haspopup="listbox" aria-expanded="false" aria-controls="{{ listId }}" data-lily-locale-chooser-button>
{%- if caller %}{{ caller() }}{% else %}<span class="locale-chooser-icon" aria-hidden="true">&#127760;&#65038;</span>{% endif -%}
</button>
<ul class="locale-chooser-list" id="{{ listId }}" role="listbox" aria-label="{{ opts.label }}" tabindex="-1" hidden data-lily-locale-chooser-list>
{%- for locale in opts.locales -%}
  {%- set tag = locale | replace("_", "-") -%}
  <li class="locale-chooser-option" id="{{ id }}-option-{{ loop.index0 }}" role="option" aria-selected="{{ 'true' if locale == selected else 'false' }}" data-value="{{ locale }}" lang="{{ tag }}">
    {%- if localeLabels[locale] -%}
      {{ localeLabels[locale] }}
    {%- else -%}
      {{ locale }}
    {%- endif -%}
  </li>
{%- endfor -%}
</ul>
</div>
{%- endmacro -%}
