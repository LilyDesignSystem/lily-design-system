@namespace LilyBlazorHeadless.Components

@*
    GanttTableTfoot component
    a Gantt chart table interactive grid tfoot for planning schedule visualization <tfoot>
*@

<tfoot class="@($"gantt-table-tfoot {CssClass}".Trim())" aria-label="@Label" @attributes="AdditionalAttributes">@ChildContent</tfoot>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
