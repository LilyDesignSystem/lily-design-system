@namespace LilyBlazorHeadless.Components

@*
    EnglandNationalHealthServiceNumberInput component
    an input for entering England's National Health Service Number (NHS)
*@

<input class="@($"england-national-health-service-number-input {CssClass}".Trim())" type="text" aria-label="@Label" autocomplete="off" @attributes="AdditionalAttributes" />

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
