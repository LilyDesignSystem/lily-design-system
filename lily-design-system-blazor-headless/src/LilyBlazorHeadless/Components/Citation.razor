@namespace LilyBlazorHeadless.Components

@*
    Citation component
    a citation acknowledges the relevance of a work of another to the topic of discussion
*@

<cite class="@($"citation {CssClass}".Trim())" aria-label="@Label" @attributes="AdditionalAttributes">@ChildContent</cite>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
