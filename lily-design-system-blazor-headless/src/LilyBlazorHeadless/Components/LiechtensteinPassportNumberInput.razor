@namespace LilyBlazorHeadless.Components

@*
    LiechtensteinPassportNumberInput component
    an input for entering Liechtenstein's Liechtenstein Passport Number
*@

<input class="@($"liechtenstein-passport-number-input {CssClass}".Trim())" type="text" aria-label="@Label" autocomplete="off" @attributes="AdditionalAttributes" />

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
