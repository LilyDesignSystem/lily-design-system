@namespace LilyBlazorHeadless.Components

@*
    Draft component
    a wrapper marking content as a work-in-progress draft with an optional status.
*@

<div class="@($"draft {CssClass}".Trim())" aria-label="@Label" data-status="@(string.IsNullOrEmpty(Status) ? null : Status)" @attributes="AdditionalAttributes">@ChildContent</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Status { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
