@namespace LilyBlazorHeadless.Components

@*
    ElladaDematerialisedSecuritiesSystemInput component
    an input for entering Greece's Dematerialised Securities System (DSS)
*@

<input class="@($"ellada-dematerialised-securities-system-input {CssClass}".Trim())" type="text" aria-label="@Label" autocomplete="off" @attributes="AdditionalAttributes" />

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
