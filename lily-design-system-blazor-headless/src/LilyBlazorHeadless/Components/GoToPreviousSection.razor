@namespace LilyBlazorHeadless.Components

@*
    GoToPreviousSection component
    A link that takes users to the previous section of the current page.
*@

<a class="@($"go-to-previous-section {CssClass}".Trim())" href="@Href" aria-label="@Label" @attributes="AdditionalAttributes">@Label</a>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
